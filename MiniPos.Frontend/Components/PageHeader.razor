<div class="flex flex-col gap-6 mb-8 animate-slide-down">
    <!-- Main Header Row -->
    <div
        class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6 pb-6 border-b border-border/30">
        <div class="space-y-1">
            <h1 class="text-4xl font-black tracking-tight text-foreground font-outfit">@Title</h1>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <p class="text-muted-foreground font-medium text-sm flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary/40"></span>
                    @Subtitle
                </p>
            }
        </div>

        <div class="flex flex-wrap items-center gap-3 w-full lg:w-auto">

            <!-- View Mode Toggle -->
            @if (ShowViewToggle)
            {
                <div class="flex bg-muted/30 p-1 rounded-2xl border border-border/40 shadow-sm shrink-0">
                    <button
                        class="p-2 rounded-xl transition-all @(ViewMode == "grid" ? "bg-white shadow-sm text-primary" : "text-muted-foreground hover:text-foreground")"
                        @onclick='() => SetViewMode("grid")'
                        title="Grid View">
                        <i data-lucide="layout-grid" class="w-4 h-4"></i>
                    </button>
                    <button
                        class="p-2 rounded-xl transition-all @(ViewMode == "list" ? "bg-white shadow-sm text-primary" : "text-muted-foreground hover:text-foreground")"
                        @onclick='() => SetViewMode("list")'
                        title="List View">
                        <i data-lucide="list" class="w-4 h-4"></i>
                    </button>
                </div>
            }

            <!-- Search Command -->
            @if (ShowSearch)
            {
                <div class="relative flex-1 sm:w-64 group/search">
                    <i data-lucide="search"
                       class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within/search:text-primary transition-colors"></i>
                    <input type="text"
                           value="@SearchTerm"
                           @oninput="HandleSearchInput"
                           @onkeyup="HandleKeyUp"
                           placeholder="@SearchPlaceholder"
                           class="w-full pl-10 pr-10 py-2.5 bg-white border border-border/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm"/>
                    @if (!string.IsNullOrEmpty(SearchTerm))
                    {
                        <button
                            class="absolute right-2 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-lg hover:bg-red-50 text-muted-foreground/40 hover:text-red-500 transition-all active:scale-95"
                            @onclick="ClearSearch">
                            <i data-lucide="x" class="w-3.5 h-3.5"></i>
                        </button>
                    }
                </div>
            }

            <!-- Filters Slot -->
            @if (Filters != null)
            {
                <div class="flex items-center gap-3">
                    @Filters
                </div>
            }

            <!-- Actions Slot -->
            @if (Actions != null)
            {
                <div class="flex items-center gap-2">
                    @Actions
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string SearchPlaceholder { get; set; } = "Search...";
    [Parameter] public string SearchTerm { get; set; } = "";

    [Parameter] public EventCallback<string?> SearchTermChanged { get; set; }
    [Parameter] public EventCallback<string?> OnSearch { get; set; }

    [Parameter] public bool ShowViewToggle { get; set; } = true;
    [Parameter] public bool ShowSearch { get; set; } = true;
    [Parameter] public string ViewMode { get; set; } = "grid";

    [Parameter] public EventCallback<string> ViewModeChanged { get; set; }

    [Parameter] public RenderFragment? Filters { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    private string _localSearchTerm = "";

    protected override void OnParametersSet()
    {
        _localSearchTerm = SearchTerm;
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        SearchTerm = e.Value?.ToString() ?? "";
        await SearchTermChanged.InvokeAsync(SearchTerm);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await OnSearch.InvokeAsync(_localSearchTerm);
        }
    }

    private async Task ClearSearch()
    {
        SearchTerm = "";
        _localSearchTerm = "";
        await SearchTermChanged.InvokeAsync(SearchTerm);
        await OnSearch.InvokeAsync(SearchTerm);
    }

    private async Task SetViewMode(string mode)
    {
        ViewMode = mode;
        await ViewModeChanged.InvokeAsync(ViewMode);
    }

}
