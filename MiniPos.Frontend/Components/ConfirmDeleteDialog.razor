<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column align-center">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" Class="mb-4"/>
            <MudText Typo="Typo.h6" Align="Align.Center">@Title</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-2">
                @ContentText
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-4">
                This action cannot be undone.
            </MudText>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Confirm">Delete Permanently</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string Title { get; set; } = "Confirm Delete";

    [Parameter] public string ContentText { get; set; } = "Are you sure you want to delete this item?";

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Confirm()
    {
        // Closes the dialog and returns 'Canceled = false' to the calling page
        MudDialog.Close(DialogResult.Ok(true));
    }

}