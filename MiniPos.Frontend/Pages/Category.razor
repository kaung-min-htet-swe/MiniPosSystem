@page "/categories"
@using MiniPos.Frontend.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>MiniPos:Category</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudTable ServerData="@MockServerReload"
              Dense="true"
              Hover="true"
              Elevation="3"
              @ref="_table">

        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Categories</MudText>
            <MudSpacer/>

            <MudTextField T="string"
                          ValueChanged="@(s => OnSearch(s))"
                          Placeholder="Search categories..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0"
                          Clearable="true"/>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="ml-4"
                       Href="/categories/create">
                Add Category
            </MudButton>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortLabel="Name" T="CategoryResponseDto">Name</MudTableSortLabel>
            </MudTh>
            <MudTh>Description</MudTh>
            <MudTh>
                <MudTableSortLabel SortLabel="Merchant" T="CategoryResponseDto">Merchant</MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.subtitle2">@context.Name</MudText>
            </MudTd>

            <MudTd DataLabel="Description">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    @(string.IsNullOrEmpty(context.Description) ? "No description" : context.Description)
                </MudText>
            </MudTd>

            <MudTd DataLabel="Merchant">
                @if (context.Merchant != null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                        @context.Merchant.Name
                    </MudChip>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">Unassigned</MudText>
                }
            </MudTd>

            <MudTd DataLabel="Actions" Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Info"
                               Size="Size.Small"
                               Href="@($"/categories/edit/{context.Id}")"/>

                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => PromptDelete(context.Id, context.Name))"/>
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText>No categories found.</MudText>
        </NoRecordsContent>

        <LoadingContent>
            <MudText>Loading categories...</MudText>
        </LoadingContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }"/>
        </PagerContent>
    </MudTable>
</MudContainer>
