@page "/branches/create"
@using MiniPos.Frontend.Mocks
@using MiniPos.Frontend.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IMockBranch MockBranch
@inject IMockMerchant MockMerchant

<MudCard Elevation="3">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Create New Branch</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Add a new physical location for a merchant.</MudText>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        @if (_isLoadingMerchants)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4"/>
            <MudText Typo="Typo.caption">Loading available merchants...</MudText>
        }
        else
        {
            <MudForm @ref="_form" Model="@_branchModel">

                <MudSelect T="string"
                           Label="Assign to Merchant"
                           @bind-Value="@_branchModel.MerchantId"
                           Required="true"
                           RequiredError="You must select a merchant."
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Class="mb-4">
                    @foreach (var merchant in _availableMerchants)
                    {
                        <MudSelectItem Value="@merchant.Id">@merchant.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudTextField @bind-Value="@_branchModel.Name"
                              Label="Branch Name"
                              Required="true"
                              RequiredError="Branch name is required."
                              Variant="Variant.Outlined"
                              Placeholder="e.g., Yangon Downtown"
                              Class="mb-4"/>

                <MudTextField @bind-Value="@_branchModel.Address"
                              Label="Physical Address (Optional)"
                              Lines="3"
                              Variant="Variant.Outlined"
                              Placeholder="Enter full address details..."
                              Class="mb-4"/>
            </MudForm>
        }
    </MudCardContent>

    <MudCardActions Class="pb-4 pl-4 pr-4 d-flex justify-end">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="Cancel"
                   Class="mr-2">
            Cancel
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SubmitForm"
                   Disabled="@(_isLoadingMerchants || _isSaving)">
            @if (_isSaving)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                <MudText Class="ms-2">Creating...</MudText>
            }
            else
            {
                <MudText>Create Branch</MudText>
            }
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    private MudForm _form = null!;
    private readonly BranchCreateRequestDto _branchModel = new();
    private List<MerchantResponseDto> _availableMerchants = new();
    private bool _isLoadingMerchants = true;
    private bool _isSaving;

    public record MerchantLookupDto(Guid Id, string Name);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = MockMerchant.GetList();
            _availableMerchants = response.Data;
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load merchants. Please check your connection.", Severity.Error);
        }
        finally
        {
            _isLoadingMerchants = false;
        }
    }

    private async Task SubmitForm()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _isSaving = true;
        try
        {
            // var response = await Http.PostAsJsonAsync("api/branches", _branchModel);
            var response = new { IsSuccessStatusCode = MockBranch.Create(_branchModel) };
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Branch created successfully!", Severity.Success);
                Navigation.NavigateTo("/branches"); // Send them back to the list
            }
            else
            {
                Snackbar.Add("Failed to create branch. Check your inputs.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("A network error occurred.", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/branches");
    }

}