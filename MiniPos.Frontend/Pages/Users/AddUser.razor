@page "/users/add"
@using MiniPos.Frontend.Shared.Types
@inject NotificationService Notification

<PageTitle>Add Staff - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-4xl mx-auto pb-12 relative">
    <!-- Header -->
    <div class="mb-6 flex items-center justify-between">
        <button
            class="group flex items-center gap-2.5 px-4 py-2 rounded-xl bg-white/40 hover:bg-white/60 border border-white/20 hover:border-white/40 shadow-sm transition-all duration-300 backdrop-blur-md"
            @onclick="GoBack">
            <i data-lucide="arrow-left" class="w-4 h-4 text-muted-foreground group-hover:-translate-x-1 transition-transform"></i>
            <span class="font-bold text-[10px] uppercase tracking-widest text-muted-foreground group-hover:text-foreground">Back to Staff</span>
        </button>

        <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/5 border border-primary/10">
            <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></div>
            <span class="text-[10px] font-bold text-primary uppercase tracking-tighter">Registration Portal</span>
        </div>
    </div>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
        <div>
            <h1 class="text-3xl font-black tracking-tighter text-foreground mb-2">Create New Identity</h1>
            <p class="text-sm text-muted-foreground font-medium">Provision a new staff account with specific permissions.</p>
        </div>

        <!-- Premium Role Selection -->
        <div class="flex p-1.5 bg-white/40 backdrop-blur-xl rounded-2xl border border-white/30 shadow-inner-white w-fit">
            <button class="px-8 py-2.5 rounded-xl text-[11px] font-black transition-all duration-500 flex items-center gap-2.5 uppercase tracking-wider
                @(_selectedRole == "Merchant" ? "bg-white text-primary shadow-xl shadow-primary/10 border border-primary/10 scale-[1.02]" : "text-muted-foreground hover:text-foreground hover:bg-white/20")"
                    @onclick='() => SelectRole("Merchant")'>
                <i data-lucide="shield-check" class="w-3.5 h-3.5 @(_selectedRole == "Merchant" ? "text-primary" : "")"></i>
                Merchant
            </button>
            <button class="px-8 py-2.5 rounded-xl text-[11px] font-black transition-all duration-500 flex items-center gap-2.5 uppercase tracking-wider
                @(_selectedRole == "Cashier" ? "bg-white text-emerald-600 shadow-xl shadow-emerald-500/10 border border-emerald-500/10 scale-[1.02]" : "text-muted-foreground hover:text-foreground hover:bg-white/20")"
                    @onclick='() => SelectRole("Cashier")'>
                <i data-lucide="credit-card" class="w-3.5 h-3.5 @(_selectedRole == "Cashier" ? "text-emerald-500" : "")"></i>
                Cashier
            </button>
        </div>
    </div>


    <!-- Main Form Card with Deep Glassmorphism -->
    <div class="relative overflow-hidden group">
        <!-- Background decorative elements -->
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none group-hover:bg-primary/10 transition-colors duration-1000"></div>
        <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl pointer-events-none group-hover:bg-emerald-500/10 transition-colors duration-1000"></div>

        <div class="pos-card p-0 overflow-hidden bg-white/50 backdrop-blur-3xl shadow-[0_20px_50px_-12px_rgba(0,0,0,0.08)] border-white/40 animate-slide-up relative z-10">
            <!-- Form Header Ribbon -->
            <div class="h-1.5 w-full bg-gradient-to-r from-primary/40 via-primary/60 to-emerald-400/40"></div>
            
            <!-- Form Content -->
            <div class="p-8 md:p-10 space-y-10">
                <!-- Account Section -->
                <section class="space-y-6">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                            <i data-lucide="user-plus" class="w-4 h-4"></i>
                        </div>
                        <h3 class="text-xs font-black uppercase tracking-[0.2em] text-foreground/80">Account Identification</h3>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-muted-foreground/80 ml-1">Legal Full Name</label>
                            <div class="relative group/input">
                                <input type="text" @bind="_userName" placeholder="e.g. Alexander Pierce"
                                    class="w-full px-5 py-3.5 bg-white/40 border border-white/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all font-semibold placeholder:text-muted-foreground/30 shadow-sm"/>
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 text-muted-foreground/20 group-focus-within/input:text-primary transition-colors">
                                    <i data-lucide="signature" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-muted-foreground/80 ml-1">Contact Email</label>
                            <div class="relative group/input">
                                <input type="email" @bind="_email" placeholder="name@company.com"
                                    class="w-full px-5 py-3.5 bg-white/40 border border-white/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all font-semibold placeholder:text-muted-foreground/30 shadow-sm"/>
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 text-muted-foreground/20 group-focus-within/input:text-primary transition-colors">
                                    <i data-lucide="at-sign" class="w-4 h-4"></i>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-2 md:col-span-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-muted-foreground/80 ml-1">Access Credential</label>
                            <div class="relative group/input">
                                <input type="@(_showPassword ? "text" : "password")" @bind="_password"
                                    placeholder="Secure passphrase (min 8 chars)"
                                    class="w-full px-5 py-3.5 bg-white/40 border border-white/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all font-semibold placeholder:text-muted-foreground/30 shadow-sm pr-14"/>
                                <button type="button"
                                        class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-xl bg-white/40 text-muted-foreground/40 hover:text-primary hover:bg-white transition-all shadow-sm active:scale-95"
                                        @onclick="TogglePassword">
                                    <i data-lucide="@(_showPassword ? "eye-off" : "eye")" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Dynamic Detail Sections -->
                @if (_selectedRole == "Merchant")
                {
                    <section class="animate-fade-in space-y-6 pt-10 border-t border-white/30">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-600">
                                <i data-lucide="building-2" class="w-4 h-4"></i>
                            </div>
                            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-foreground/80">Business Entity Information</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted-foreground/80 ml-1">Registered Business Name</label>
                                <input type="text" @bind="_merchantName" placeholder="e.g. Zenith Solutions Group"
                                    class="w-full px-5 py-3.5 bg-white/40 border border-white/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all font-semibold placeholder:text-muted-foreground/30 shadow-sm"/>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted-foreground/80 ml-1">Business Contact Email</label>
                                <input type="email" @bind="_merchantContactEmail" placeholder="billing@company.com"
                                    class="w-full px-5 py-3.5 bg-white/40 border border-white/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all font-semibold placeholder:text-muted-foreground/30 shadow-sm"/>
                            </div>
                        </div>
                    </section>
                }

                @if (_selectedRole == "Cashier")
                {
                    <section class="animate-fade-in space-y-6 pt-10 border-t border-white/30">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-600">
                                <i data-lucide="map-pin" class="w-4 h-4"></i>
                            </div>
                            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-foreground/80">Deployment Assignment</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted-foreground/80 ml-1">Affiliated Merchant</label>
                                <div class="relative">
                                    <select @bind="_merchantId" @bind:after="OnMerchantChanged"
                                            class="w-full px-5 py-3.5 bg-white/40 border border-white/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all font-semibold appearance-none cursor-pointer shadow-sm">
                                        <option value="">Select Merchant Entity...</option>
                                        @if (_merchants != null)
                                        {
                                            @foreach (var merchant in _merchants)
                                            {
                                                <option value="@merchant.Id">@merchant.Name</option>
                                            }
                                        }
                                    </select>
                                    <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-muted-foreground/40">
                                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted-foreground/80 ml-1">Target Branch Location</label>
                                <div class="relative">
                                    <select @bind="_branchId"
                                            class="w-full px-5 py-3.5 bg-white/40 border border-white/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all font-semibold appearance-none cursor-pointer shadow-sm">
                                        <option value="">Select Branch...</option>
                                        @if (_branches != null)
                                        {
                                            @foreach (var branch in _branches)
                                            {
                                                <option value="@branch.Id">@branch.Name</option>
                                            }
                                        }
                                    </select>
                                    <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-muted-foreground/40">
                                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                }
            </div>

            <!-- Footer Actions -->
            <div class="px-8 py-8 bg-white/30 backdrop-blur-md border-t border-white/40 flex flex-col sm:flex-row justify-between items-center gap-6">
                <div class="flex items-center gap-3 text-[10px] text-muted-foreground/60 font-black uppercase tracking-wider">
                    <i data-lucide="info" class="w-3.5 h-3.5"></i>
                    Verification required for all fields
                </div>
                <div class="flex gap-4 w-full sm:w-auto">
                    <button
                        class="flex-1 sm:flex-none px-8 py-3.5 rounded-2xl bg-white/50 border border-white/60 hover:bg-white hover:shadow-xl transition-all duration-300 font-black text-[10px] uppercase tracking-widest text-muted-foreground hover:text-foreground"
                        @onclick="GoBack" disabled="@_isSubmitting">
                        Cancel
                    </button>
                    <button
                        class="flex-1 sm:flex-none px-10 py-3.5 rounded-2xl bg-primary text-white shadow-[0_15px_30px_-10px_rgba(var(--primary),0.5)] flex items-center justify-center gap-3 transition-all duration-500 hover:scale-[1.02] hover:shadow-[0_20px_40px_-10px_rgba(var(--primary),0.6)] active:scale-95 disabled:opacity-40 disabled:grayscale disabled:cursor-not-allowed group"
                        @onclick="HandleSubmit" disabled="@(!IsFormValid() || _isSubmitting)">
                        @if (_isSubmitting)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-2 border-white/20 border-t-white"></div>
                            <span class="font-black uppercase tracking-widest text-[10px]">Processing...</span>
                        }
                        else
                        {
                            <i data-lucide="user-plus" class="w-4 h-4 group-hover:rotate-12 transition-transform"></i>
                            <span class="font-black uppercase tracking-widest text-[10px]">Authorize New Staff</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fixed Centered Success Modal Layer -->
@if (_showSuccessView)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-6 animate-fade-in backdrop-blur-md">
        <!-- Persistent Overlay -->
        <div class="absolute inset-0 bg-slate-900/40" @onclick="ResetForm"></div>
        
        <!-- Modal Card -->
        <div class="relative w-full max-w-lg bg-white/90 backdrop-blur-3xl rounded-[2.5rem] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.3)] border border-white/40 overflow-hidden animate-scale-in">
            <!-- Decorative Burst -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-40 bg-gradient-to-b from-emerald-500/10 to-transparent"></div>
            
            <div class="p-10 md:p-14 flex flex-col items-center text-center relative z-10">
                <!-- Animated Success Icon -->
                <div class="w-24 h-24 rounded-[2rem] bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-8 text-emerald-500 shadow-xl shadow-emerald-500/5 animate-bounce-subtle">
                    <i data-lucide="check" class="w-12 h-12 stroke-[3]"></i>
                </div>

                <div class="space-y-3 mb-10">
                    <h2 class="text-3xl font-black text-foreground tracking-tighter uppercase">Identity Verified</h2>
                    <p class="text-sm text-muted-foreground font-medium">New staff profile has been successfully provisioned into the system.</p>
                </div>

                <!-- Registration Proof -->
                <div class="w-full bg-slate-50/50 border border-slate-200/40 rounded-3xl p-8 mb-10 text-left space-y-6">
                    <div class="flex justify-between items-center border-b border-slate-200/60 pb-4">
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-muted-foreground/60">Access Profile</span>
                        <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20">
                            <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                            <span class="text-[10px] font-black text-emerald-600 uppercase">@_lastCreatedRole</span>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white shadow-sm border border-slate-100 flex items-center justify-center text-primary">
                                <i data-lucide="user" class="w-5 h-5"></i>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black uppercase tracking-widest text-muted-foreground/40 leading-none mb-1">Full Name</span>
                                <span class="text-sm font-black text-foreground">@_lastCreatedUserName</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white shadow-sm border border-slate-100 flex items-center justify-center text-muted-foreground">
                                <i data-lucide="mail" class="w-5 h-5"></i>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black uppercase tracking-widest text-muted-foreground/40 leading-none mb-1">Email System</span>
                                <span class="text-sm font-bold text-muted-foreground truncate max-w-[200px]">@_lastCreatedEmail</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal Actions -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full">
                    <button
                        class="w-full bg-slate-900 text-white rounded-[1.25rem] py-4 font-black text-[10px] uppercase tracking-widest shadow-xl shadow-slate-900/20 hover:bg-slate-800 transition-all hover:scale-[1.02] active:scale-95"
                        @onclick="ResetForm">
                        Add Another
                    </button>
                    <button
                        class="w-full bg-white text-slate-900 border border-slate-200/60 rounded-[1.25rem] py-4 font-black text-[10px] uppercase tracking-widest hover:bg-slate-50 transition-all hover:scale-[1.02] active:scale-95"
                        @onclick="GoBack">
                        View List
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string MerchantId { get; set; } = "";
    
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    // Form state
    private string _selectedRole = "Merchant";
    private string _userName = "";
    private string _email = "";
    private string _password = "";
    private bool _showPassword;

    // Merchant fields
    private string _merchantName = "";
    private string _merchantContactEmail = "";

    // Cashier fields
    private string _merchantId = "";
    private string _branchId = "";

    // Dropdown data
    private List<Merchant>? _merchants;
    private List<Branch>? _branches;

    // UI state
    private bool _isSubmitting;
    private bool _showSuccessView;

    // Last created info for success view
    private string? _lastCreatedUserName;
    private string? _lastCreatedEmail;
    private string? _lastCreatedRole;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/merchants");
            if (!response.IsSuccessStatusCode)
            {
                await Notification.ShowError("Failed to load merchants.");
                return;
            }

            var merchantData = await response.Content.ReadFromJsonAsync<PagedResult<Merchant>>();
            _merchants = merchantData?.Data;
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"An error occurred during initialization: {ex.Message}");
        }
    }

    private void SelectRole(string role)
    {
        _selectedRole = role;
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private bool IsFormValid()
    {
        if (string.IsNullOrWhiteSpace(_userName) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
            return false;

        if (_selectedRole == "Merchant" && string.IsNullOrWhiteSpace(_merchantName))
            return false;

        if (_selectedRole == "Cashier" && (string.IsNullOrWhiteSpace(_merchantId) || string.IsNullOrWhiteSpace(_branchId)))
            return false;

        return true;
    }

    private async Task HandleSubmit()
    {
        if (!IsFormValid())
        {
            await Notification.ShowWarning("Please fill in all required fields.");
            return;
        }

        _isSubmitting = true;

        try
        {
            var response = await Http.PostAsync("/api/users",
                JsonContent.Create(new
                {
                    UserName = _userName,
                    Email = _email,
                    Role = _selectedRole,
                    Password = _password,
                    MerchantId = _merchantId,
                    BranchId = _branchId
                }));

            if (response.IsSuccessStatusCode)
            {
                await Notification.ShowSuccess($"{_selectedRole} account for \"{_userName}\" created successfully!");
                _showSuccessView = true;

                // Store last created info
                _lastCreatedUserName = _userName;
                _lastCreatedEmail = _email;
                _lastCreatedRole = _selectedRole;

                _userName = "";
                _email = "";
                _password = "";
                _merchantName = "";
                _merchantContactEmail = "";
                _merchantId = "";
                _branchId = "";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await Notification.ShowError($"{_selectedRole} account creation failed: {error}");
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"A network error occurred: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
        }

        StateHasChanged();
    }

    private void ResetForm()
    {
        _showSuccessView = false;
        _userName = "";
        _email = "";
        _password = "";
        _merchantName = "";
        _merchantContactEmail = "";
        _merchantId = "";
        _branchId = "";
        StateHasChanged();
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/users", replace: false);
    }

    private async Task ReinitIcons()
    {
        await JSRuntime.InvokeVoidAsync("initIcons");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("initIcons");
    }

    private async Task OnMerchantChanged()
    {
        if (!string.IsNullOrEmpty(_merchantId))
        {
            try
            {
                var request = new HttpRequestMessage(HttpMethod.Get, $"api/branches?merchantId={_merchantId}");
                request.SetBrowserRequestCredentials(BrowserRequestCredentials.Include);

                var response = await Http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    var branchData = await response.Content.ReadFromJsonAsync<PagedResult<Branch>>();
                    _branches = branchData?.Data;
                }
                else
                {
                    await Notification.ShowError("Failed to load branches for the selected merchant.");
                }
            }
            catch (Exception ex)
            {
                await Notification.ShowError($"Error loading branches: {ex.Message}");
            }
        }
        else
        {
            _branches = null;
        }

        // Reset the branch selection if the merchant is changed
        _branchId = "";
    }

}
