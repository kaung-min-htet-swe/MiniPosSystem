@page "/merchants/{MerchantId}"
@using MiniPos.Frontend.Shared.Types

<PageTitle>Merchant Details - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-6xl mx-auto pb-12 px-4 md:px-6">
    <!-- Breadcrumb & Back Navigation -->
    <div class="flex items-center justify-between mb-8">
        <button
            class="flex items-center gap-2.5 text-xs font-bold text-muted-foreground hover:text-primary transition-all group px-3 py-2 rounded-lg hover:bg-primary/5 border border-transparent hover:border-primary/10"
            @onclick="GoBack">
            <i data-lucide="chevron-left" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform"></i>
            BACK TO MERCHANT DIRECTORY
        </button>
    </div>

    @if (_merchant == null)
    {
        <div class="flex flex-col items-center justify-center p-24 relative">
            <div class="absolute w-24 h-24 bg-primary/20 blur-xl rounded-full animate-ping"></div>
            <div
                class="animate-spin rounded-full h-12 w-12 border-4 border-t-primary border-primary/20 relative z-10"></div>
            <span class="mt-6 text-sm font-bold text-muted-foreground tracking-widest uppercase">Loading Merchant Profile...</span>
        </div>
    }
    else
    {
        <!-- Profile Hero Card: Ultra-Premium Glassmorphism -->
        <div class="relative mb-10 group">
            <!-- Background Decorative Elements -->
            <div class="absolute -top-12 -right-12 w-64 h-64 bg-primary/10 rounded-full blur-3xl opacity-50 group-hover:opacity-70 transition-opacity"></div>
            <div class="absolute -bottom-8 -left-8 w-48 h-48 bg-indigo-500/10 rounded-full blur-2xl opacity-40"></div>

            <div class="pos-card p-0 overflow-hidden bg-white/40 backdrop-blur-md border border-white/40 shadow-2xl relative z-10">
                <!-- Banner with Animated Gradient -->
                <div class="relative h-44 bg-gradient-to-r from-blue-600 via-indigo-600 to-primary/90 overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.15),transparent)]"></div>
                    <div class="absolute inset-0 opacity-20" style="background-image: url('data:image/svg+xml,%3Csvg width=%2220%22 height=%2220%22 viewBox=%220 0 20 20%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.4%22 fill-rule=%22evenodd%22%3E%3Ccircle cx=%223%22 cy=%223%22 r=%223%22/%3E%3Ccircle cx=%2213%22 cy=%2213%22 r=%223%22/%3E%3C/g%3E%3C/svg%3E');"></div>
                    
                    <!-- Quick Actions Over Banner -->
                    <div class="absolute top-6 right-6 flex gap-3 z-20">
                        <button
                            class="w-10 h-10 rounded-xl bg-white/15 backdrop-blur-xl border border-white/25 flex items-center justify-center text-white hover:bg-white/30 hover:scale-105 active:scale-95 transition-all shadow-lg"
                            title="Edit Merchant"
                            @onclick="() => _showEditModal = true">
                            <i data-lucide="edit-3" class="w-5 h-5"></i>
                        </button>
                    </div>

                    <!-- Status Indicator -->
                    <div class="absolute top-6 left-6 z-20">
                        @if (_merchant.IsActive)
                        {
                            <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/20 backdrop-blur-xl border border-emerald-500/30 text-emerald-50 shadow-inner">
                                <span class="relative flex h-2 w-2">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                                </span>
                                <span class="text-[10px] font-black uppercase tracking-[0.15em]">System Active</span>
                            </div>
                        }
                        else
                        {
                            <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-500/20 backdrop-blur-xl border border-slate-500/30 text-white shadow-inner">
                                <span class="w-2 h-2 rounded-full bg-slate-400"></span>
                                <span class="text-[10px] font-black uppercase tracking-[0.15em]">Deactivated</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Profile Identity -->
                <div class="px-8 pb-10 relative">
                    <div class="flex flex-col md:flex-row items-start md:items-end gap-6 -mt-12">
                        <!-- Avatar / Logo -->
                        <div class="relative group/avatar">
                            <div class="w-28 h-28 rounded-3xl bg-white p-1.5 shadow-2xl border border-border/10 transform transition-transform group-hover/avatar:scale-105 duration-500">
                                <div class="w-full h-full rounded-2xl bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center text-primary border border-border/5">
                                    <span class="text-4xl font-black font-outfit tracking-tighter">@(_merchant.Name?.FirstOrDefault().ToString().ToUpper() ?? "?")</span>
                                </div>
                            </div>
                            <!-- Edit Avatar Overlay (Future) -->
                        </div>

                        <!-- Text Details -->
                        <div class="flex-1 min-w-0 pb-1">
                            <div class="flex items-center gap-3 mb-1">
                                <h1 class="text-3xl font-black text-foreground font-outfit tracking-tight truncate leading-none">@_merchant.Name</h1>
                                <i data-lucide="badge-check" class="w-6 h-6 text-blue-500 fill-blue-500/10"></i>
                            </div>
                            <div class="flex flex-wrap gap-4 items-center mt-2.5">
                                <div class="flex items-center gap-2 text-sm text-muted-foreground font-semibold bg-muted/30 px-3 py-1 rounded-full border border-border/20">
                                    <i data-lucide="mail" class="w-4 h-4 text-primary/70"></i>
                                    @(_merchant.ContactEmail ?? "no-email@merchant.io")
                                </div>
                                <div class="flex items-center gap-2 text-sm text-muted-foreground font-semibold bg-muted/30 px-3 py-1 rounded-full border border-border/20">
                                    <i data-lucide="hash" class="w-4 h-4 text-primary/70"></i>
                                    ID: <span class="font-mono text-[10px] opacity-70">@_merchant.Id.ToString().Substring(0, 8)...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

            <!-- Left: Primary Details & Lists (Col 1-8) -->
            <div class="lg:col-span-8 space-y-8">

                <!-- Branch Management Section -->
                <div class="pos-card bg-white/40 backdrop-blur-sm shadow-xl border-border/30 overflow-hidden">
                    <div class="px-6 py-5 border-b border-border/20 flex items-center justify-between bg-gradient-to-r from-slate-50/50 to-white/50">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center shadow-inner">
                                <i data-lucide="map-pin" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-bold text-foreground font-outfit leading-none">Registered Branches</h2>
                                <p class="text-xs text-muted-foreground font-medium mt-1">Manage physical locations for this merchant</p>
                            </div>
                        </div>
                        <button
                            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-primary text-white text-xs font-black uppercase tracking-widest hover:bg-primary/90 hover:shadow-lg shadow-primary/20 transition-all active:scale-95"
                            @onclick="NavigateToAddBranch">
                            <i data-lucide="plus" class="w-3.5 h-3.5"></i> Add New
                        </button>
                    </div>

                    <div class="p-6">
                        @if (_branches == null || !_branches.Any())
                        {
                            <div class="flex flex-col items-center justify-center py-12 px-6 rounded-2xl border-2 border-dashed border-border/30 bg-muted/10">
                                <div class="w-16 h-16 rounded-full bg-muted/20 flex items-center justify-center mb-4">
                                    <i data-lucide="store" class="w-8 h-8 text-muted-foreground/40"></i>
                                </div>
                                <h3 class="text-sm font-bold text-foreground">No Branches Connected</h3>
                                <p class="text-xs text-muted-foreground mt-1 text-center max-w-[240px]">Start by adding a branch to manage categories and products at a local level.</p>
                                <button class="mt-4 text-xs font-black text-primary underline decoration-2 underline-offset-4" @onclick="NavigateToAddBranch">Setup first branch</button>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                @foreach (var br in _branches)
                                {
                                    <div
                                        class="group relative bg-white/60 hover:bg-white rounded-2xl p-5 border border-border/40 hover:border-primary/30 transition-all cursor-pointer shadow-sm hover:shadow-xl hover:-translate-y-1"
                                        @onclick="() => NavigateToBranch(br.Id)">
                                        <!-- Decorative Corner -->
                                        <div class="absolute top-0 right-0 w-16 h-16 bg-gradient-to-bl from-primary/5 to-transparent rounded-tr-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                        
                                        <div class="flex items-start gap-4">
                                            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-border/20 flex items-center justify-center text-primary font-black shadow-sm group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                                                <i data-lucide="store" class="w-6 h-6"></i>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <div class="flex items-center justify-between mb-1">
                                                    <span class="text-sm font-black text-foreground truncate group-hover:text-primary transition-colors">@br.Name</span>
                                                    <i data-lucide="arrow-up-right" class="w-3.5 h-3.5 text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity"></i>
                                                </div>
                                                <div class="flex items-center gap-2 text-[11px] text-muted-foreground font-semibold leading-relaxed">
                                                    <i data-lucide="map-pin" class="w-3 h-3 shrink-0 text-primary/50"></i>
                                                    <span class="truncate">@br.Address</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

            </div>

            <!-- Right: Stats & Actions (Col 9-12) -->
            <div class="lg:col-span-4 space-y-8">

                <!-- Metrics: Integrated from Stats Component -->
                <div class="pos-card bg-white/40 backdrop-blur-md shadow-xl border-border/30 p-6">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center shadow-inner">
                            <i data-lucide="activity" class="w-5 h-5"></i>
                        </div>
                        <h2 class="text-lg font-bold text-foreground font-outfit">Core Pulse</h2>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <!-- Stat Card: Unified Style -->
                        <div class="bg-white/60 p-4 rounded-2xl border border-border/30 hover:border-blue-200 transition-colors group">
                            <div class="flex items-center justify-between mb-3">
                                <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <i data-lucide="store" class="w-4 h-4"></i>
                                </div>
                            </div>
                            <div class="text-[10px] font-black uppercase tracking-wider text-muted-foreground/60 leading-none">Branches</div>
                            <div class="text-2xl font-black font-outfit text-foreground mt-1">@_merchant.BranchCount</div>
                        </div>

                        <div class="bg-white/60 p-4 rounded-2xl border border-border/30 hover:border-purple-200 transition-colors group">
                            <div class="flex items-center justify-between mb-3">
                                <div class="w-8 h-8 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <i data-lucide="package" class="w-4 h-4"></i>
                                </div>
                            </div>
                            <div class="text-[10px] font-black uppercase tracking-wider text-muted-foreground/60 leading-none">Products</div>
                            <div class="text-2xl font-black font-outfit text-foreground mt-1">@_merchant.ProductCount</div>
                        </div>

                        <div class="bg-white/60 p-4 rounded-2xl border border-border/30 hover:border-emerald-200 transition-colors group">
                            <div class="flex items-center justify-between mb-3">
                                <div class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <i data-lucide="users" class="w-4 h-4"></i>
                                </div>
                            </div>
                            <div class="text-[10px] font-black uppercase tracking-wider text-muted-foreground/60 leading-none">Staff</div>
                            <div class="text-2xl font-black font-outfit text-foreground mt-1">@_merchant.EmployeeCount</div>
                        </div>

                        <div class="bg-white/60 p-4 rounded-2xl border border-border/30 hover:border-amber-200 transition-colors group">
                            <div class="flex items-center justify-between mb-3">
                                <div class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <i data-lucide="calendar" class="w-4 h-4"></i>
                                </div>
                            </div>
                            <div class="text-[10px] font-black uppercase tracking-wider text-muted-foreground/60 leading-none">Platform Since</div>
                            <div class="text-sm font-black font-outfit text-foreground mt-2">@_merchant.CreatedAt.ToString("MMM yyyy")</div>
                        </div>
                    </div>
                </div>

                <!-- Admin Control Center -->
                <div class="pos-card bg-slate-900 border-none p-6 shadow-2xl relative overflow-hidden">
                    <!-- Glassy Overlay for contrast -->
                    <div class="absolute inset-0 bg-blue-500/5 pointer-events-none"></div>
                    
                    <div class="flex items-center gap-3 mb-6 relative z-10">
                        <div class="w-10 h-10 rounded-xl bg-white/10 text-white flex items-center justify-center">
                            <i data-lucide="settings-2" class="w-5 h-5"></i>
                        </div>
                        <h2 class="text-lg font-bold text-white font-outfit">Control Center</h2>
                    </div>

                    <div class="space-y-3 relative z-10">
                        <button
                            class="w-full flex items-center justify-between px-5 py-3.5 rounded-xl bg-white/5 border border-white/10 text-white hover:bg-white/10 hover:border-white/20 transition-all font-bold text-sm group"
                            @onclick="() => _showEditModal = true">
                            <div class="flex items-center gap-3">
                                <i data-lucide="pencil-line" class="w-4 h-4 text-blue-400"></i>
                                Modify Profile
                            </div>
                            <i data-lucide="chevron-right" class="w-4 h-4 text-white/40 group-hover:translate-x-1 transition-transform"></i>
                        </button>
                        
                        <button
                            class="w-full flex items-center justify-between px-5 py-3.5 rounded-xl bg-white/5 border border-white/10 text-white hover:bg-white/10 hover:border-white/20 transition-all font-bold text-sm group"
                            @onclick="NavigateToAddBranch">
                            <div class="flex items-center gap-3">
                                <i data-lucide="plus-circle" class="w-4 h-4 text-emerald-400"></i>
                                Provision Branch
                            </div>
                            <i data-lucide="chevron-right" class="w-4 h-4 text-white/40 group-hover:translate-x-1 transition-transform"></i>
                        </button>

                        <div class="pt-4 mt-4 border-t border-white/10">
                            @if (_merchant.IsActive)
                            {
                                <button
                                    class="w-full flex items-center gap-3 px-5 py-3.5 rounded-xl bg-destructive/10 text-destructive-foreground hover:bg-destructive/20 border border-destructive/20 transition-all font-black text-[10px] uppercase tracking-widest"
                                    @onclick="() => _showDeactivateModal = true">
                                    <i data-lucide="alert-octagon" class="w-4 h-4"></i>
                                    Restrict Merchant Account
                                </button>
                            }
                            else
                            {
                                <button
                                    class="w-full flex items-center gap-3 px-5 py-3.5 rounded-xl bg-emerald-500/10 text-emerald-500 hover:bg-emerald-500/20 border border-emerald-500/20 transition-all font-black text-[10px] uppercase tracking-widest"
                                    @onclick="() => _merchant.IsActive = true">
                                    <i data-lucide="check-circle" class="w-4 h-4"></i>
                                    Restore Active Status
                                </button>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- --- Action Modals --- -->

        <!-- Edit Modal -->
        @if (_showEditModal)
        {
            <div
                class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
                <div
                    class="bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-border/40 w-full max-w-md p-6 animate-scale-up space-y-5">
                    <div class="flex items-center gap-2 text-primary">
                        <i data-lucide="pencil" class="w-5 h-5"></i>
                        <h3 class="text-lg font-bold">Edit Details</h3>
                    </div>
                    <div class="space-y-4">
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Merchant
                                Name</label>
                            <input type="text" @bind="_editName"
                                   class="w-full px-4 py-2.5 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium"/>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Contact
                                Email</label>
                            <input type="text" @bind="_editEmail"
                                   class="w-full px-4 py-2.5 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium"/>
                        </div>
                    </div>
                    <div class="flex justify-end gap-3 pt-2">
                        <button class="btn btn-ghost rounded-xl px-5 text-sm" @onclick='() => _showEditModal = false'
                                disabled="@_isSubmitting">Cancel
                        </button>
                        <button
                            class="btn btn-primary rounded-xl px-6 text-sm shadow-primary disabled:opacity-50 flex items-center gap-2"
                            @onclick="HandleEditMerchant" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <div
                                    class="animate-spin rounded-full h-3.5 w-3.5 border-2 border-white/20 border-t-white"></div>
                            }
                            <span>Save Changes</span>
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Deactivate Modal -->
        @if (_showDeactivateModal)
        {
            <div
                class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
                <div
                    class="bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-border/40 w-full max-w-md p-6 animate-scale-up space-y-5">
                    <div class="flex items-center gap-2 text-destructive">
                        <i data-lucide="power" class="w-5 h-5"></i>
                        <h3 class="text-lg font-bold">Deactivate Account</h3>
                    </div>
                    <p class="text-sm text-muted-foreground">Are you sure you want to deactivate <b>@_merchant.Name</b>?
                        Doing so will halt active sessions and close digital profiles layout structures safely.</p>
                    <div class="flex justify-end gap-3 pt-2">
                        <button class="btn btn-ghost rounded-xl px-5 text-sm"
                                @onclick='() => _showDeactivateModal = false' disabled="@_isSubmitting">Cancel
                        </button>
                        <button class="btn btn-destructive rounded-xl px-6 text-sm flex items-center gap-2"
                                @onclick="HandleDeactivateMerchant" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <div
                                    class="animate-spin rounded-full h-3.5 w-3.5 border-2 border-white/20 border-t-white"></div>
                            }
                            <span>Deactivate</span>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string MerchantId { get; set; } = "";

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private Merchant? _merchant;
    private List<Branch> _branches = new();

    // Modal controls
    private bool _showEditModal = false;
    private bool _showDeactivateModal = false;

    // Field bindings for edit
    private string _editName = "";
    private string _editEmail = "";

    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        _merchant = await Http.GetFromJsonAsync<Merchant>($"api/merchants/{MerchantId}");
        if (_merchant != null)
        {
            _editName = _merchant.Name;
            _editEmail = _merchant.ContactEmail ?? "";
            var branchesData = await Http.GetFromJsonAsync<PagedResult<Branch>>($"api/branches?merchantId={MerchantId}");
            if (branchesData != null)
            {
                _branches = branchesData.Data.Where(b => b.Merchant != null && b.Merchant.Id == _merchant.Id).ToList();
            }
        }
        await JSRuntime.InvokeVoidAsync("initIcons");
        StateHasChanged();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/merchants");
    }

    private void NavigateToAddBranch()
    {
        Navigation.NavigateTo($"/branches/add?merchantId={MerchantId}");
    }

    private void NavigateToBranch(Guid branchId)
    {
        Navigation.NavigateTo($"/branches/{branchId}");
    }

    private async Task HandleEditMerchant()
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;
        _isSubmitting = true;
        await Task.Delay(1000); // Simulate
        if (_merchant != null)
        {
            _merchant.Name = _editName;
            _merchant.ContactEmail = _editEmail;
        }

        _isSubmitting = false;
        _showEditModal = false;
        StateHasChanged();
    }

    private async Task HandleDeactivateMerchant()
    {
        _isSubmitting = true;
        await Task.Delay(1000); // Simulate
        if (_merchant != null)
        {
            _merchant.IsActive = false;
        }

        _isSubmitting = false;
        _showDeactivateModal = false;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

}
