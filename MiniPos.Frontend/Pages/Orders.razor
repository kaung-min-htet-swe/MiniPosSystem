@page "/orders"

<PageTitle>Orders - MiniPOS</PageTitle>

<div class="animate-slide-down h-full flex flex-col">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4 shrink-0">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Active Orders</h1>
            <p class="text-muted-foreground mt-1 text-sm">Process line queue, review transactions, and manage refunds.</p>
        </div>
        <div class="flex items-center gap-3">
            <button class="btn btn-outline bg-white hover:bg-muted shadow-sm rounded-lg">
                <i data-lucide="filter" class="w-4 h-4 mr-2"></i> All Statuses
            </button>
        </div>
    </div>

    <!-- Split Screen Layout -->
    <div class="flex flex-col lg:flex-row gap-6 flex-1 min-h-[600px]">
        <!-- Left: Order List -->
        <div class="w-full lg:w-1/2 xl:w-7/12 flex flex-col gap-4 overflow-y-auto pr-2 pb-4" style="max-height: calc(100vh - 200px);">
            
            <!-- Order Item 1 (Selected) -->
            <div class="pos-card relative overflow-hidden group border-primary shadow-md cursor-pointer bg-white/60">
                <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-primary"></div>
                <div class="flex justify-between items-start">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-bold text-lg">ORD-991A</span>
                            <span class="badge badge-primary text-[10px]">Processing</span>
                        </div>
                        <div class="text-sm font-medium text-foreground">Table 12 • Dina Smith</div>
                        <div class="text-xs text-muted-foreground mt-1"><i data-lucide="clock" class="w-3 h-3 inline mr-1"></i> 2 mins ago</div>
                    </div>
                    <div class="text-right">
                        <div class="font-bold text-xl font-outfit">$42.50</div>
                        <div class="text-xs text-muted-foreground mt-1">3 items</div>
                    </div>
                </div>
            </div>

            <!-- Order Item 2 -->
            <div class="pos-card relative overflow-hidden group hover:border-border/80 transition-all cursor-pointer bg-white/40">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-bold text-lg">ORD-9919</span>
                            <span class="badge badge-success text-[10px]">Paid</span>
                        </div>
                        <div class="text-sm font-medium text-foreground">Takeaway • Walk-in</div>
                        <div class="text-xs text-muted-foreground mt-1"><i data-lucide="clock" class="w-3 h-3 inline mr-1"></i> 14 mins ago</div>
                    </div>
                    <div class="text-right">
                        <div class="font-bold text-xl font-outfit text-muted-foreground">$18.00</div>
                        <div class="text-xs text-muted-foreground mt-1">1 item</div>
                    </div>
                </div>
            </div>

            <!-- Order Item 3 -->
            <div class="pos-card relative overflow-hidden group hover:border-border/80 transition-all cursor-pointer bg-white/40">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-bold text-lg">ORD-9918</span>
                            <span class="badge badge-success text-[10px]">Paid</span>
                        </div>
                        <div class="text-sm font-medium text-foreground">Delivery • John D.</div>
                        <div class="text-xs text-muted-foreground mt-1"><i data-lucide="clock" class="w-3 h-3 inline mr-1"></i> 45 mins ago</div>
                    </div>
                    <div class="text-right">
                        <div class="font-bold text-xl font-outfit text-muted-foreground">$114.25</div>
                        <div class="text-xs text-muted-foreground mt-1">6 items</div>
                    </div>
                </div>
            </div>

            <!-- Order Item 4 (Failed) -->
            <div class="pos-card relative overflow-hidden group hover:border-border/80 transition-all cursor-pointer bg-destructive/5 backdrop-blur-none border-destructive/20">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-bold text-lg">ORD-9917</span>
                            <span class="badge badge-warning bg-destructive/10 text-destructive text-[10px]">Failed</span>
                        </div>
                        <div class="text-sm font-medium text-foreground">Card Error • Walk-in</div>
                        <div class="text-xs text-muted-foreground mt-1"><i data-lucide="clock" class="w-3 h-3 inline mr-1"></i> 1 hour ago</div>
                    </div>
                    <div class="text-right">
                        <div class="font-bold text-xl font-outfit text-muted-foreground">$24.00</div>
                        <div class="text-xs text-muted-foreground mt-1">2 items</div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Right: Receipt View -->
        <div class="w-full lg:w-1/2 xl:w-5/12">
            <div class="pos-card sticky top-6 h-full flex flex-col p-0 overflow-hidden shadow-lg border-primary/20 bg-white/90">
                <!-- Receipt Header -->
                <div class="p-6 border-b border-dashed border-border/80 bg-muted/10">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-2xl font-bold font-outfit">ORD-991A</h2>
                        <span class="badge badge-primary px-3 py-1 text-xs">Processing</span>
                    </div>
                    <div class="grid grid-cols-2 gap-4 text-sm">
                        <div>
                            <span class="text-muted-foreground block text-xs uppercase font-bold tracking-wider mb-1">Customer</span>
                            <span class="font-semibold text-foreground">Dina Smith</span>
                        </div>
                        <div class="text-right">
                            <span class="text-muted-foreground block text-xs uppercase font-bold tracking-wider mb-1">Time</span>
                            <span class="font-semibold text-foreground">10:42 AM</span>
                        </div>
                        <div>
                            <span class="text-muted-foreground block text-xs uppercase font-bold tracking-wider mb-1">Served By</span>
                            <span class="font-semibold text-foreground">Alice S.</span>
                        </div>
                        <div class="text-right">
                            <span class="text-muted-foreground block text-xs uppercase font-bold tracking-wider mb-1">Payment</span>
                            <span class="font-semibold text-foreground">Pending</span>
                        </div>
                    </div>
                </div>

                <!-- Receipt Items -->
                <div class="flex-1 overflow-y-auto p-6">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-muted-foreground border-b border-border/50 text-xs uppercase tracking-wider">
                                <th class="text-left pb-2 font-bold">Qty</th>
                                <th class="text-left pb-2 font-bold w-full pl-2">Item</th>
                                <th class="text-right pb-2 font-bold">Price</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/30">
                            <!-- Item 1 -->
                            <tr>
                                <td class="py-3 font-semibold text-foreground align-top">2</td>
                                <td class="py-3 pl-2">
                                    <div class="font-semibold">Espresso Roast</div>
                                    <div class="text-xs text-muted-foreground mt-0.5">SKU: BEAN-01</div>
                                </td>
                                <td class="py-3 text-right font-semibold align-top">$24.00</td>
                            </tr>
                            <!-- Item 2 -->
                            <tr>
                                <td class="py-3 font-semibold text-foreground align-top">1</td>
                                <td class="py-3 pl-2">
                                    <div class="font-semibold">Almond Croissant</div>
                                </td>
                                <td class="py-3 text-right font-semibold align-top">$5.50</td>
                            </tr>
                            <!-- Item 3 -->
                            <tr>
                                <td class="py-3 font-semibold text-foreground align-top">1</td>
                                <td class="py-3 pl-2">
                                    <div class="font-semibold">Ceramic Mug</div>
                                    <div class="text-xs text-muted-foreground mt-0.5">- Logo Engraved</div>
                                </td>
                                <td class="py-3 text-right font-semibold align-top">$12.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Receipt Totals -->
                <div class="p-6 bg-muted/10 border-t border-dashed border-border/80">
                    <div class="flex justify-between text-sm mb-2 text-muted-foreground">
                        <span>Subtotal</span>
                        <span>$41.50</span>
                    </div>
                    <div class="flex justify-between text-sm mb-4 text-muted-foreground">
                        <span>Tax (8%)</span>
                        <span>$3.32</span>
                    </div>
                    <div class="flex justify-between items-center bg-white border border-border/50 rounded-lg p-3 shadow-sm mb-6">
                        <span class="text-sm font-bold uppercase tracking-wider">Total</span>
                        <span class="text-2xl font-bold font-outfit text-primary">$44.82</span>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-3">
                        <button class="btn btn-outline flex-1 border-border/60 bg-white hover:bg-muted font-bold">
                            <i data-lucide="printer" class="w-4 h-4 mr-2"></i> Print
                        </button>
                        <button class="btn btn-primary flex-1 shadow-primary font-bold text-base hover:-translate-y-0.5 transition-transform">
                            <i data-lucide="credit-card" class="w-4 h-4 mr-2"></i> Pay Now
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
