@page "/orders"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Orders - MiniPOS</PageTitle>

<!-- Stunning Animated Background -->
<div class="fixed inset-0 z-[-1] overflow-hidden bg-slate-50">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-50/80 via-white/80 to-purple-50/80 backdrop-blur-3xl"></div>
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/20 blur-[120px] rounded-full animate-pulse mix-blend-multiply"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-purple-500/20 blur-[120px] rounded-full animate-pulse delay-700 mix-blend-multiply"></div>
</div>

<div class="animate-slide-down h-full flex flex-col p-6">
    <!-- Premium Header & Top Metrics -->
    <div class="flex flex-col xl:flex-row justify-between items-start xl:items-center mb-8 gap-6 shrink-0">
        <div>
            <h1 class="text-4xl font-black tracking-tight text-foreground bg-clip-text text-transparent bg-gradient-to-r from-primary to-purple-600 drop-shadow-sm">Active Orders</h1>
            <p class="text-muted-foreground mt-2 text-sm font-medium">Process the live queue, review transactions, and manage operations in real-time.</p>
        </div>
        
        <!-- Quick Stats Glass Panel -->
        <div class="flex items-center gap-4 bg-white/40 backdrop-blur-xl border border-white/60 shadow-lg rounded-2xl p-2 px-4">
            <div class="flex flex-col px-4 border-r border-border/40">
                <span class="text-[10px] uppercase font-bold text-muted-foreground tracking-widest mb-1">Gross Sales</span>
                <span class="text-lg font-black font-outfit text-foreground">$@_grossSalesToday.ToString("N2")</span>
            </div>
            <div class="flex flex-col px-4 border-r border-border/40">
                <span class="text-[10px] uppercase font-bold text-muted-foreground tracking-widest mb-1">Completed</span>
                <span class="text-lg font-black font-outfit text-success">@_completedOrdersCount <i data-lucide="trending-up" class="inline w-3 h-3 ml-1 mb-1"></i></span>
            </div>
            <div class="flex flex-col px-4">
                <span class="text-[10px] uppercase font-bold text-muted-foreground tracking-widest mb-1">Pending</span>
                <span class="text-lg font-black font-outfit text-warning">@_pendingOrdersCount <i data-lucide="clock" class="inline w-3 h-3 ml-1 mb-1"></i></span>
            </div>
        </div>
    </div>

    @if (_orders == null)
    {
        <div class="flex items-center justify-center p-24 relative flex-col">
            <div class="absolute w-24 h-24 bg-primary/20 blur-xl rounded-full animate-ping"></div>
            <div class="animate-spin rounded-full h-12 w-12 border-4 border-t-primary border-primary/20 relative z-10"></div>
            <span class="mt-6 text-sm font-bold text-muted-foreground tracking-widest uppercase">Loading Orders...</span>
        </div>
    }
    else
    {
        <!-- Main Layout Split -->
        <div class="flex flex-col lg:flex-row gap-8 h-[calc(100vh-220px)] lg:h-[75vh]">
            
            <!-- Left Panel: Order Queue (Glass Cards) -->
            <div class="w-full lg:w-1/2 xl:w-7/12 flex flex-col gap-4 overflow-y-auto pr-2 pb-8 stylish-scrollbar" style="max-height: calc(100vh - 200px);">
                
                <div class="flex items-center justify-between mb-2 px-2 sticky top-0 backdrop-blur-md bg-white/20 rounded-lg py-2 z-10 border border-white/40">
                    <span class="text-sm font-bold text-foreground">Live Queue (@_orders.Count)</span>
                    <button class="btn btn-ghost btn-sm text-primary font-bold hover:bg-white/50 rounded-full text-xs">
                        <i data-lucide="filter" class="w-3.5 h-3.5 mr-1"></i> Filter
                    </button>
                </div>

                @foreach (var order in _orders)
                {
                    var isSelected = _selectedOrder?.Id == order.Id;
                    var orderNumber = GetFormattedOrderNumber(order.Id);
                    var status = _orderStatuses.GetValueOrDefault(order.Id, new OrderStatusInfo { Label = "Pending", Class = "badge-warning" });
                    var typeStr = _orderTypes.GetValueOrDefault(order.Id, "Walk-in");
                    var customerName = order.Customer?.Name ?? typeStr;
                    var timeAgo = GetTimeAgo(order.OrderDate);
                    
                    var cardClasses = isSelected 
                        ? "bg-gradient-to-br from-white/90 to-white/70 backdrop-blur-xl border-primary/50 shadow-xl shadow-primary/10 ring-1 ring-primary/20 scale-[1.01]" 
                        : (status.Label == "Failed" 
                            ? "bg-white/50 backdrop-blur-md border-destructive/30 hover:bg-white/70 hover:border-destructive/50" 
                            : "bg-white/40 backdrop-blur-md border-white/60 hover:bg-white/70 hover:border-primary/30");

                    <div class="relative overflow-hidden group transition-all duration-300 cursor-pointer rounded-2xl border p-5 hover:-translate-y-1 hover:shadow-lg @cardClasses" @onclick="() => SelectOrder(order)">
                        
                        @if (isSelected)
                        {
                            <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-gradient-to-b from-primary to-purple-600"></div>
                            <div class="absolute -right-12 -top-12 w-32 h-32 bg-primary/5 rounded-full blur-2xl pointer-events-none"></div>
                        }

                        <div class="flex justify-between items-start">
                            <div class="flex gap-4">
                                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-muted to-muted/50 border border-white/80 shadow-sm flex items-center justify-center text-foreground font-bold shrink-0">
                                    <i data-lucide="@(status.Label == "Paid" ? "check-circle-2" : (status.Label == "Failed" ? "x-circle" : "clock"))" 
                                       class="w-5 h-5 @(status.Label == "Paid" ? "text-success" : (status.Label == "Failed" ? "text-destructive" : "text-warning"))"></i>
                                </div>
                                <div>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="font-black text-lg tracking-tight">@orderNumber</span>
                                        <span class="badge @status.Class text-[9px] shadow-sm uppercase tracking-widest px-2 py-0.5">@status.Label</span>
                                    </div>
                                    <div class="text-sm font-semibold text-foreground/80">@((order.Customer != null ? "Table 12 • " : "") + customerName)</div>
                                    <div class="text-xs text-muted-foreground mt-1.5 font-medium flex items-center gap-1.5">
                                        <i data-lucide="clock" class="w-3.5 h-3.5"></i> @timeAgo
                                    </div>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="font-black text-2xl font-outfit @(isSelected ? "text-primary drop-shadow-sm" : "text-foreground")">$@order.TotalAmount.ToString("F2")</div>
                                <div class="text-[10px] uppercase font-bold text-muted-foreground mt-2 tracking-widest">
                                    @order.OrderItems.Count Item@(order.OrderItems.Count != 1 ? "s" : "")
                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>

            <!-- Right Panel: Receipt View (Floating Glass Pane) -->
            <div class="w-full lg:w-1/2 xl:w-5/12 h-[calc(100vh-220px)] pb-8">
                @if (_selectedOrder != null)
                {
                    var selStatus = _orderStatuses.GetValueOrDefault(_selectedOrder.Id, new OrderStatusInfo { Label = "Pending", Class = "badge-warning" });
                    var tax = _selectedOrder.TotalAmount * 0.08m;
                    var subtotal = _selectedOrder.TotalAmount - tax;
                    var customerDisplay = _selectedOrder.Customer?.Name ?? _orderTypes.GetValueOrDefault(_selectedOrder.Id, "Walk-in");
                    
                    <div class="h-full flex flex-col p-0 overflow-hidden shadow-2xl rounded-3xl border border-white/80 bg-white/70 backdrop-blur-2xl ring-1 ring-black/5 animate-fade-in">
                        
                        <!-- Receipt Header -->
                        <div class="p-8 border-b border-dashed border-border/80 bg-gradient-to-br from-white/60 to-transparent relative overflow-hidden">
                            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary/10 rounded-full blur-2xl pointer-events-none"></div>
                            
                            <div class="flex justify-between items-center mb-6 relative z-10">
                                <h2 class="text-3xl font-black font-outfit tracking-tighter flex items-center gap-3">
                                    <i data-lucide="receipt" class="w-6 h-6 text-primary"></i> 
                                    @GetFormattedOrderNumber(_selectedOrder.Id)
                                </h2>
                                <span class="badge @selStatus.Class px-4 py-1.5 text-xs uppercase font-black tracking-widest shadow-md">@selStatus.Label</span>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-y-5 gap-x-4 text-sm relative z-10 bg-white/50 rounded-2xl p-4 border border-white/60 shadow-sm">
                                <div>
                                    <span class="text-primary/70 block text-[9px] uppercase font-black tracking-widest mb-1.5">Customer</span>
                                    <span class="font-bold text-foreground text-sm">@customerDisplay</span>
                                </div>
                                <div class="text-right">
                                    <span class="text-primary/70 block text-[9px] uppercase font-black tracking-widest mb-1.5">Time</span>
                                    <span class="font-bold text-foreground text-sm">@_selectedOrder.OrderDate.ToString("hh:mm tt")</span>
                                </div>
                                <div>
                                    <span class="text-primary/70 block text-[9px] uppercase font-black tracking-widest mb-1.5">Served By</span>
                                    <span class="font-bold text-foreground text-sm">@(_selectedOrder.ProcessedBy?.Username ?? "System")</span>
                                </div>
                                <div class="text-right">
                                    <span class="text-primary/70 block text-[9px] uppercase font-black tracking-widest mb-1.5">Payment</span>
                                    <span class="font-bold text-foreground text-sm">@(selStatus.Label == "Paid" ? "Completed" : (selStatus.Label == "Failed" ? "Declined" : "Pending"))</span>
                                </div>
                            </div>
                        </div>

                        <!-- Receipt Items -->
                        <div class="flex-1 overflow-y-auto px-8 pt-6 pb-2 stylish-scrollbar bg-gradient-to-b from-transparent to-white/40">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="text-muted-foreground border-b-2 border-border/40 text-[10px] uppercase font-black tracking-widest">
                                        <th class="text-left pb-3 w-12">Qty</th>
                                        <th class="text-left pb-3 w-full pl-2">Item</th>
                                        <th class="text-right pb-3">Amount</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-border/20">
                                    @foreach (var item in _selectedOrder.OrderItems)
                                    {
                                        <tr class="group hover:bg-white/40 transition-colors">
                                            <td class="py-4 font-black text-foreground align-top text-center bg-muted/20 rounded-l-lg group-hover:bg-primary/5 group-hover:text-primary transition-colors">
                                                @item.Quantity<span class="text-[10px] text-muted-foreground font-normal ml-0.5">x</span>
                                            </td>
                                            <td class="py-4 pl-4 align-top">
                                                <div class="font-bold text-foreground text-base leading-tight">@item.Product.Name</div>
                                                <div class="text-[11px] font-semibold text-muted-foreground uppercase tracking-widest mt-1">SKU: @item.Product.Sku</div>
                                            </td>
                                            <td class="py-4 text-right font-black align-top font-outfit text-base rounded-r-lg group-hover:text-primary transition-colors">
                                                $@item.SubTotal.ToString("F2")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Receipt Totals -->
                        <div class="px-8 py-6 bg-white/60 border-t border-white/80 backdrop-blur-xl">
                            <div class="flex justify-between text-sm mb-3">
                                <span class="font-semibold text-muted-foreground">Subtotal</span>
                                <span class="font-bold text-foreground">$@subtotal.ToString("F2")</span>
                            </div>
                            <div class="flex justify-between text-sm mb-5 pb-5 border-b border-dashed border-border">
                                <span class="font-semibold text-muted-foreground">Tax (8%)</span>
                                <span class="font-bold text-foreground">$@tax.ToString("F2")</span>
                            </div>
                            
                            <div class="flex justify-between items-end mb-8 relative">
                                <div class="absolute -left-4 -right-4 top-1/2 -translate-y-1/2 h-16 bg-primary/5 rounded-2xl blur pointer-events-none"></div>
                                <span class="text-sm font-black uppercase tracking-widest text-primary relative z-10">Total Due</span>
                                <span class="text-4xl font-black font-outfit text-foreground tracking-tighter relative z-10 drop-shadow-sm">$@_selectedOrder.TotalAmount.ToString("F2")</span>
                            </div>

                            <!-- Premium Action Buttons -->
                            <div class="flex gap-4">
                                <button class="flex-1 bg-white/80 hover:bg-white text-foreground font-black py-4 rounded-2xl border border-white/60 shadow-sm hover:shadow-md transition-all active:scale-[0.98] flex items-center justify-center gap-2 group">
                                    <i data-lucide="printer" class="w-5 h-5 text-muted-foreground group-hover:text-foreground transition-colors"></i> 
                                    Print Receipt
                                </button>
                                <button class="flex-[1.5] bg-gradient-to-r from-primary to-purple-600 hover:from-primary hover:to-primary text-white font-black py-4 rounded-2xl shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 transition-all hover:-translate-y-1 active:scale-[0.98] flex items-center justify-center gap-2 disabled:opacity-50 disabled:grayscale disabled:hover:translate-y-0 disabled:hover:shadow-none" disabled="@(selStatus.Label == "Paid")">
                                    <i data-lucide="credit-card" class="w-5 h-5"></i>
                                    @(selStatus.Label == "Paid" ? "Payment Completed" : "Charge Customer")
                                </button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="h-full flex flex-col items-center justify-center text-muted-foreground p-12 text-center bg-white/40 backdrop-blur-xl border border-white/50 shadow-xl rounded-3xl">
                        <div class="w-24 h-24 rounded-full bg-white/60 flex items-center justify-center mb-6 shadow-inner border border-white/80 relative">
                            <div class="absolute inset-0 rounded-full border border-primary/20 animate-ping"></div>
                            <i data-lucide="receipt" class="w-10 h-10 text-primary/40"></i>
                        </div>
                        <h3 class="font-black text-2xl text-foreground mb-2">No Order Selected</h3>
                        <p class="text-sm font-medium max-w-xs">Select an order from the live queue to process payments or print receipts.</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    /* Custom CSS to inject glass scrollbars and pulse animations if not provided */
    .stylish-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .stylish-scrollbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    .stylish-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 10px;
    }
    .stylish-scrollbar:hover::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.2);
    }
</style>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    public class OrderStatusInfo
    {
        public string Label { get; set; } = "";
        public string Class { get; set; } = "";
    }

    private List<Order>? _orders;
    private Order? _selectedOrder;
    private Dictionary<Guid, OrderStatusInfo> _orderStatuses = new();
    private Dictionary<Guid, string> _orderTypes = new();

    // Summary Metrics Dummy State
    private int _pendingOrdersCount = 12;
    private int _completedOrdersCount = 48;
    private decimal _grossSalesToday = 1245.50m;

    protected override async Task OnInitializedAsync()
    {
        _orders = await Http.GetFromJsonAsync<List<Order>>("sample-data/orders.json");

        if (_orders != null)
        {
            var id1 = Guid.Parse("00000000-0000-0000-0000-00000000991A");
            var id2 = Guid.Parse("00000000-0000-0000-0000-000000009919");
            var id3 = Guid.Parse("00000000-0000-0000-0000-000000009918");
            var id4 = Guid.Parse("00000000-0000-0000-0000-000000009917");

            _orderStatuses[id1] = new OrderStatusInfo { Label = "Processing", Class = "bg-primary text-white" };
            _orderTypes[id1] = "Walk-in";

            _orderStatuses[id2] = new OrderStatusInfo { Label = "Paid", Class = "bg-success text-white" };
            _orderTypes[id2] = "Takeaway • Walk-in";

            _orderStatuses[id3] = new OrderStatusInfo { Label = "Paid", Class = "bg-success text-white" };
            _orderTypes[id3] = "Delivery";

            _orderStatuses[id4] = new OrderStatusInfo { Label = "Failed", Class = "bg-destructive text-white" };
            _orderTypes[id4] = "Card Error • Walk-in";

            _selectedOrder = _orders.FirstOrDefault();
        }
    }

    private void SelectOrder(Order order)
    {
        _selectedOrder = order;
        StateHasChanged();
    }

    private string GetFormattedOrderNumber(Guid id)
    {
        var idStr = id.ToString().Split('-').Last().ToUpper();
        if (idStr.Length > 4) idStr = idStr.Substring(idStr.Length - 4);
        return $"ORD-{idStr}";
    }

    private string GetTimeAgo(DateTime date)
    {
        var ts = DateTime.Now - date;
        if (ts.TotalMinutes < 60) return $"{(int)ts.TotalMinutes} mins ago";
        if (ts.TotalHours < 24) return $"{(int)ts.TotalHours} hour{(ts.TotalHours >= 2 ? "s" : "")} ago";
        return date.ToString("MMM dd");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
