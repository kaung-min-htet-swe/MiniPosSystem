@page "/orders"
@using MiniPos.Frontend.Models
@using MiniPos.Frontend.Services

<PageTitle>Point of Sale - MiniPOS @(string.IsNullOrEmpty(_selectedBranchName) ? "" : $"- {_selectedBranchName}")</PageTitle>

<!-- Stunning Animated Background -->
<div class="fixed inset-0 z-[-1] overflow-hidden bg-slate-50">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-50/80 via-white/80 to-purple-50/80 backdrop-blur-3xl"></div>
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/20 blur-[120px] rounded-full animate-pulse mix-blend-multiply"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-purple-500/20 blur-[120px] rounded-full animate-pulse delay-700 mix-blend-multiply"></div>
</div>

<div class="animate-slide-down h-full flex flex-col p-6">
    <!-- Premium Header -->
    <div class="flex flex-col xl:flex-row justify-between items-start xl:items-center mb-6 gap-6 shrink-0">
        <div>
            <div class="flex items-center gap-4">
                <h1 class="text-4xl font-black tracking-tight text-foreground bg-clip-text text-transparent bg-gradient-to-r from-primary to-purple-600 drop-shadow-sm">Point of Sale</h1>
                @if (_selectedBranchId.HasValue)
                {
                    <div class="bg-white/60 backdrop-blur-md border border-white/80 px-4 py-1.5 rounded-full flex items-center gap-2 shadow-sm animate-fade-in">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                        <span class="text-xs font-black uppercase tracking-tight text-muted-foreground">Branch:</span>
                        <span class="text-xs font-black text-foreground">@_selectedBranchName</span>
                        <button class="ml-2 text-[10px] font-black text-primary hover:text-primary/70 transition-colors uppercase tracking-widest" @onclick="ChangeBranch">Change</button>
                    </div>
                }
            </div>
            <p class="text-muted-foreground mt-2 text-sm font-medium">Add products to the active cart and process customer transactions instantly.</p>
        </div>
        
        <div class="flex items-center gap-3">
            <!-- Merchant Selector -->
            <div class="relative group animate-fade-in">
                <i data-lucide="store"
                   class="w-3.5 h-3.5 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors pointer-events-none"></i>
                <select @bind="_selectedMerchantId" @bind:after="LoadData"
                        class="bg-white border border-border/60 rounded-2xl text-xs font-bold py-2.5 pl-10 pr-10 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm cursor-pointer appearance-none">
                    <option value="">All Merchants</option>
                    @foreach (var mer in _merchants)
                    {
                        <option value="@mer.Id">@mer.Name</option>
                    }
                </select>
                <i data-lucide="chevron-down"
                   class="w-3.5 h-3.5 absolute right-3.5 top-1/2 -translate-y-1/2 text-muted-foreground transition-transform group-focus-within:rotate-180 pointer-events-none"></i>
            </div>

            <!-- Search Catalog -->
            @if (_selectedBranchId.HasValue)
            {
                <div class="relative flex items-center w-72 animate-fade-in group">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors"></i>
                    <input type="text" placeholder="Search catalog..." class="w-full pl-10 pr-4 py-2.5 bg-white border border-border/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm"
                           @bind="_searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
                </div>
            }
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="flex items-center justify-center p-24 relative flex-col flex-1">
            <div class="absolute w-24 h-24 bg-primary/20 blur-xl rounded-full animate-ping"></div>
            <div class="animate-spin rounded-full h-12 w-12 border-4 border-t-primary border-primary/20 relative z-10"></div>
            <span class="mt-6 text-sm font-bold text-muted-foreground tracking-widest uppercase">@( _selectedBranchId.HasValue ? "Loading Catalog..." : "Loading Branches...")</span>
        </div>
    }
    else if (!_selectedBranchId.HasValue)
    {
        <!-- Sleek Branch Selection View -->
        <div class="flex-1 flex flex-col items-center justify-center max-w-4xl mx-auto w-full animate-fade-in p-6">
            <div class="text-center mb-10 w-full max-w-md mx-auto">
                <div class="w-16 h-16 bg-white border border-border/40 shadow-xl shadow-primary/5 rounded-2xl flex items-center justify-center mx-auto mb-6 transform -rotate-3 hover:rotate-0 transition-transform duration-500 group">
                    <i data-lucide="store" class="w-7 h-7 text-primary group-hover:scale-110 transition-transform duration-500"></i>
                </div>
                <h2 class="text-3xl font-black tracking-tight text-foreground font-outfit mb-2">POS Terminals</h2>
                <p class="text-muted-foreground text-sm font-medium">Select your active branch routing terminal to initialize the sales register.</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full">
                @if (_branches != null)
                {
                    @foreach (var branch in _branches)
                    {
                        var isHighlighted = _branches.IndexOf(branch) == 0;
                        var glowClass = isHighlighted ? "shadow-primary/20 border-primary/30" : "shadow-sm border-white/60";
                        var badgeRender = isHighlighted ? "<span class='absolute top-3 right-3 flex h-2 w-2'><span class='animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75'></span><span class='relative inline-flex rounded-full h-2 w-2 bg-emerald-500'></span></span>" : "";

                        <div class="group relative overflow-hidden transition-all duration-300 cursor-pointer rounded-2xl border @glowClass bg-white/60 backdrop-blur-xl p-5 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/10 hover:border-primary/50 flex items-center gap-4" @onclick="() => SelectBranch(branch)">
                            @((MarkupString)badgeRender)
                            <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            
                            <div class="shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all duration-500 shadow-inner">
                                <i data-lucide="map-pin" class="w-5 h-5"></i>
                            </div>

                            <div class="flex-1 min-w-0">
                                <h3 class="text-[15px] font-bold text-foreground truncate group-hover:text-primary transition-colors font-outfit">@branch.Name</h3>
                                <p class="text-[11px] text-muted-foreground font-medium truncate mt-0.5">@(branch.Address ?? "No address registered")</p>
                            </div>
                            
                            <div class="shrink-0 w-8 h-8 rounded-full bg-white border border-border/40 flex items-center justify-center text-muted-foreground group-hover:bg-primary group-hover:text-white group-hover:border-primary transition-all shadow-sm group-hover:shadow-primary/30">
                                <i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform"></i>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
    else
    {
        <!-- Main POS Layout -->
        <div class="flex flex-col lg:flex-row gap-8 h-[calc(100vh-180px)] lg:h-[78vh] animate-fade-in">
            
            <!-- Left Panel: Product Catalog Grid -->
            <div class="w-full lg:w-7/12 xl:w-8/12 flex flex-col h-full">
                
                <!-- Category Tabs -->
                <div class="flex gap-3 overflow-x-auto pb-4 mb-2 stylish-scrollbar shrink-0">
                    <button class="px-5 py-2.5 rounded-full font-bold text-xs uppercase tracking-widest border transition-all whitespace-nowrap @(null == _selectedCategoryId ? "bg-primary text-white shadow-md shadow-primary/30" : "bg-white/60 text-muted-foreground border-white/80 hover:bg-white/80 hover:text-foreground")"
                            @onclick="() => SelectCategory(null)">
                        All Items
                    </button>
                    @if (_categories != null)
                    {
                        @foreach (var category in _categories)
                        {
                            var isActive = category.Id == _selectedCategoryId;
                            var badgeClass = isActive ? "bg-primary text-white shadow-md shadow-primary/30" : "bg-white/60 text-muted-foreground border-white/80 hover:bg-white/80 hover:text-foreground";
                            <button class="px-5 py-2.5 rounded-full font-bold text-xs uppercase tracking-widest border transition-all whitespace-nowrap @badgeClass"
                                    @onclick="() => SelectCategory(category.Id)">
                                @category.Name
                            </button>
                        }
                    }
                </div>

                <!-- Products Grid -->
                <div class="grid grid-cols-2 lg:grid-cols-3 gap-5 overflow-y-auto pr-2 pb-8 stylish-scrollbar h-full content-start">
                    @if (_branchInventories == null || !_branchInventories.Any())
                    {
                        <div class="col-span-full flex flex-col items-center justify-center p-12 text-center bg-white/20 rounded-[2rem] border border-dashed border-white/40">
                            <i data-lucide="package-search" class="w-16 h-16 text-muted-foreground opacity-20 mb-4"></i>
                            <h3 class="text-xl font-black text-foreground">No Products Found</h3>
                            <p class="text-sm text-muted-foreground">This branch has no stock for the selected category.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in _branchInventories)
                        {
                            var ui = _productUIs.GetValueOrDefault(item.ProductId, new ProductUI { Icon = "package", Gradient = "from-primary to-purple-600", Glow = "bg-primary/20" });

                            <div class="relative overflow-hidden group transition-all duration-300 cursor-pointer rounded-3xl border border-white/60 bg-white/40 backdrop-blur-xl p-0 hover:-translate-y-2 hover:shadow-xl hover:shadow-primary/20 hover:border-primary/40 flex flex-col" @onclick="() => AddToCart(item)">
                                
                                <!-- Img Block -->
                                <div class="h-32 w-full bg-gradient-to-br @ui.Gradient relative flex items-center justify-center overflow-hidden">
                                    <div class="absolute inset-0 bg-white/10 backdrop-blur-2xl"></div>
                                    <div class="absolute -bottom-8 -right-8 w-24 h-24 @ui.Glow rounded-full blur-2xl group-hover:scale-150 transition-transform duration-500"></div>
                                    <div class="h-full w-full flex items-center justify-center relative z-10 mt-4">
                                        <i data-lucide="@ui.Icon" class="w-12 h-12 text-white/90 drop-shadow-md group-hover:scale-110 group-active:scale-95 transition-transform duration-300"></i>
                                    </div>
                                    <div class="absolute top-3 right-3 bg-white/20 backdrop-blur-md px-2 py-0.5 rounded-full text-[10px] font-black text-white uppercase tracking-tight border border-white/20">
                                        Stock: @item.StockQuantity
                                    </div>
                                </div>
                                
                                <!-- Content -->
                                <div class="p-5 flex flex-col grow bg-gradient-to-t from-white/80 to-transparent">
                                    <div class="font-bold text-foreground text-base leading-tight">@item.Name</div>
                                    <div class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest mt-1 mb-auto">SKU: @item.Sku</div>
                                    
                                    <div class="flex justify-between items-center mt-4">
                                        <div class="font-black text-xl font-outfit text-primary">$@item.Price.ToString("F2")</div>
                                        <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors text-primary border border-primary/20 opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0">
                                            <i data-lucide="plus" class="w-4 h-4 font-black"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Right Panel: Active Cart / Checkout -->
            <div class="w-full lg:w-5/12 xl:w-4/12 h-full pb-8 shrink-0">
                <div class="h-full flex flex-col p-0 overflow-hidden shadow-2xl rounded-[2rem] border border-white/80 bg-white/70 backdrop-blur-2xl ring-1 ring-black/5">
                    
                    <!-- Cart Header -->
                    <div class="p-6 border-b border-dashed border-border/80 bg-gradient-to-br from-white/80 to-transparent relative overflow-hidden shrink-0">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary/10 rounded-full blur-2xl pointer-events-none"></div>
                        <div class="flex justify-between items-center relative z-10">
                            <div>
                                <h2 class="text-2xl font-black font-outfit tracking-tighter flex items-center gap-3">
                                    <i data-lucide="shopping-cart" class="w-6 h-6 text-primary"></i> 
                                    New Order
                                </h2>
                                <p class="text-[10px] text-muted-foreground uppercase font-black tracking-widest mt-1">@_cart.Sum(x => x.Quantity) Items Selected</p>
                            </div>
                            @if (_cart.Any())
                            {
                                <button class="btn btn-ghost btn-sm text-destructive hover:bg-destructive/10 hover:text-destructive hidden sm:flex" @onclick="ClearCart">
                                    <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Clear
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Cart Items List -->
                    <div class="flex-1 overflow-y-auto p-4 stylish-scrollbar bg-gradient-to-b from-transparent to-white/40">
                        @if (!_cart.Any())
                        {
                            <div class="h-full flex flex-col items-center justify-center text-muted-foreground p-8 text-center bg-white/30 rounded-2xl border border-dashed border-border">
                                <i data-lucide="shopping-bag" class="w-12 h-12 mb-4 opacity-20"></i>
                                <h3 class="font-black text-xl text-foreground mb-1">Cart is Empty</h3>
                                <p class="text-xs font-medium max-w-[200px]">Tap products from the catalog to add them to the current transaction.</p>
                            </div>
                        }
                        else
                        {
                            <div class="flex flex-col gap-3">
                                @foreach (var item in _cart)
                                {
                                    <div class="bg-white/80 border border-border/50 rounded-2xl p-3 shadow-sm flex items-center justify-between group hover:border-primary/30 transition-colors animate-fade-in relative overflow-hidden">
                                        <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-primary to-purple-600 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                        
                                        <!-- Item Info -->
                                        <div class="flex-1 min-w-0 pr-2 pl-2">
                                            <div class="font-bold text-foreground text-sm truncate">@item.ProductName</div>
                                            <div class="font-black font-outfit text-primary mt-0.5">$@item.UnitPrice.ToString("F2")</div>
                                        </div>

                                        <!-- Quantity Controls -->
                                        <div class="flex items-center gap-2 bg-muted/40 rounded-full p-1 border border-border/60 shadow-inner">
                                            <button class="w-7 h-7 rounded-full bg-white shadow-sm border border-border flex items-center justify-center text-foreground hover:bg-primary/10 hover:text-primary transition-colors hover:border-primary/30 active:scale-95" @onclick="() => DecreaseQuantity(item)">
                                                <i data-lucide="@(item.Quantity == 1 ? "trash-2" : "minus")" class="w-3.5 h-3.5 @(item.Quantity == 1 ? "text-destructive" : "")"></i>
                                            </button>
                                            <span class="w-4 text-center text-sm font-black font-outfit">@item.Quantity</span>
                                            <button class="w-7 h-7 rounded-full bg-white shadow-sm border border-border flex items-center justify-center text-foreground hover:bg-primary hover:text-white transition-colors hover:border-primary active:scale-95" @onclick="() => IncreaseQuantity(item)">
                                                <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                                            </button>
                                        </div>
                                        
                                        <!-- Line Total -->
                                        <div class="w-16 text-right font-black font-outfit text-base pr-1">
                                            $@item.SubTotal.ToString("F2")
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Cart Checkout Footer -->
                    <div class="px-8 py-6 bg-white/80 border-t border-white/80 backdrop-blur-xl shrink-0">
                        @{
                            var subtotal = _cart.Sum(i => i.SubTotal);
                            var tax = subtotal * 0.00m;
                            var grandTotal = subtotal + tax;
                        }

                        <div class="flex justify-between text-sm mb-3">
                            <span class="font-semibold text-muted-foreground">Subtotal</span>
                            <span class="font-bold text-foreground">$@subtotal.ToString("F2")</span>
                        </div>
                        <div class="flex justify-between text-sm mb-5 pb-5 border-b border-dashed border-border">
                            <span class="font-semibold text-muted-foreground">Tax</span>
                            <span class="font-bold text-foreground">$@tax.ToString("F2")</span>
                        </div>
                        
                        <div class="flex justify-between items-end mb-8 relative group">
                            <div class="absolute -inset-4 bg-primary/5 rounded-2xl blur-lg pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <span class="text-sm font-black uppercase tracking-widest text-primary relative z-10">Total Due</span>
                            <span class="text-4xl font-black font-outfit text-foreground tracking-tighter relative z-10 drop-shadow-sm">$@grandTotal.ToString("F2")</span>
                        </div>

                        <!-- Premium Action Buttons -->
                        <div class="flex gap-4">
                            <button class="relative group overflow-hidden bg-slate-900 text-white font-black py-5 px-6 rounded-[2rem] transition-all duration-500 hover:shadow-[0_20px_50px_rgba(79,70,229,0.3)] active:scale-[0.98] w-full disabled:opacity-40 disabled:grayscale disabled:hover:shadow-none"
                                    disabled="@(!_cart.Any() || _isProcessing)" @onclick="Checkout">
                                
                                <!-- Animated background gradient -->
                                <div class="absolute inset-0 bg-gradient-to-r from-primary via-purple-600 to-primary bg-[length:200%_100%] animate-pulse opacity-100 group-hover:opacity-90 transition-opacity"></div>
                                
                                <!-- Glass sheen effect -->
                                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 bg-gradient-to-tr from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-all ease-in-out"></div>
                                
                                <div class="relative flex items-center justify-between gap-4">
                                    @if (_isProcessing)
                                    {
                                        <div class="flex items-center gap-3 mx-auto">
                                            <div class="animate-spin rounded-full h-6 w-6 border-4 border-t-white border-white/20"></div>
                                            <span class="text-xl tracking-tight">Processing Payment...</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-2xl bg-white/20 backdrop-blur-md flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                                                <i data-lucide="credit-card" class="w-6 h-6 text-white"></i>
                                            </div>
                                            <div class="flex flex-col items-start leading-none text-left">
                                                <span class="text-[10px] font-bold text-white/70 uppercase tracking-widest mb-1">Confirm Sale</span>
                                                <span class="text-xl tracking-tight">Charge Customer</span>
                                            </div>
                                        </div>
                                        
                                        <div class="flex items-center gap-2 bg-black/20 backdrop-blur-md py-2 px-4 rounded-2xl border border-white/10 group-hover:bg-black/30 transition-all">
                                            <span class="text-lg font-black font-outfit">$@grandTotal.ToString("F2")</span>
                                            <i data-lucide="chevron-right" class="w-4 h-4 text-white/50 group-hover:translate-x-1 transition-transform"></i>
                                        </div>
                                    }
                                </div>
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    }
</div>

@if (_showSuccessModal)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-md animate-fade-in">
        <div class="bg-white rounded-[2.5rem] shadow-2xl p-10 max-w-sm w-full text-center animate-scale-up border border-white/20">
            <div class="w-24 h-24 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner border border-emerald-200">
                <i data-lucide="check-circle" class="w-12 h-12"></i>
            </div>
            <h2 class="text-3xl font-black text-foreground mb-2">Sale Complete!</h2>
            <p class="text-muted-foreground font-medium mb-8">Transaction has been processed successfully.</p>
            <button class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-black py-4 rounded-2xl shadow-lg shadow-emerald-500/30 transition-all active:scale-95" @onclick="CloseSuccessModal">
                Back to POS
            </button>
        </div>
    </div>
}

<style>
    /* Custom CSS to inject glass scrollbars */
    .stylish-scrollbar::-webkit-scrollbar { width: 6px; }
    .stylish-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    .stylish-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.1); border-radius: 10px; }
    .stylish-scrollbar:hover::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.2); }
</style>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private CookieService CookieService { get; set; } = default!;

    public class ProductUI
    {
        public string Icon { get; set; } = "";
        public string Gradient { get; set; } = "";
        public string Glow { get; set; } = "";
    }

    private bool _isLoading = true;
    private bool _isProcessing = false;
    private bool _showSuccessModal = false;
    private List<Category>? _categories;
    private List<BranchListResponseDto>? _branches;
    private List<BranchInventoryListResponseDto>? _branchInventories;
    
    private Guid? _selectedBranchId;
    private string? _selectedBranchName;
    private Guid? _selectedCategoryId;
    private string _searchQuery = "";
    
    private Dictionary<Guid, ProductUI> _productUIs = new();
    private List<OrderItem> _cart = new();
    private List<Merchant> _merchants = new();
    private Guid? _selectedMerchantId;

    private User? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var userId = await CookieService.GetUserId();
            if (userId.HasValue)
            {
                var userResult = await Http.GetFromJsonAsync<User>($"api/users/{userId.Value}");
                _currentUser = userResult;
            }

            // Fetch Merchants
            var merchantResult = await Http.GetFromJsonAsync<PagedResult<Merchant>>("api/merchants?pageSize=100");
            _merchants = merchantResult?.Data ?? new();

            // Fetch Branches
            var branchUrl = "api/branches?pageSize=100";
            if (_selectedMerchantId.HasValue) branchUrl += $"&merchantId={_selectedMerchantId.Value}";
            var branchResult = await Http.GetFromJsonAsync<PagedResult<BranchListResponseDto>>(branchUrl);
            _branches = branchResult?.Data;
            
            // Fetch Categories
            var categoryUrl = "api/categories?pageSize=100";
            if (_selectedMerchantId.HasValue) categoryUrl += $"&merchantId={_selectedMerchantId.Value}";
            var categoryResult = await Http.GetFromJsonAsync<PagedResult<Category>>(categoryUrl);
            _categories = categoryResult?.Data;

            // If selected merchant changed and current branch is not in the new merchant's branches, clear it
            if (_selectedBranchId.HasValue && _branches != null && !_branches.Any(b => b.Id == _selectedBranchId.Value))
            {
                _selectedBranchId = null;
                _selectedBranchName = null;
                _branchInventories = null;
                _cart.Clear();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POS data: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private async Task SelectBranch(BranchListResponseDto branch)
    {
        _selectedBranchId = branch.Id;
        _selectedBranchName = branch.Name;
        _cart.Clear(); // Clear cart when switching branches
        
        await LoadBranchInventories();
    }

    private void ChangeBranch()
    {
        _selectedBranchId = null;
        _selectedBranchName = null;
        _branchInventories = null;
        _cart.Clear();
        StateHasChanged();
        JSRuntime.InvokeVoidAsync("initIcons");
    }

    private async Task LoadBranchInventories()
    {
        if (!_selectedBranchId.HasValue) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            var url = $"api/inventories?pageSize=100&branchId={_selectedBranchId.Value}";
            if (_selectedCategoryId.HasValue) url += $"&categoryId={_selectedCategoryId.Value}";
            if (!string.IsNullOrWhiteSpace(_searchQuery)) url += $"&searchTerm={System.Web.HttpUtility.UrlEncode(_searchQuery)}";

            var result = await Http.GetFromJsonAsync<PagedResult<BranchInventoryListResponseDto>>(url);
            _branchInventories = result?.Data;
            
            AssignProductUIs();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading branch inventory: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private void AssignProductUIs()
    {
        if (_branchInventories == null) return;
        
        var gradients = new[] { 
            ("from-indigo-500 to-purple-600", "bg-indigo-300", "coffee"),
            ("from-emerald-400 to-teal-600", "bg-emerald-300", "leaf"),
            ("from-amber-400 to-orange-500", "bg-amber-300", "croissant"),
            ("from-rose-400 to-red-500", "bg-rose-300", "flame"),
            ("from-sky-400 to-blue-500", "bg-sky-300", "cup-soda"),
            ("from-violet-400 to-fuchsia-500", "bg-violet-300", "cake")
        };

        int i = 0;
        foreach (var item in _branchInventories)
        {
            if (!_productUIs.ContainsKey(item.ProductId))
            {
                var g = gradients[i % gradients.Length];
                _productUIs[item.ProductId] = new ProductUI { Icon = g.Item3, Gradient = g.Item1, Glow = g.Item2 };
                i++;
            }
        }
    }

    private async Task SelectCategory(Guid? categoryId)
    {
        _selectedCategoryId = categoryId;
        await LoadBranchInventories();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadBranchInventories();
        }
    }

    private void AddToCart(BranchInventoryListResponseDto item)
    {
        if (item.StockQuantity <= 0) return; // Simple stock check

        var existing = _cart.FirstOrDefault(i => i.ProductId == item.ProductId);
        if (existing != null)
        {
            if (existing.Quantity < item.StockQuantity)
            {
                existing.Quantity++;
                existing.SubTotal = existing.Quantity * existing.UnitPrice;
            }
        }
        else
        {
            _cart.Insert(0, new OrderItem
            {
                Id = Guid.NewGuid(),
                ProductId = item.ProductId,
                ProductName = item.Name,
                Quantity = 1,
                UnitPrice = item.Price,
                SubTotal = item.Price
            });
        }
        StateHasChanged();
        JSRuntime.InvokeVoidAsync("initIcons");
    }

    private void IncreaseQuantity(OrderItem item)
    {
        // Find corresponding inventory to check stock
        var inv = _branchInventories?.FirstOrDefault(i => i.ProductId == item.ProductId);
        if (inv != null && item.Quantity < inv.StockQuantity)
        {
            item.Quantity++;
            item.SubTotal = item.Quantity * item.UnitPrice;
            StateHasChanged();
        }
    }

    private void DecreaseQuantity(OrderItem item)
    {
        if(item.Quantity > 1)
        {
            item.Quantity--;
            item.SubTotal = item.Quantity * item.UnitPrice;
        }
        else
        {
            _cart.Remove(item);
        }
        StateHasChanged();
    }

    private void ClearCart()
    {
        _cart.Clear();
        StateHasChanged();
    }
    
    private async Task Checkout()
    {
        if (!_cart.Any() || !_selectedBranchId.HasValue || !_selectedMerchantId.HasValue || _currentUser == null) return;

        _isProcessing = true;
        StateHasChanged();

        try
        {
            var request = new
            {
                BranchId = _selectedBranchId.Value,
                MerchantId = _selectedMerchantId.Value,
                OrderedItems = _cart.Select(i => new {
                    ProductId = i.ProductId,
                    Quantity = i.Quantity
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("api/orders", request);
            
            if (response.IsSuccessStatusCode)
            {
                _cart.Clear();
                _showSuccessModal = true;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Order failed: {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Checkout error: {ex.Message}");
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private async Task CloseSuccessModal()
    {
        _showSuccessModal = false;
        await LoadBranchInventories(); // Refresh stock
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
