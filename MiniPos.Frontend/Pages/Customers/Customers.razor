@page "/customers"
@using MiniPos.Frontend.Shared.Types

<PageTitle>Client Directory - MiniPOS</PageTitle>

<PageHeader Title="Client Directory" 
            Subtitle="Maintain detailed customer profiles and loyalty"
            SearchPlaceholder="Search customers..."
            @bind-SearchTerm="_searchTerm"
            ShowViewToggle="false"
            OnSearch="LoadData">
    <Filters>
        <div class="relative group">
            <i data-lucide="store"
               class="w-3.5 h-3.5 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors pointer-events-none"></i>
            <select @bind="_selectedMerchantId" @bind:after="LoadData"
                    class="bg-white border border-border/60 rounded-2xl text-xs font-bold py-2.5 pl-10 pr-10 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm cursor-pointer appearance-none">
                <option value="">All Merchants</option>
                @foreach (var mer in _merchants)
                {
                    <option value="@mer.Id">@mer.Name</option>
                }
            </select>
            <i data-lucide="chevron-down"
               class="w-3.5 h-3.5 absolute right-3.5 top-1/2 -translate-y-1/2 text-muted-foreground transition-transform group-focus-within:rotate-180 pointer-events-none"></i>
        </div>
    </Filters>
    <Actions>
        <button class="btn btn-primary px-6 h-12 shadow-xl shadow-primary/20 flex items-center gap-3 transition-all" @onclick="GoToAddCustomer">
            <i data-lucide="plus" class="w-5 h-5 font-black"></i>
            <span class="font-black uppercase tracking-tight text-sm">Add Customer</span>
        </button>
    </Actions>
</PageHeader>

<div class="bg-white/40 backdrop-blur-xl border border-white/60 rounded-[2rem] shadow-2xl shadow-primary/5 overflow-hidden flex flex-col min-h-0">
    @if (_isLoading && (_pagedCustomers == null || !_pagedCustomers.Data.Any()))
    {
        <div class="flex-1 flex flex-col items-center justify-center p-24">
            <div class="animate-spin rounded-full h-12 w-12 border-4 border-t-primary border-primary/20"></div>
            <p class="mt-6 text-sm font-bold text-muted-foreground tracking-widest uppercase">Fetching directory...</p>
        </div>
    }
    else if (_pagedCustomers == null || !_pagedCustomers.Data.Any())
    {
        <div class="flex-1 flex flex-col items-center justify-center p-24 text-center">
            <div class="w-20 h-20 bg-muted/20 rounded-3xl flex items-center justify-center mb-6">
                <i data-lucide="user-x" class="w-10 h-10 text-muted-foreground/30"></i>
            </div>
            <h3 class="text-xl font-black text-foreground">No clients found</h3>
            <p class="text-muted-foreground max-w-xs mx-auto mt-2">Add your first customer to start tracking loyalty.</p>
        </div>
    }
    else
    {
        <div class="flex-1 overflow-auto custom-scrollbar">
            <table class="w-full text-left border-collapse table-fixed lg:table-auto">
                <thead class="sticky top-0 z-10 bg-white/80 backdrop-blur-md border-b border-border/10">
                    <tr>
                        <th class="pl-8 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground w-[35%]">Customer</th>
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground">Contact</th>
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground">Location</th>
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-center">Loyalty</th>
                        <th class="pr-8 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-right w-32">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border/5">
                @foreach (var customer in _pagedCustomers.Data)
                {
                    <tr class="group hover:bg-white/40 transition-all cursor-pointer">
                        <td class="pl-8 py-4">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center text-slate-500 border border-slate-200">
                                    <i data-lucide="user" class="w-5 h-5"></i>
                                </div>
                                <div class="min-w-0">
                                    <h4 class="font-black text-sm text-foreground group-hover:text-primary transition-colors truncate font-outfit">@customer.Name</h4>
                                    <p class="text-[11px] text-muted-foreground font-medium truncate">ID: @customer.Id.ToString().Substring(0, 8)</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-foreground">@customer.PhoneNumber</span>
                                <span class="text-[11px] text-muted-foreground font-medium">@customer.Email</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2 text-xs font-bold text-foreground/70">
                                <i data-lucide="map-pin" class="w-3.5 h-3.5 text-muted-foreground/40"></i>
                                <span class="truncate">@customer.Address</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="px-3 py-1 bg-primary/5 text-primary text-[10px] font-black uppercase tracking-widest rounded-lg border border-primary/10">Member</span>
                        </td>
                        <td class="pr-8 py-4 text-right">
                            <button class="w-9 h-9 rounded-xl hover:bg-white shadow-sm border border-transparent hover:border-border/40 flex items-center justify-center transition-all text-muted-foreground hover:text-primary active:scale-90 ml-auto">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <Pagination CurrentPage="_currentPage" 
                    TotalPages="@(_pagedCustomers?.TotalPages ?? 1)" 
                    TotalCount="@(_pagedCustomers?.TotalCount ?? 0)"
                    PageSize="10"
                    PageChanged="HandlePageChanged" />
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private PagedResult<Customer>? _pagedCustomers;
    private List<Merchant> _merchants = new();
    private Guid? _selectedMerchantId;
    private string _searchTerm = "";
    private int _currentPage = 1;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadMerchants();
        await LoadData();
    }

    private async Task LoadMerchants()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<PagedResult<Merchant>>("api/merchants?pageSize=100");
            _merchants = result?.Data ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading merchants: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var url = $"api/customers?page={_currentPage}&pageSize=10";
            if (!string.IsNullOrEmpty(_searchTerm)) url += $"&searchTerm={Uri.EscapeDataString(_searchTerm)}";
            if (_selectedMerchantId.HasValue) url += $"&merchantId={_selectedMerchantId.Value}";

            _pagedCustomers = await Http.GetFromJsonAsync<PagedResult<Customer>>(url);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customers: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private void GoToAddCustomer() => Nav.NavigateTo("/customers/add");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
