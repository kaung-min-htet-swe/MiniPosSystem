@page "/products/{ProductId}"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Product Details - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-4xl mx-auto pb-12">
    <!-- Header with Back Navigation -->
    <div class="mb-8 flex justify-between items-center">
        <button class="flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors group" @onclick="GoBack">
            <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
            Back to Products
        </button>
        <div class="flex items-center gap-2">
            <button class="btn btn-outline border-border btn-sm rounded-lg flex items-center gap-1.5 hover:bg-muted/10 mr-1" @onclick="() => { _editStock = _ui.StockQuantity; _showStockModal = true; }">
                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Update Stock
            </button>
            <button class="btn btn-primary btn-sm rounded-lg flex items-center gap-1.5" @onclick="() => _showEditModal = true">
                <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Edit Product
            </button>
            <button class="btn btn-outline border-destructive/30 text-destructive btn-sm rounded-lg flex items-center gap-1.5 hover:bg-destructive/5" @onclick="() => _showDeleteModal = true">
                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
            </button>
        </div>
    </div>
    
    <!-- Floating Alert Box -->
    @if (!string.IsNullOrEmpty(_alertMessage))
    {
        <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] animate-slide-down">
            <div class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-2xl border backdrop-blur-md
                @(_alertType == "success" ? "bg-emerald-50/90 border-emerald-200 text-emerald-800" : "bg-rose-50/90 border-rose-200 text-rose-800")">
                <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center
                    @(_alertType == "success" ? "bg-emerald-100" : "bg-rose-100")">
                    <i data-lucide="@(_alertType == "success" ? "check-circle" : "alert-circle")" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="text-xs font-black uppercase tracking-widest opacity-60">@(_alertType == "success" ? "Success" : "Error")</p>
                    <p class="text-sm font-bold">@_alertMessage</p>
                </div>
            </div>
        </div>
    }

    @if (_product == null)
    {
        <div class="flex flex-col items-center justify-center p-24">
            <div class="animate-spin rounded-full h-10 w-10 border-4 border-t-primary border-primary/20"></div>
            <span class="mt-4 text-sm font-bold text-muted-foreground">Loading product parameters...</span>
        </div>
    }
    else
    {
        <!-- Main Details display -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Info column -->
            <div class="lg:col-span-2 flex flex-col gap-6">
                <!-- Profile Banner Card -->
                <div class="pos-card p-0 overflow-hidden bg-white/60 shadow-xl border-border/40 flex flex-col h-full">
                    <div class="h-48 w-full bg-gradient-to-br @_ui.Gradient relative flex items-center justify-center">
                        <div class="absolute inset-0 bg-white/10 backdrop-blur-3xl"></div>
                        <div class="absolute -top-10 -right-10 w-40 h-40 bg-white/20 rounded-full blur-2xl"></div>
                        <i data-lucide="@_ui.Icon" class="w-20 h-20 text-white/90 drop-shadow-md z-10"></i>
                        <span class="absolute top-4 left-4 badge bg-white @_ui.BadgeClass text-xs font-bold shadow-md rounded-full px-2.5 py-1">@_categoryName</span>
                    </div>
                    <div class="p-8">
                        <h1 class="text-3xl font-black text-foreground tracking-tight mb-2">@_product.Name</h1>
                        <div class="flex items-center gap-4 text-sm font-semibold text-muted-foreground">
                            <span class="flex items-center gap-1"><i data-lucide="tag" class="w-4 h-4"></i> SKU: @_product.Sku</span>
                            <span class="w-1.5 h-1.5 rounded-full bg-muted-foreground/40"></span>
                            <span class="flex items-center gap-1"><i data-lucide="folder" class="w-4 h-4"></i> Category: @_categoryName</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right side Sidebar specs -->
            <div class="flex flex-col gap-6">
                <!-- Pricing & Inventory -->
                <div class="pos-card bg-white/60 shadow-lg border-border/40 p-6">
                    <h3 class="text-xs font-black uppercase tracking-wider text-muted-foreground mb-4">Pricing & Inventory</h3>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center bg-muted/20 p-4 rounded-xl border border-border/30">
                            <span class="text-sm font-bold text-muted-foreground">Retail Price</span>
                            <span class="text-2xl font-black font-outfit text-primary">$@_product.Price.ToString("F2")</span>
                        </div>
                        <div class="flex justify-between items-center px-2">
                            <span class="text-xs text-muted-foreground">Calculated Stock</span>
                            <div class="flex items-center gap-1.5">
                                <span class="w-2 h-2 rounded-full @_ui.StatusClass"></span>
                                <span class="text-sm font-bold text-foreground">@_ui.StockQuantity Units</span>
                            </div>
                        </div>
                        <hr class="border-border/30" />
                        <div class="flex justify-between items-center px-2">
                            <span class="text-xs text-muted-foreground">Created On</span>
                            <span class="text-sm font-bold font-outfit text-foreground">@_product.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- --- Action Modals --- -->

        <!-- Edit Modal -->
        @if (_showEditModal)
        {
            <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
                <div class="bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-border/40 w-full max-w-md p-6 animate-scale-up space-y-5">
                    <div class="flex items-center gap-2 text-primary">
                        <i data-lucide="pencil" class="w-5 h-5"></i>
                        <h3 class="text-lg font-bold">Edit Product</h3>
                    </div>
                    <div class="space-y-4">
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Product Name</label>
                            <input type="text" @bind="_editName" class="w-full px-4 py-2.5 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium" />
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">SKU</label>
                            <input type="text" @bind="_editSku" class="w-full px-4 py-2.5 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium" />
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Price ($)</label>
                            <input type="number" step="0.01" @bind="_editPrice" class="w-full px-4 py-2.5 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium" />
                        </div>
                    </div>
                    <div class="flex justify-end gap-3 pt-2">
                        <button class="btn btn-ghost rounded-xl px-4 text-sm" @onclick='() => _showEditModal = false' disabled="@_isSubmitting">Cancel</button>
                        <button class="btn btn-primary rounded-xl px-5 text-sm shadow-primary disabled:opacity-50 flex items-center gap-2" @onclick="HandleEditProduct" disabled="@_isSubmitting">
                            @if (_isSubmitting) { <div class="animate-spin rounded-full h-3.5 w-3.5 border-2 border-white/20 border-t-white"></div> }
                            <span>Save Changes</span>
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Update Stock Modal -->
        @if (_showStockModal)
        {
            <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
                <div class="bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-border/40 w-full max-w-md p-6 animate-scale-up space-y-5">
                    <div class="flex items-center gap-2 text-primary">
                        <i data-lucide="plus" class="w-5 h-5"></i>
                        <h3 class="text-lg font-bold">Update Stock</h3>
                    </div>
                    <div class="space-y-4">
                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Adjust Quantity Units</label>
                            <input type="number" @bind="_editStock" class="w-full px-4 py-2.5 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium" />
                        </div>
                    </div>
                    <div class="flex justify-end gap-3 pt-2">
                        <button class="btn btn-ghost rounded-xl px-4 text-sm" @onclick='() => _showStockModal = false' disabled="@_isSubmitting">Cancel</button>
                        <button class="btn btn-primary rounded-xl px-5 text-sm shadow-primary disabled:opacity-50 flex items-center gap-2" @onclick="HandleUpdateStock" disabled="@_isSubmitting">
                            @if (_isSubmitting) { <div class="animate-spin rounded-full h-3.5 w-3.5 border-2 border-white/20 border-t-white"></div> }
                            <span>Update</span>
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Delete Modal -->
        @if (_showDeleteModal)
        {
            <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
                <div class="bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-border/40 w-full max-w-md p-6 animate-scale-up space-y-5">
                    <div class="flex items-center gap-2 text-destructive">
                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                        <h3 class="text-lg font-bold">Delete Product</h3>
                    </div>
                    <p class="text-sm text-muted-foreground">Are you sure you want to delete Product <b>@_product.Name</b>? Doing so will halt linked inventory counters safely.</p>
                    <div class="flex justify-end gap-3 pt-2">
                        <button class="btn btn-ghost rounded-xl px-4 text-sm" @onclick='() => _showDeleteModal = false' disabled="@_isSubmitting">Cancel</button>
                        <button class="btn btn-destructive rounded-xl px-5 text-sm flex items-center gap-2" @onclick="HandleDeleteProduct" disabled="@_isSubmitting">
                            @if (_isSubmitting) { <div class="animate-spin rounded-full h-3.5 w-3.5 border-2 border-white/20 border-t-white"></div> }
                            <span>Delete</span>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string ProductId { get; set; } = "";

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private ProductGetByIdResponseDto? _product;
    private ProductUI _ui = new();
    private string _categoryName = "General";

    // Modals controls
    private bool _showEditModal = false;
    private bool _showDeleteModal = false;
    private bool _showStockModal = false;

    private string _editName = "";
    private string _editSku = "";
    private decimal _editPrice = 0;
    private int _editStock = 0;

    private bool _isSubmitting = false;

    // Alert state
    private string _alertMessage = "";
    private string _alertType = "success";

    public class ProductUI
    {
        public string Icon { get; set; } = "";
        public string Gradient { get; set; } = "";
        public string BadgeClass { get; set; } = "";
        public string StatusClass { get; set; } = "";
        public int StockQuantity { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"api/products/{ProductId}");
            if (response.IsSuccessStatusCode)
            {
                _product = await response.Content.ReadFromJsonAsync<ProductGetByIdResponseDto>();
                if (_product != null)
                {
                    _editName = _product.Name;
                    _editSku = _product.Sku;
                    _editPrice = _product.Price;

                    await LoadCategoryData(_product.CategoryId);
                    _ui = GetProductUI(_product);
                }
            }
            else
            {
                await ShowAlert("Failed to load product details.", "error");
            }
        }
        catch (Exception ex)
        {
            await ShowAlert($"Error loading product: {ex.Message}", "error");
        }
    }

    private async Task LoadCategoryData(Guid categoryId)
    {
        var response = await Http.GetAsync($"api/categories/{categoryId}");
        if (response.IsSuccessStatusCode)
        {
            var category = await response.Content.ReadFromJsonAsync<CategoryGetByIdResponseDto>();
            _categoryName = category?.Name ?? "General";
        }
    }

    private ProductUI GetProductUI(ProductGetByIdResponseDto product)
    {
        var catName = _categoryName;
        var style = GetCategoryStyle(catName);

        var hash = Math.Abs(product.Id.GetHashCode());
        var isOutOfStock = hash % 10 == 0; 
        var stockQty = isOutOfStock ? 0 : (hash % 150) + 10;
        var statusClass = isOutOfStock ? "bg-destructive" : (stockQty < 20 ? "bg-warning" : "bg-success");

        return new ProductUI
        {
            Icon = style.Icon,
            Gradient = style.Gradient,
            BadgeClass = style.BadgeClass,
            StatusClass = statusClass,
            StockQuantity = stockQty
        };
    }

    private (string Icon, string Gradient, string BadgeClass) GetCategoryStyle(string name)
    {
        var categoryStyleMaps = new Dictionary<string, (string Icon, string Gradient, string BadgeClass)>
        {
            { "Coffee Beans", ("coffee", "from-indigo-500 to-purple-600", "text-primary") },
            { "Tea", ("leaf", "from-emerald-400 to-teal-600", "text-emerald-600") },
            { "Pastries", ("croissant", "from-amber-400 to-orange-500", "text-orange-600") },
            { "Merchandise", ("shopping-bag", "from-slate-400 to-slate-600", "text-slate-700") }
        };

        if (categoryStyleMaps.TryGetValue(name, out var style)) return style;
        var icons = new[] { "package", "box", "tag", "bookmark" };
        var gradients = new[] { "from-primary to-primary", "from-blue-500 to-indigo-600", "from-violet-400 to-purple-600" };
        var hash = Math.Abs(name.GetHashCode());
        return (icons[hash % icons.Length], gradients[hash % gradients.Length], "text-primary");
    }

    private void GoBack() { Navigation.NavigateTo("/products"); }

    private async Task HandleEditProduct()
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;
        _isSubmitting = true;

        try
        {
            var request = new ProductUpdateRequestDto
            {
                Name = _editName,
                Sku = _editSku,
                Price = _editPrice
            };

            var response = await Http.PutAsJsonAsync($"api/products/{ProductId}", request);
            if (response.IsSuccessStatusCode)
            {
                if (_product != null)
                {
                    _product.Name = _editName;
                    _product.Sku = _editSku;
                    _product.Price = _editPrice;
                }
                await ShowAlert("Product updated successfully!");
                _showEditModal = false;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await ShowAlert($"Update failed: {error}", "error");
            }
        }
        catch (Exception ex)
        {
            await ShowAlert($"Network error: {ex.Message}", "error");
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task HandleUpdateStock()
    {
        // Note: ProductService doesn't handle stock directly.
        // This would normally go to an InventoryService.
        await ShowAlert("Stock update is managed via Branch Inventory. Please use the Inventory module for real updates.", "warning");
        _showStockModal = false;
    }

    private async Task HandleDeleteProduct()
    {
        _isSubmitting = true;
        try
        {
            var response = await Http.DeleteAsync($"api/products/{ProductId}");
            if (response.IsSuccessStatusCode)
            {
                await ShowAlert("Product deleted successfully!");
                await Task.Delay(1500);
                Navigation.NavigateTo("/products");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await ShowAlert($"Delete failed: {error}", "error");
            }
        }
        catch (Exception ex)
        {
            await ShowAlert($"Network error: {ex.Message}", "error");
        }
        finally
        {
            _isSubmitting = false;
            _showDeleteModal = false;
        }
    }

    private async Task ShowAlert(string message, string type = "success")
    {
        _alertMessage = message;
        _alertType = type;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("initIcons");
        _alertMessage = "";
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await JSRuntime.InvokeVoidAsync("initIcons"); }
    }
}
