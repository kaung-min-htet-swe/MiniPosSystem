@page "/categories"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Categories - MiniPOS</PageTitle>

@if (!string.IsNullOrEmpty(_alertMessage))
{
    <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] animate-slide-down">
        <div class="px-6 py-4 rounded-2xl shadow-2xl backdrop-blur-md flex items-center gap-4 border
            @(_alertType == "success" ? "bg-success border-success/30 text-white" : "bg-destructive border-destructive/30 text-white")">
            <i data-lucide="@(_alertType == "success" ? "check-circle-2" : "alert-circle")" class="w-6 h-6 shrink-0"></i>
            <span class="font-bold tracking-wide">@_alertMessage</span>
            <button @onclick='() => _alertMessage = ""' class="ml-4 hover:opacity-70 transition-opacity">
                <i data-lucide="x" class="w-4 h-4 text-white/80"></i>
            </button>
        </div>
    </div>
}

<div class="animate-slide-down">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Categories</h1>
            <p class="text-muted-foreground mt-1 text-sm">Organize your menu and product catalog effectively.</p>
        </div>
        <button class="btn btn-primary rounded-lg shadow-primary" @onclick="GoToAddCategory">
            <i data-lucide="folder-plus" class="w-4 h-4 mr-2"></i>
            Create Category
        </button>
    </div>

    @if (_pagedCategories == null)
    {
        <div class="flex items-center justify-center h-48">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var category in _pagedCategories.Data)
            {
                var style = GetCategoryStyle(category.Name);
                var colorClass = style.Color == "primary" ? "primary" : style.Color;
                var textColor = style.Color == "primary" ? "text-primary" : $"text-{colorClass}-600";
                var borderColorHover = style.Color == "primary" ? "hover:border-primary/30" : $"hover:border-{colorClass}-500/30";
                var bgGlow = style.Color == "primary" ? "bg-primary/20" : $"bg-{colorClass}-500/20";
                var bgGlowHover = style.Color == "primary" ? "group-hover:bg-primary/40" : $"group-hover:bg-{colorClass}-500/40";
                var bgIcon = style.Color == "primary" ? "bg-primary/10" : $"bg-{colorClass}-500/10";
                <div class="pos-card overflow-hidden group hover:shadow-lg transition-all border-border @borderColorHover flex flex-col h-48 cursor-pointer pl-8" @onclick="() => GoToCategoryDetail(category.Id)">
                    <div class="absolute -left-6 top-1/2 -translate-y-1/2 w-4 h-32 @bgGlow rounded-full blur-xl @bgGlowHover transition-colors"></div>
                    <div class="w-12 h-12 rounded-full @bgIcon @textColor flex items-center justify-center mb-4 mt-2">
                        <i data-lucide="@style.Icon" class="w-6 h-6"></i>
                    </div>
                    <h3 class="font-bold text-xl text-foreground mb-1">@category.Name</h3>
                    <p class="text-muted-foreground text-[10px] font-bold uppercase tracking-wider mb-2">@category.MerchantName</p>
                    <p class="text-xs text-muted-foreground line-clamp-2 pr-6 mb-auto">@category.Description</p>
                    <div class="mt-4 pt-3 border-t border-border/50 text-xs font-bold uppercase tracking-widest @textColor flex items-center">
                        @category.ProductCount Items <i data-lucide="arrow-right" class="w-3 h-3 ml-2 group-hover:translate-x-1 transition-transform"></i>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private PagedResult<CategoryListResponseDto>? _pagedCategories;
    private string userId = "3798433e-f36b-1410-8548-003fb1df8966";
    
    // Alert state
    private string _alertMessage = "";
    private string _alertType = "success";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"api/categories?merchantId={userId}&page=1&pageSize=12");
            if (!response.IsSuccessStatusCode)
            {
                await ShowAlert("Failed to load categories.", "error");
                return;
            }

            _pagedCategories = await response.Content.ReadFromJsonAsync<PagedResult<CategoryListResponseDto>>();
        }
        catch (Exception ex)
        {
            await ShowAlert($"Error loading categories: {ex.Message}", "error");
        }
    }

    private (string Icon, string Color) GetCategoryStyle(string name)
    {
        var lowerName = name.ToLower();
        
        // Keyword matching for Icons
        string icon = lowerName switch
        {
            var n when n.Contains("coffee") || n.Contains("espresso") || n.Contains("latte") => "coffee",
            var n when n.Contains("bakery") || n.Contains("bread") || n.Contains("pastry") || n.Contains("croissant") => "croissant",
            var n when n.Contains("food") || n.Contains("meal") || n.Contains("dish") || n.Contains("lunch") || n.Contains("dinner") => "utensils",
            var n when n.Contains("beverage") || n.Contains("drink") || n.Contains("soda") || n.Contains("juice") => "cup-soda",
            var n when n.Contains("dessert") || n.Contains("sweet") || n.Contains("cake") => "ice-cream",
            var n when n.Contains("merchandise") || n.Contains("gift") || n.Contains("shop") => "shopping-bag",
            var n when n.Contains("leaf") || n.Contains("tea") || n.Contains("organic") || n.Contains("vegan") => "leaf",
            var n when n.Contains("package") || n.Contains("box") || n.Contains("delivery") => "package",
            var n when n.Contains("tag") || n.Contains("sale") || n.Contains("offer") => "tag",
            var n when n.Contains("star") || n.Contains("featured") || n.Contains("special") => "star",
            _ => "folder"
        };

        // Keyword matching for Colors
        string color = lowerName switch
        {
            var n when n.Contains("coffee") || n.Contains("espresso") => "orange",
            var n when n.Contains("bakery") || n.Contains("pastry") => "amber",
            var n when n.Contains("food") || n.Contains("meal") => "rose",
            var n when n.Contains("beverage") || n.Contains("drink") => "sky",
            var n when n.Contains("dessert") || n.Contains("sweet") => "pink",
            var n when n.Contains("leaf") || n.Contains("tea") || n.Contains("organic") => "emerald",
            var n when n.Contains("merchandise") || n.Contains("shop") => "indigo",
            var n when n.Contains("special") || n.Contains("star") => "yellow",
            var n when n.Contains("sale") || n.Contains("tag") => "fuchsia",
            _ => "primary"
        };

        // Fallbacks for unknown categories
        if (icon == "folder")
        {
            var icons = new[] { "folder", "bookmark", "box", "archive", "layers" };
            icon = icons[Math.Abs(name.GetHashCode()) % icons.Length];
        }
        
        if (color == "primary")
        {
            var colors = new[] { "primary", "emerald", "orange", "indigo", "rose", "pink", "sky", "violet", "amber", "cyan", "fuchsia", "lime" };
            color = colors[Math.Abs(name.GetHashCode() + 3) % colors.Length];
        }

        return (icon, color);
    }

    private void GoToCategoryDetail(Guid id)
    {
        Navigation.NavigateTo($"/categories/{id}");
    }

    private void GoToAddCategory()
    {
        Navigation.NavigateTo("/categories/add");
    }

    private async Task ShowAlert(string message, string type = "success")
    {
        _alertMessage = message;
        _alertType = type;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("initIcons");
        await Task.Delay(5000);
        _alertMessage = "";
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
