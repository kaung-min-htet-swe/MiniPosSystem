@page "/cashiers/create"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Color="Color.Primary">Register New Cashier</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Create a new account and assign them to a branch.
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            @if (_isLoadingMerchants)
            {
                <div class="d-flex justify-center my-4">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true"/>
                </div>
            }
            else
            {
                <MudForm @ref="_form" Model="@_cashierModel">

                    <MudGrid>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Account Credentials</MudText>
                            <MudDivider Class="mb-4"/>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_cashierModel.Username"
                                          Label="Username"
                                          Required="true"
                                          RequiredError="Username is required."
                                          Variant="Variant.Outlined"/>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_cashierModel.Email"
                                          Label="Email Address"
                                          Required="true"
                                          RequiredError="Email is required."
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"/>
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_cashierModel.Password"
                                          Label="Temporary Password"
                                          Required="true"
                                          RequiredError="Password is required."
                                          InputType="@_passwordInput"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@_passwordInputIcon"
                                          OnAdornmentClick="TogglePasswordVisibility"
                                          AdornmentAriaLabel="Show Password"/>
                        </MudItem>

                        <MudItem xs="12" Class="mt-4">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Location Assignment</MudText>
                            <MudDivider Class="mb-4"/>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="string"
                                       Label="Merchant"
                                       Value="_cashierModel.MerchantId"
                                       ValueChanged="OnMerchantChanged"
                                       Required="true"
                                       RequiredError="Please select a Merchant."
                                       Variant="Variant.Outlined"
                                       AnchorOrigin="Origin.BottomCenter"
                                       Clearable="true">
                                @foreach (var merchant in _availableMerchants)
                                {
                                    <MudSelectItem T="Guid?" Value="@merchant.Id">@merchant.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="string"
                                       Label="Branch"
                                       @bind-Value="_cashierModel.BranchId"
                                       Required="true"
                                       RequiredError="Please assign a specific Branch."
                                       Variant="Variant.Outlined"
                                       AnchorOrigin="Origin.BottomCenter"
                                       Disabled="@(_cashierModel.MerchantId == null || _isLoadingBranches)"
                                       Clearable="true">
                                @if (_isLoadingBranches)
                                {
                                    <MudSelectItem T="Guid?" Value="null" Disabled="true">Loading branches...
                                    </MudSelectItem>
                                }
                                else if (!_availableBranches.Any() && _cashierModel.MerchantId != null)
                                {
                                    <MudSelectItem T="Guid?" Value="null" Disabled="true">No branches available.
                                    </MudSelectItem>
                                }
                                else
                                {
                                    @foreach (var branch in _availableBranches)
                                    {
                                        <MudSelectItem T="Guid?" Value="@branch.Id">@branch.Name</MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudForm>
            }
        </MudCardContent>

        <MudCardActions Class="pb-4 pl-4 pr-4 d-flex justify-end">
            <MudButton Variant="Variant.Text" OnClick="Cancel" Class="mr-2">Cancel</MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitForm"
                       Disabled="@(_isLoadingMerchants || _isSaving)">
                @if (_isSaving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">Creating...</MudText>
                }
                else
                {
                    <MudText>Create Cashier</MudText>
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>