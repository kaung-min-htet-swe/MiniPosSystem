@page "/categories/create"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Color="Color.Primary">Create New Category</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Add a new product category to organize your
                    inventory.
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            @if (_isLoadingMerchants)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4"/>
                <MudText Typo="Typo.caption">Loading available merchants...</MudText>
            }
            else
            {
                <MudForm @ref="_form" Model="@_categoryModel">

                    <MudSelect T="string"
                               Label="Assign to Merchant"
                               @bind-Value="@_categoryModel.MerchantId"
                               Required="true"
                               RequiredError="You must select a merchant."
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter"
                               Class="mb-4">
                        @foreach (var merchant in _availableMerchants)
                        {
                            <MudSelectItem Value="@merchant.Id">@merchant.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField @bind-Value="_categoryModel.Name"
                                  Label="Category Name"
                                  Required="true"
                                  RequiredError="Category name is required."
                                  Variant="Variant.Outlined"
                                  Placeholder="e.g., Hot Beverages"
                                  Class="mb-4"/>

                    <MudTextField @bind-Value="_categoryModel.Description"
                                  Label="Description (Optional)"
                                  Lines="3"
                                  Variant="Variant.Outlined"
                                  Placeholder="Briefly describe what items belong in this category..."
                                  Class="mb-4"/>
                </MudForm>
            }
        </MudCardContent>

        <MudCardActions Class="pb-4 pl-4 pr-4 d-flex justify-end">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       OnClick="Cancel"
                       Class="mr-2">
                Cancel
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitForm"
                       Disabled="@(_isLoadingMerchants || _isSaving)">
                @if (_isSaving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">Creating...</MudText>
                }
                else
                {
                    <MudText>Create Category</MudText>
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>