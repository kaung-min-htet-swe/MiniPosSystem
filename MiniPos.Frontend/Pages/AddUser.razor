@page "/users/add"
@using MiniPos.Frontend.Models

<PageTitle>Add Staff - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-3xl mx-auto pb-12">
    <!-- Header with Back Navigation -->
    <div class="mb-10">
        <button
            class="flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors mb-6 group"
            @onclick="GoBack">
            <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
            Back to Staff Directory
        </button>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Add New Staff</h1>
        <p class="text-muted-foreground mt-1 text-sm">Create a new merchant account or register a cashier to a
            branch.</p>
    </div>

    @if (!string.IsNullOrEmpty(_alertMessage))
    {
        <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] animate-slide-down">
            <div class="px-6 py-4 rounded-2xl shadow-2xl backdrop-blur-md flex items-center gap-4 border
                @(_alertType == "success" ? "bg-success border-success/30 text-white" : "bg-destructive border-destructive/30 text-white")">
                <i data-lucide="@(_alertType == "success" ? "check-circle-2" : "alert-circle")" class="w-6 h-6 shrink-0"></i>
                <span class="font-bold tracking-wide">@_alertMessage</span>
                <button @onclick='() => _alertMessage = ""' class="ml-4 hover:opacity-70 transition-opacity">
                    <i data-lucide="x" class="w-4 h-4 text-white/80"></i>
                </button>
            </div>
        </div>
    }

    <!-- Error/Success Banners (deprecated in favor of floating alerts, except the Success Card) -->
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div
            class="mb-6 p-4 rounded-2xl bg-destructive/10 border border-destructive/30 text-destructive flex items-center gap-3 animate-fade-in shadow-sm">
            <i data-lucide="alert-circle" class="w-5 h-5 shrink-0"></i>
            <span class="text-sm font-semibold">@_errorMessage</span>
        </div>
    }

    @if (string.IsNullOrEmpty(_successMessage))
    {
        <!-- Main Form Card -->
        <div class="pos-card p-0 overflow-hidden bg-white/60 shadow-lg border-border/40 animate-slide-up">

            <!-- Role Selection Header -->
            <div
                class="p-8 pb-6 border-b border-border/40 bg-gradient-to-br from-white/80 to-transparent relative overflow-hidden">
                <div
                    class="absolute -right-8 -top-8 w-32 h-32 bg-primary/5 rounded-full blur-2xl pointer-events-none"></div>
                <h2 class="text-xl font-bold text-foreground mb-1 relative z-10">Select Role</h2>
                <p class="text-sm text-muted-foreground relative z-10">Choose the type of staff account to create.</p>

                <div class="flex gap-4 mt-6 relative z-10">
                    <button class="flex-1 p-4 rounded-2xl border-2 transition-all flex flex-col items-center gap-3 group
                        @(_selectedRole == "Merchant" ? "border-primary bg-primary/5 shadow-md shadow-primary/10" : "border-border/60 bg-white/50 hover:border-primary/30 hover:bg-white")"
                            @onclick='() => SelectRole("Merchant")'>
                        <div class="w-14 h-14 rounded-full flex items-center justify-center transition-all
                            @(_selectedRole == "Merchant" ? "bg-primary text-white shadow-lg shadow-primary/30" : "bg-muted/50 text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary")">
                            <i data-lucide="briefcase" class="w-6 h-6"></i>
                        </div>
                        <div class="text-center">
                            <div
                                class="font-bold text-sm @(_selectedRole == "Merchant" ? "text-primary" : "text-foreground")">
                                Merchant
                            </div>
                            <div class="text-[10px] text-muted-foreground font-medium mt-0.5">Store owner / operator</div>
                        </div>
                    </button>

                    <button class="flex-1 p-4 rounded-2xl border-2 transition-all flex flex-col items-center gap-3 group
                        @(_selectedRole == "Cashier" ? "border-success bg-success/5 shadow-md shadow-success/10" : "border-border/60 bg-white/50 hover:border-success/30 hover:bg-white")"
                            @onclick='() => SelectRole("Cashier")'>
                        <div class="w-14 h-14 rounded-full flex items-center justify-center transition-all
                            @(_selectedRole == "Cashier" ? "bg-success text-white shadow-lg shadow-success/30" : "bg-muted/50 text-muted-foreground group-hover:bg-success/10 group-hover:text-success")">
                            <i data-lucide="calculator" class="w-6 h-6"></i>
                        </div>
                        <div class="text-center">
                            <div
                                class="font-bold text-sm @(_selectedRole == "Cashier" ? "text-success" : "text-foreground")">
                                Cashier
                            </div>
                            <div class="text-[10px] text-muted-foreground font-medium mt-0.5">Branch terminal operator</div>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Form Fields -->
            <div class="p-8 space-y-8">

                <!-- Account Information Section -->
                <div>
                    <h3 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-5 flex items-center gap-2">
                        <i data-lucide="user" class="w-4 h-4 text-primary"></i> Account Information
                    </h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Full Name <span
                                    class="text-destructive">*</span></label>
                            <input type="text" @bind="_userName" placeholder="e.g. John Doe"
                                   class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40 shadow-sm"/>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Email Address
                                <span class="text-destructive">*</span></label>
                            <input type="email" @bind="_email" placeholder="e.g. john@example.com"
                                   class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40 shadow-sm"/>
                        </div>
                        <div class="space-y-2 sm:col-span-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Password <span
                                    class="text-destructive">*</span></label>
                            <div class="relative">
                                <input type="@(_showPassword ? "text" : "password")" @bind="_password"
                                       placeholder="Min 8 characters"
                                       class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40 pr-12 shadow-sm"/>
                                <button type="button"
                                        class="absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors p-1"
                                        @onclick="TogglePassword">
                                    <i data-lucide="@(_showPassword ? "eye-off" : "eye")" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Merchant Details Section (shown for Merchant role) -->
                @if (_selectedRole == "Merchant")
                {
                    <div class="animate-fade-in">
                        <div class="h-px bg-border/40 mb-8"></div>
                        <h3 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-5 flex items-center gap-2">
                            <i data-lucide="building" class="w-4 h-4 text-primary"></i> Merchant Details
                        </h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Business
                                    Name <span class="text-destructive">*</span></label>
                                <input type="text" @bind="_merchantName" placeholder="e.g. Super Mart LLC"
                                       class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40 shadow-sm"/>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Business
                                    Email</label>
                                <input type="email" @bind="_merchantContactEmail" placeholder="e.g. info@supermart.com"
                                       class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40 shadow-sm"/>
                            </div>
                        </div>
                    </div>
                }

                <!-- Branch Assignment Section (shown for Cashier role) -->
                @if (_selectedRole == "Cashier")
                {
                    <div class="animate-fade-in">
                        <div class="h-px bg-border/40 mb-8"></div>
                        <h3 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-5 flex items-center gap-2">
                            <i data-lucide="store" class="w-4 h-4 text-success"></i> Branch Assignment
                        </h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Merchant
                                    <span class="text-destructive">*</span></label>
                                <div class="relative">
                                    <select @bind="_merchantId" @bind:after="OnMerchantChanged"
                                            class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium appearance-none cursor-pointer shadow-sm">
                                        <option value="">Select a merchant...</option>
                                        @if (_merchants != null)
                                        {
                                            @foreach (var merchant in _merchants)
                                            {
                                                <option value="@merchant.Id">@merchant.Name</option>
                                            }
                                        }
                                    </select>
                                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-muted-foreground/40">
                                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Branch <span
                                        class="text-destructive">*</span></label>
                                <div class="relative">
                                    <select @bind="_branchId"
                                            class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium appearance-none cursor-pointer shadow-sm">
                                        <option value="">Select a branch...</option>
                                        @if (_branches != null)
                                        {
                                            @foreach (var branch in _branches)
                                            {
                                                <option value="@branch.Id">@branch.Name</option>
                                            }
                                        }
                                    </select>
                                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-muted-foreground/40">
                                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Footer Actions -->
            <div
                class="px-8 py-6 bg-muted/20 border-t border-border/40 flex flex-col sm:flex-row justify-between items-center gap-4">
                <p class="text-xs text-muted-foreground font-medium">
                    <i data-lucide="info" class="w-3 h-3 inline mr-1"></i>
                    Fields marked with <span class="text-destructive font-bold">*</span> are required.
                </p>
                <div class="flex gap-3 w-full sm:w-auto">
                    <button class="flex-1 sm:flex-none btn btn-ghost rounded-xl px-8 hover:bg-white transition-all font-semibold"
                            @onclick="GoBack" disabled="@_isSubmitting">
                        Cancel
                    </button>
                    <button
                        class="flex-1 sm:flex-none btn btn-primary rounded-xl px-10 shadow-lg shadow-primary/20 disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2 font-bold transition-all hover:-translate-y-0.5"
                        @onclick="HandleSubmit" disabled="@(!IsFormValid() || _isSubmitting)">
                        @if (_isSubmitting)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-2 border-white/30 border-t-white"></div>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <i data-lucide="user-plus" class="w-4 h-4 text-white/80"></i>
                            <span>Create</span>
                        }
                    </button>
                </div>
            </div>

        </div>
    }
    else
    {
        <!-- Success Card View -->
        <div class="max-w-xl mx-auto animate-scale-in">
            <div class="pos-card overflow-hidden bg-white/40 shadow-2xl border-white/20 backdrop-blur-xl relative group">
                <!-- Background decorative glow -->
                <div class="absolute -right-20 -top-20 w-64 h-64 bg-success/10 rounded-full blur-3xl pointer-events-none group-hover:bg-success/20 transition-all duration-1000"></div>
                <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-primary/10 rounded-full blur-3xl pointer-events-none group-hover:bg-primary/20 transition-all duration-1000"></div>

                <div class="p-10 flex flex-col items-center text-center relative z-10">
                    <!-- Icon with animated rings -->
                    <div class="relative mb-8">
                        <div class="absolute inset-0 bg-success/20 rounded-full animate-ping opacity-20"></div>
                        <div class="absolute -inset-4 bg-success/10 rounded-full animate-pulse-subtle opacity-40"></div>
                        <div class="w-24 h-24 rounded-full bg-gradient-to-br from-success to-emerald-600 flex items-center justify-center shadow-[0_0_30px_rgba(16,185,129,0.4)] transition-transform hover:scale-110 duration-500">
                            <i data-lucide="check-circle-2" class="w-12 h-12 text-white drop-shadow-md"></i>
                        </div>
                    </div>

                    <h2 class="text-3xl font-extrabold text-foreground mb-2 bg-clip-text text-transparent bg-gradient-to-r from-foreground to-foreground/70">Account Ready!</h2>
                    <p class="text-muted-foreground mb-10 font-medium">New member registered and added to the network.</p>

                    <!-- Account Details Card -->
                    <div class="w-full bg-white/40 border border-white/40 rounded-3xl p-6 mb-10 backdrop-blur-sm text-left shadow-inner animate-slide-up">
                        <div class="flex items-center justify-between mb-6 pb-4 border-b border-border/20">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground">Account Summary</span>
                            <span class="px-3 py-1 bg-success/10 text-success text-[10px] font-bold uppercase tracking-wider rounded-full border border-success/20">Active</span>
                        </div>
                        
                        <div class="space-y-4">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0 border border-primary/20">
                                    <i data-lucide="user" class="w-5 h-5"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <p class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground mb-0.5">Full Name</p>
                                    <p class="text-base font-bold text-foreground truncate">@_lastCreatedUserName</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-xl bg-violet-500/10 flex items-center justify-center text-violet-500 shrink-0 border border-violet-500/20">
                                    <i data-lucide="mail" class="w-5 h-5"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <p class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground mb-0.5">Email Address</p>
                                    <p class="text-base font-bold text-foreground truncate">@_lastCreatedEmail</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-xl bg-orange-500/10 flex items-center justify-center text-orange-500 shrink-0 border border-orange-500/20">
                                    <i data-lucide="shield" class="w-5 h-5"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <p class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground mb-0.5">Access Role</p>
                                    <p class="text-base font-bold text-foreground truncate flex items-center gap-2">
                                        @_lastCreatedRole
                                        <i class="w-1 h-1 rounded-full bg-muted-foreground opacity-40"></i>
                                        <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Full Access</span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-col gap-3 w-full animate-slide-up" style="animation-delay: 150ms;">
                        <button class="w-full bg-gradient-to-r from-primary to-primary-600 text-white rounded-2xl py-4 font-bold shadow-xl shadow-primary/25 flex items-center justify-center gap-2 hover:-translate-y-0.5 hover:shadow-primary/30 active:scale-[0.98] transition-all duration-300"
                                @onclick="ResetForm">
                            <i data-lucide="user-plus" class="w-5 h-5"></i>
                            Register Another Member
                        </button>
                        <button class="w-full bg-white/40 border border-border/40 text-foreground rounded-2xl py-4 font-bold hover:bg-white active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-2"
                                @onclick="GoBack">
                            <i data-lucide="arrow-left" class="w-5 h-5"></i>
                            Back to Staff Directory
                        </button>
                    </div>
                </div>

                <div class="p-6 bg-muted/30 border-t border-border/20 text-center backdrop-blur-md">
                    <p class="text-[10px] text-muted-foreground font-bold uppercase tracking-widest flex items-center justify-center gap-2">
                         <i data-lucide="zap" class="w-3 h-3 text-orange-500 animate-pulse"></i>
                         Account is now authorized and ready for login
                    </p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    // Form state
    private string _selectedRole = "Merchant";
    private string _userName = "";
    private string _email = "";
    private string _password = "";
    private bool _showPassword;

    // Merchant fields
    private string _merchantName = "";
    private string _merchantContactEmail = "";

    // Cashier fields
    private string _merchantId = "";
    private string _branchId = "";

    // Dropdown data
    private List<Merchant>? _merchants;
    private List<Branch>? _branches;

    // UI state
    private bool _isSubmitting;
    private string _successMessage = "";
    private string _errorMessage = "";
    
    // Alert state
    private string _alertMessage = "";
    private string _alertType = "success";

    // Last created info for success view
    private string? _lastCreatedUserName;
    private string? _lastCreatedEmail;
    private string? _lastCreatedRole;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"api/merchants");
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to load merchants.";
                return;
            }

            var merchantData = await response.Content.ReadFromJsonAsync<PagedResult<Merchant>>();
            _merchants = merchantData?.Data;
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred during initialization: {ex.Message}";
            await ShowAlert("Initialization failed.", "error");
        }
    }
    
    private void SelectRole(string role)
    {
        _selectedRole = role;
        _errorMessage = "";
        _successMessage = "";
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private bool IsFormValid()
    {
        if (string.IsNullOrWhiteSpace(_userName) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
            return false;

        if (_selectedRole == "Merchant" && string.IsNullOrWhiteSpace(_merchantName))
            return false;

        if (_selectedRole == "Cashier" && (string.IsNullOrWhiteSpace(_merchantId) || string.IsNullOrWhiteSpace(_branchId)))
            return false;

        return true;
    }

    private async Task HandleSubmit()
    {
        _errorMessage = "";
        _successMessage = "";

        if (!IsFormValid())
        {
            _errorMessage = "Please fill in all required fields.";
            return;
        }

        _isSubmitting = true;

        try
        {
            var response = await Http.PostAsync("/api/users",
                JsonContent.Create(new
                {
                    UserName = _userName,
                    Email = _email,
                    Role = _selectedRole,
                    Password = _password,
                    MerchantId = _merchantId,
                    BranchId = _branchId
                }));

            if (response.IsSuccessStatusCode)
            {
                _successMessage = $"{_selectedRole} account for \"{_userName}\" created successfully!";
                
                // Store last created info
                _lastCreatedUserName = _userName;
                _lastCreatedEmail = _email;
                _lastCreatedRole = _selectedRole;

                _userName = "";
                _email = "";
                _password = "";
                _merchantName = "";
                _merchantContactEmail = "";
                _merchantId = "";
                _branchId = "";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _errorMessage = $"{_selectedRole} account creation failed: {error}";
                await ShowAlert("Account creation failed.", "error");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"A network error occurred: {ex.Message}";
            await ShowAlert("Network error.", "error");
        }
        finally
        {
            _isSubmitting = false;
        }

        StateHasChanged();
    }

    private void ResetForm()
    {
        _successMessage = "";
        _errorMessage = "";
        _userName = "";
        _email = "";
        _password = "";
        _merchantName = "";
        _merchantContactEmail = "";
        _merchantId = "";
        _branchId = "";
        StateHasChanged();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/users");
    }

    private async Task ShowAlert(string message, string type = "success")
    {
        _alertMessage = message;
        _alertType = type;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("initIcons");
        await Task.Delay(5000);
        _alertMessage = "";
        StateHasChanged();
    }

    private async Task ReinitIcons()
    {
        await JSRuntime.InvokeVoidAsync("initIcons");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("initIcons");
    }

    private async Task OnMerchantChanged()
    {
        if (!string.IsNullOrEmpty(_merchantId))
        {
            try
            {
                var request = new HttpRequestMessage(HttpMethod.Get, $"api/branches?merchantId={_merchantId}");
                request.SetBrowserRequestCredentials(Microsoft.AspNetCore.Components.WebAssembly.Http.BrowserRequestCredentials.Include);

                var response = await Http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    var branchData = await response.Content.ReadFromJsonAsync<PagedResult<Branch>>();
                    _branches = branchData?.Data;
                }
                else
                {
                    _errorMessage = "Failed to load branches for the selected merchant.";
                }
            }
            catch (Exception ex)
            {
                _errorMessage = $"Error loading branches: {ex.Message}";
            }
        }
        else
        {
            _branches = null;
        }

        // Reset the branch selection if the merchant is changed
        _branchId = "";
    }

}
