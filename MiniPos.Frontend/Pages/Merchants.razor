@page "/merchants"
@using MiniPos.Frontend.Models
@using MiniPos.Frontend.Services

<PageTitle>Merchant Partners - MiniPOS</PageTitle>

<PageHeader Title="Merchant Partners" 
            Subtitle="Onboard and manage merchant business accounts"
            SearchPlaceholder="Search merchants..."
            @bind-SearchTerm="_searchTerm"
            ShowViewToggle="false"
            OnSearch="LoadData">
    <Actions>
        <button class="btn btn-primary px-6 h-12 shadow-xl shadow-primary/20 flex items-center gap-3 transition-all" @onclick="GoToAddMerchant">
            <i data-lucide="plus" class="w-5 h-5 font-black"></i>
            <span class="font-black uppercase tracking-tight text-sm">Add Merchant</span>
        </button>
    </Actions>
</PageHeader>

<div class="bg-white/40 backdrop-blur-xl border border-white/60 rounded-[2rem] shadow-2xl shadow-primary/5 overflow-hidden flex flex-col min-h-0">
    @if (_isLoading && (_pagedMerchants == null || !_pagedMerchants.Data.Any()))
    {
        <div class="flex-1 flex flex-col items-center justify-center p-24">
            <div class="animate-spin rounded-full h-12 w-12 border-4 border-t-primary border-primary/20"></div>
            <p class="mt-6 text-sm font-bold text-muted-foreground tracking-widest uppercase">Fetching partners...</p>
        </div>
    }
    else if (_pagedMerchants == null || !_pagedMerchants.Data.Any())
    {
        <div class="flex-1 flex flex-col items-center justify-center p-24 text-center">
            <div class="w-20 h-20 bg-muted/20 rounded-3xl flex items-center justify-center mb-6">
                <i data-lucide="building-2" class="w-10 h-10 text-muted-foreground/30"></i>
            </div>
            <h3 class="text-xl font-black text-foreground">No merchants enrolled</h3>
            <p class="text-muted-foreground max-w-xs mx-auto mt-2">Enlist your first merchant partner to get started.</p>
        </div>
    }
    else
    {
        <div class="p-8 stylish-scrollbar overflow-y-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var merchant in _pagedMerchants.Data)
                {
                    <div class="group relative bg-white/60 hover:bg-white border border-border/40 hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/5 rounded-[2.5rem] p-8 transition-all duration-500 cursor-pointer"
                         @onclick='() => Navigation.NavigateTo($"/merchants/edit/{merchant.Id}")'>
                        
                        <div class="flex items-start justify-between mb-8">
                            <div class="w-16 h-16 rounded-3xl bg-indigo-50 flex items-center justify-center text-indigo-600 group-hover:scale-110 group-hover:rotate-6 transition-transform duration-500 border border-indigo-100 shadow-sm">
                                <i data-lucide="briefcase" class="w-8 h-8"></i>
                            </div>
                            <div class="flex flex-col items-end gap-2">
                                <span class="px-3 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-black uppercase tracking-widest rounded-full border border-emerald-100 shadow-sm">Verified</span>
                                <span class="text-[9px] font-black text-muted-foreground/40 uppercase tracking-widest leading-none">Partner ID: @merchant.Id.ToString().Substring(0, 8)</span>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <h3 class="text-2xl font-black text-foreground group-hover:text-primary transition-colors font-outfit">@merchant.Name</h3>
                            <p class="text-sm text-muted-foreground font-medium flex items-center gap-2">
                                <i data-lucide="mail" class="w-4 h-4 opacity-40"></i>
                                info@@(merchant.Name.Replace(" ", "").ToLower()).com
                            </p>
                        </div>

                        <div class="mt-8 pt-8 border-t border-border/10 flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black text-muted-foreground uppercase tracking-widest leading-none mb-1">Status</span>
                                <div class="flex items-center gap-1.5">
                                    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                                    <span class="text-xs font-bold text-foreground/80">Active Ecosystem</span>
                                </div>
                            </div>
                            <button class="w-10 h-10 rounded-2xl bg-slate-50 flex items-center justify-center text-muted-foreground group-hover:bg-primary group-hover:text-white transition-all shadow-sm">
                                <i data-lucide="chevron-right" class="w-5 h-5"></i>
                            </button>
                        </div>

                        <div class="absolute inset-0 border-2 border-primary/40 rounded-[2.5rem] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none scale-[1.02]"></div>
                    </div>
                }
            </div>
        </div>

        <Pagination CurrentPage="_currentPage" 
                    TotalPages="@(_pagedMerchants?.TotalPages ?? 1)" 
                    TotalCount="@(_pagedMerchants?.TotalCount ?? 0)"
                    PageSize="10"
                    PageChanged="HandlePageChanged" />
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private PagedResult<Merchant>? _pagedMerchants;
    private string _searchTerm = "";
    private int _currentPage = 1;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var url = $"api/merchants?page={_currentPage}&pageSize=10";
            if (!string.IsNullOrEmpty(_searchTerm)) url += $"&searchTerm={Uri.EscapeDataString(_searchTerm)}";

            _pagedMerchants = await Http.GetFromJsonAsync<PagedResult<Merchant>>(url);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading merchants: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private void GoToAddMerchant() => Navigation.NavigateTo("/merchants/add");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
