@page "/merchants"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Merchants - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <!-- Header -->
    <div class="mt-8 mb-6 flex justify-between items-end">
        <div>
            <h2 class="text-2xl font-bold tracking-tight">Active Merchants</h2>
            <p class="text-sm text-muted-foreground mt-1">Manage and monitor all point-of-sale operators.</p>
        </div>

        <div class="flex items-center gap-3">
            <div class="relative max-w-sm">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground"></i>
                <input type="text" placeholder="Search merchants..." class="bg-background border border-input rounded-md pl-9 pr-4 py-2 text-sm max-w-[200px] focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-colors" />
            </div>
            <button class="btn btn-outline border-border h-9">
                <i data-lucide="filter" class="w-4 h-4 mr-2"></i> Filter
            </button>
            <button class="btn btn-primary rounded-lg shadow-primary">
                <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                New Merchant
            </button>
        </div>
    </div>

    @if (_merchants == null)
    {
        <div class="flex items-center justify-center p-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <!-- Overview Statistics -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            @foreach (var merchant in _merchants)
            {
                var colorClass = merchant.IsActive ? "primary" : "border";
                var textGlowOrMuted = merchant.IsActive ? "text-primary" : "text-muted-foreground";
                var bgGradient = merchant.IsActive ? "from-primary/20 to-primary/5" : "bg-muted";
                var glowClass = merchant.IsActive ? "bg-primary/10 group-hover:bg-primary/20" : "";
                var opacityClass = merchant.IsActive ? "" : "bg-muted/30 opacity-80 backdrop-blur-none grayscale";
                var idOrEmail = merchant.ContactEmail != null ? merchant.ContactEmail : $"ID: {merchant.Id.ToString().Substring(0,8).ToUpper()}";
                var initials = GetInitials(merchant.Name);

                <div class="pos-card relative overflow-hidden group hover:border-@colorClass/30 transition-all p-0 flex flex-col @opacityClass cursor-pointer" @onclick="() => GoToMerchantDetail(merchant.Id)">
                    @if (merchant.IsActive)
                    {
                        <div class="absolute -right-12 -top-12 w-32 h-32 @glowClass rounded-full blur-2xl transition-colors"></div>
                    }
                    
                    <div class="p-6 pb-4">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 rounded-xl bg-gradient-to-br @bgGradient @textGlowOrMuted border @(!merchant.IsActive ? "border-border" : "border-transparent") flex items-center justify-center font-bold font-outfit text-lg shadow-sm">
                                    @initials
                                </div>
                                <div>
                                    <div class="flex items-center gap-2">
                                        <h3 class="font-bold text-lg text-foreground -mb-1">@merchant.Name</h3>
                                        @if (!merchant.IsActive)
                                        {
                                            <span class="badge bg-muted-foreground text-white text-[9px] px-1.5 py-0">Inactive</span>
                                        }
                                    </div>
                                    <span class="text-xs text-muted-foreground">@idOrEmail</span>
                                </div>
                            </div>
                            <button class="btn btn-ghost p-1 text-muted-foreground hover:text-foreground">
                                <i data-lucide="more-vertical" class="w-4 h-4"></i>
                            </button>
                        </div>

                        <div class="mt-4 flex items-center gap-2 text-xs text-muted-foreground">
                            <i data-lucide="map-pin" class="w-3.5 h-3.5"></i> @merchant.Branches.Count Branches
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<Merchant>? _merchants;

    protected override async Task OnInitializedAsync()
    {
        var pagedResult = await Http.GetFromJsonAsync<PagedResult<Merchant>>("sample-data/merchants.json");
        _merchants = pagedResult?.Data;
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "M";
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return $"{parts[0][0]}{parts[parts.Length - 1][0]}".ToUpper();
    }

    private void GoToMerchantDetail(Guid id)
    {
        Navigation.NavigateTo($"/merchants/{id}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
