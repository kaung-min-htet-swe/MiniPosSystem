@page "/merchants"

<PageTitle>Merchants - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Merchants & Franchises</h1>
            <p class="text-muted-foreground mt-1 text-sm">Monitor performance and manage all your connected stores.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex relative mr-2">
                <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"></i>
                <input type="text" placeholder="Search merchants..." class="pl-9 pr-4 py-4 bg-white/60 backdrop-blur-sm border border-border/60 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 w-48 transition-all hover:bg-white" />
            </div>
            <button class="btn btn-outline bg-white hover:bg-muted shadow-sm rounded-lg p-2">
                <i data-lucide="filter" class="w-4 h-4"></i>
            </button>
            <button class="btn btn-primary rounded-lg shadow-primary">
                <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                New Merchant
            </button>
        </div>
    </div>

    <!-- Stunning Grid Layout for Merchants -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        
        <!-- Merchant Card 1 -->
        <div class="pos-card relative overflow-hidden group hover:border-primary/30 transition-all p-0 flex flex-col">
            <div class="absolute -right-12 -top-12 w-32 h-32 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-colors"></div>
            
            <div class="p-6 pb-4">
                <div class="flex justify-between items-start mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/20 to-primary/5 text-primary flex items-center justify-center font-bold font-outfit text-lg shadow-sm">
                            SM
                        </div>
                        <div>
                            <h3 class="font-bold text-lg text-foreground -mb-1">Super Mart LLC</h3>
                            <span class="text-xs text-muted-foreground">ID: 8A9B-2F34</span>
                        </div>
                    </div>
                    <button class="btn btn-ghost p-1 text-muted-foreground hover:text-foreground">
                        <i data-lucide="more-vertical" class="w-4 h-4"></i>
                    </button>
                </div>

                <div class="grid grid-cols-2 gap-4 mt-6">
                    <div>
                        <div class="text-xs text-muted-foreground uppercase font-semibold tracking-wider mb-1">Today's Sales</div>
                        <div class="font-bold text-xl font-outfit">$4,290</div>
                    </div>
                    <div>
                        <div class="text-xs text-muted-foreground uppercase font-semibold tracking-wider mb-1">Active Branches</div>
                        <div class="font-bold text-lg">12 / 12</div>
                    </div>
                </div>
            </div>

            <!-- Mini Trend Chart (SVG) -->
            <div class="w-full h-16 relative bg-muted/10 mt-auto border-t border-border/30">
                <div class="absolute inset-0 flex items-center justify-between px-4 pb-2 z-10 text-[10px] font-bold text-success">
                    <span class="flex items-center"><i data-lucide="trending-up" class="w-3 h-3 mr-1"></i> +8.4%</span>
                </div>
                <!-- Artificial SVG Chart -->
                <svg viewBox="0 0 400 64" class="w-full h-full pt-2" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="chartGlowSM" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="hsl(var(--success))" stop-opacity="0.2" />
                            <stop offset="100%" stop-color="hsl(var(--success))" stop-opacity="0.0" />
                        </linearGradient>
                    </defs>
                    <path d="M0,64 L0,40 C50,45 100,20 150,30 C200,40 250,10 300,25 C350,40 380,15 400,5 L400,64 Z" fill="url(#chartGlowSM)" />
                    <path d="M0,40 C50,45 100,20 150,30 C200,40 250,10 300,25 C350,40 380,15 400,5" fill="none" stroke="hsl(var(--success))" stroke-width="2" />
                </svg>
            </div>
        </div>

        <!-- Merchant Card 2 -->
        <div class="pos-card relative overflow-hidden group hover:border-warning/30 transition-all p-0 flex flex-col">
            <div class="absolute -right-12 -top-12 w-32 h-32 bg-warning/10 rounded-full blur-2xl group-hover:bg-warning/20 transition-colors"></div>
            
            <div class="p-6 pb-4">
                <div class="flex justify-between items-start mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-warning/20 to-warning/5 text-warning flex items-center justify-center font-bold font-outfit text-lg shadow-sm">
                            CF
                        </div>
                        <div>
                            <h3 class="font-bold text-lg text-foreground -mb-1">Coffee Fusion</h3>
                            <span class="text-xs text-muted-foreground">hello@coffeefusion.io</span>
                        </div>
                    </div>
                    <button class="btn btn-ghost p-1 text-muted-foreground hover:text-foreground">
                        <i data-lucide="more-vertical" class="w-4 h-4"></i>
                    </button>
                </div>

                <div class="grid grid-cols-2 gap-4 mt-6">
                    <div>
                        <div class="text-xs text-muted-foreground uppercase font-semibold tracking-wider mb-1">Today's Sales</div>
                        <div class="font-bold text-xl font-outfit">$1,850</div>
                    </div>
                    <div>
                        <div class="text-xs text-muted-foreground uppercase font-semibold tracking-wider mb-1">Active Branches</div>
                        <div class="font-bold text-lg">3 / 4 <span class="text-xs text-destructive font-normal ml-1">(1 Offline)</span></div>
                    </div>
                </div>
            </div>

            <!-- Mini Trend Chart (SVG) -->
            <div class="w-full h-16 relative bg-muted/10 mt-auto border-t border-border/30">
                <div class="absolute inset-0 flex items-center justify-between px-4 pb-2 z-10 text-[10px] font-bold text-primary">
                    <span class="flex items-center"><i data-lucide="trending-up" class="w-3 h-3 mr-1"></i> +2.1%</span>
                </div>
                <!-- Artificial SVG Chart -->
                <svg viewBox="0 0 400 64" class="w-full h-full pt-2" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="chartGlowCF" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="hsl(var(--primary))" stop-opacity="0.2" />
                            <stop offset="100%" stop-color="hsl(var(--primary))" stop-opacity="0.0" />
                        </linearGradient>
                    </defs>
                    <path d="M0,64 L0,20 C50,15 100,40 150,30 C200,20 250,50 300,35 C350,20 380,35 400,25 L400,64 Z" fill="url(#chartGlowCF)" />
                    <path d="M0,20 C50,15 100,40 150,30 C200,20 250,50 300,35 C350,20 380,35 400,25" fill="none" stroke="hsl(var(--primary))" stroke-width="2" />
                </svg>
            </div>
        </div>

        <!-- Merchant Card 3 (Inactive) -->
        <div class="pos-card relative overflow-hidden group hover:border-border transition-all p-0 flex flex-col bg-muted/30 opacity-80 backdrop-blur-none">
            
            <div class="p-6 pb-4">
                <div class="flex justify-between items-start mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-xl bg-muted border border-border text-muted-foreground flex items-center justify-center font-bold font-outfit text-lg shadow-sm grayscale">
                            BR
                        </div>
                        <div>
                            <div class="flex items-center gap-2">
                                <h3 class="font-bold text-lg text-foreground -mb-1">Bakers & Roasters</h3>
                                <span class="badge bg-muted-foreground text-white text-[9px] px-1.5 py-0">Inactive</span>
                            </div>
                            <span class="text-xs text-muted-foreground">admin@bakers.com</span>
                        </div>
                    </div>
                    <button class="btn btn-ghost p-1 text-muted-foreground hover:text-foreground">
                        <i data-lucide="more-vertical" class="w-4 h-4"></i>
                    </button>
                </div>

                <div class="grid grid-cols-2 gap-4 mt-6">
                    <div>
                        <div class="text-xs text-muted-foreground uppercase font-semibold tracking-wider mb-1">Today's Sales</div>
                        <div class="font-bold text-xl font-outfit text-muted-foreground">$0</div>
                    </div>
                    <div>
                        <div class="text-xs text-muted-foreground uppercase font-semibold tracking-wider mb-1">Active Branches</div>
                        <div class="font-bold text-lg text-muted-foreground">0 / 2 <span class="text-xs font-normal ml-1">Closed</span></div>
                    </div>
                </div>
            </div>

            <!-- Empty Chart Area -->
            <div class="w-full h-16 relative bg-muted/50 mt-auto border-t border-border flex items-center justify-center">
                <span class="text-xs font-semibold text-muted-foreground"><i data-lucide="minus-circle" class="w-3 h-3 inline mr-1"></i> No Activity</span>
            </div>
        </div>

    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
