@page "/inventory"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Inventory - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-6 pb-4 border-b border-border/30">
        <div class="space-y-1">
            <h1 class="text-4xl font-black tracking-tight text-foreground font-outfit">Inventory</h1>
            <p class="text-muted-foreground font-medium text-sm flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary/40"></span>
                Manage stock levels and branch-specific pricing
            </p>
        </div>
        <div class="flex items-center gap-4 w-full sm:w-auto">
            <!-- View Mode Toggle -->
            <div class="flex bg-muted/20 p-1 rounded-2xl border border-border/40 mr-2 shadow-sm">
                <button
                    class="p-2 rounded-xl transition-all @(_viewMode == "grid" ? "bg-white shadow-sm text-primary" : "text-muted-foreground hover:text-foreground")"
                    @onclick='() => _viewMode = "grid"'>
                    <i data-lucide="layout-grid" class="w-4 h-4"></i>
                </button>
                <button
                    class="p-2 rounded-xl transition-all @(_viewMode == "list" ? "bg-white shadow-sm text-primary" : "text-muted-foreground hover:text-foreground")"
                    @onclick='() => _viewMode = "list"'>
                    <i data-lucide="list" class="w-4 h-4"></i>
                </button>
            </div>

            <div class="relative flex-1 sm:w-56 group">
                <i data-lucide="search"
                   class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors"></i>
                <input type="text" @bind="_searchTerm" @bind:event="oninput"
                       placeholder="SKU or Name..."
                       class="w-full pl-10 pr-4 py-2.5 bg-white border border-border/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm"/>
            </div>

            <div class="flex items-center gap-3">
                <!-- Branch Selector -->
                <div class="relative group">
                    <i data-lucide="store"
                       class="w-3.5 h-3.5 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors pointer-events-none"></i>
                    <select @bind="_selectedBranchId" @bind:after="LoadInventory"
                            class="bg-white border border-border/60 rounded-2xl text-xs font-bold py-2.5 pl-10 pr-10 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all shadow-sm cursor-pointer appearance-none">
                        @if (_branches == null || !_branches.Any())
                        {
                            <option value="">Loading Branches...</option>
                        }
                        else
                        {
                            @foreach (var branch in _branches)
                            {
                                <option value="@branch.Id">@branch.Name</option>
                            }
                        }
                    </select>
                    <i data-lucide="chevron-down"
                       class="w-3.5 h-3.5 absolute right-3.5 top-1/2 -translate-y-1/2 text-muted-foreground transition-transform group-focus-within:rotate-180 pointer-events-none"></i>
                </div>

                <!-- Category Selector -->
                <div class="relative group">
                    <i data-lucide="filter"
                       class="w-3.5 h-3.5 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors pointer-events-none"></i>
                    <select @bind="_selectedCategoryId" @bind:after="LoadInventory"
                            class="bg-white border border-border/60 rounded-2xl text-xs font-bold py-2.5 pl-10 pr-10 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 transition-all shadow-sm cursor-pointer appearance-none">
                        <option value="">All Categories</option>
                        @foreach (var cat in _categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                    <i data-lucide="chevron-down"
                       class="w-3.5 h-3.5 absolute right-3.5 top-1/2 -translate-y-1/2 text-muted-foreground transition-transform group-focus-within:rotate-180 pointer-events-none"></i>
                </div>
            </div>

            <button
                class="btn btn-primary rounded-2xl px-6 py-3 shadow-lg shadow-primary/20 flex items-center gap-2 font-bold text-sm hover:scale-105 active:scale-95 transition-all"
                @onclick="GoToAddInventory">
                <i data-lucide="package-plus" class="w-4 h-4"></i>
                <span>Add Stock</span>
            </button>
        </div>
    </div>

    @if (_inventories == null)
    {
        <div class="flex items-center justify-center p-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        var filteredItems = _inventories
            .Where(i => string.IsNullOrEmpty(_searchTerm) || 
                         i.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) || 
                         i.Sku.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList();

        @if (!filteredItems.Any())
        {
            <div class="flex flex-col items-center justify-center py-24 text-center">
                <div class="w-20 h-20 rounded-full bg-muted/20 flex items-center justify-center mb-4">
                    <i data-lucide="package-search" class="w-10 h-10 text-muted-foreground/40"></i>
                </div>
                <h3 class="text-xl font-bold text-foreground">No items found</h3>
                <p class="text-muted-foreground max-w-xs mx-auto">Try adjusting your search or filters to find what you're looking for.</p>
            </div>
        }
        else
        {
            @if (_viewMode == "grid")
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-4">
                    @foreach (var item in filteredItems)
                    {
                        var ui = GetInventoryUI(item);
                        <div class="pos-card p-0.5 overflow-hidden group hover:-translate-y-1.5 transition-all duration-500 border-border/40 hover:border-primary/50 hover:shadow-2xl hover:shadow-primary/10 cursor-pointer relative rounded-2xl"
                             @onclick="() => GoToInventoryDetail(item.Id)">
                            
                            <!-- Premium Mesh Pattern -->
                            <div class="absolute inset-0 z-0 opacity-[0.03] grayscale group-hover:grayscale-0 group-hover:opacity-[0.08] transition-all duration-1000 pointer-events-none @ui.BgGlow"
                                 style="background-image: radial-gradient(currentColor 0.5px, transparent 0.5px); background-size: 10px 10px;"></div>

                            <!-- Header -->
                            <div class="h-28 w-full bg-gradient-to-br @ui.Gradient relative overflow-hidden flex items-center justify-center border rounded-lg">
                                <div class="absolute inset-0 bg-white/10 backdrop-blur-[2px]"></div>

                                <!-- Icons & Badges -->
                                <div class="w-12 h-12 rounded-xl bg-white/30 backdrop-blur-md flex items-center justify-center text-foreground/80 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 z-10 shadow-[inset_0_0_12px_rgba(255,255,255,0.5)] border border-white/40">
                                    <i data-lucide="@ui.Icon" class="w-6 h-6 @ui.TextColor drop-shadow-sm"></i>
                                </div>

                                <div class="absolute top-3 left-3 flex flex-col gap-1.5">
                                    <span class="bg-white/90 backdrop-blur-sm text-[9px] font-black uppercase tracking-widest shadow-sm rounded-full px-2 py-0.5 border border-border/20 @ui.TextColor">
                                        @item.CategoryName
                                    </span>
                                    @if (item.StockQuantity < 10)
                                    {
                                        <span class="bg-rose-500/90 text-white text-[9px] font-black uppercase tracking-widest shadow-sm rounded-full px-2 py-0.5 border border-rose-400/50 animate-pulse">
                                            Low Stock
                                        </span>
                                    }
                                </div>

                                <div class="absolute bottom-3 right-3">
                                    <div class="bg-black/10 backdrop-blur-md rounded-lg px-2 py-1 border border-white/20">
                                        <div class="text-[9px] font-bold text-white/70 uppercase tracking-widest text-right leading-none">In Stock</div>
                                        <div class="text-[16px] font-black text-white font-outfit leading-none mt-0.5">@item.StockQuantity</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="p-4 relative z-10">
                                <h3 class="font-bold text-[16px] tracking-tight text-foreground line-clamp-1 leading-snug group-hover:text-primary transition-colors font-outfit">@item.Name</h3>
                                <div class="flex justify-between items-center mt-1">
                                    <span class="text-[11px] font-bold text-muted-foreground/60 uppercase tracking-widest bg-muted/30 px-2 py-0.5 rounded-md">@item.Sku</span>
                                    <div class="text-right">
                                        <span class="text-[10px] mr-1 opacity-50 font-bold">$</span>
                                        <span class="text-[18px] font-black font-outfit text-primary tracking-tight">@item.Price.ToString("F2")</span>
                                    </div>
                                </div>

                                <!-- Mini Indicator -->
                                <div class="mt-4 pt-3 border-t border-border/40 flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-2 h-2 rounded-full @(item.StockQuantity > 0 ? "bg-emerald-500" : "bg-rose-500") shadow-[0_0_8px_currentColor]"></div>
                                        <span class="text-[10px] font-black text-muted-foreground uppercase tracking-widest">@(item.StockQuantity > 0 ? "Available" : "Out of Stock")</span>
                                    </div>
                                    <i data-lucide="chevron-right" class="w-4 h-4 text-muted-foreground/40 group-hover:text-primary group-hover:translate-x-1 transition-all"></i>
                                </div>
                            </div>

                            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-primary/40 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="pos-card p-0 bg-white/60 shadow-xl border-border/40 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead class="bg-muted/30 border-b border-border/30">
                            <tr>
                                <th class="pl-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground w-12"></th>
                                <th class="px-4 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground">Product Detail</th>
                                <th class="px-4 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground">Category</th>
                                <th class="px-4 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-center">Stock</th>
                                <th class="px-4 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-right">Unit Price</th>
                                <th class="pr-6 py-4 text-[10px] font-black uppercase tracking-widest text-muted-foreground text-right">Actions</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-border/20">
                            @foreach (var item in filteredItems)
                            {
                                var ui = GetInventoryUI(item);
                                <tr class="group hover:bg-primary/[0.03] backdrop-blur-sm transition-all duration-300 cursor-pointer border-l-2 border-transparent hover:border-primary hover:translate-x-1"
                                    @onclick="() => GoToInventoryDetail(item.Id)">
                                    <td class="pl-6 py-3">
                                        <div class="w-10 h-10 rounded-xl @ui.BgIcon backdrop-blur-md flex items-center justify-center border border-border/60 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-sm shadow-primary/5">
                                            <i data-lucide="@ui.Icon" class="w-5 h-5 @ui.TextColor"></i>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="font-bold text-[15px] text-foreground font-outfit group-hover:text-primary transition-colors">@item.Name</div>
                                        <div class="text-[10px] font-black text-muted-foreground/60 uppercase tracking-widest mt-0.5">@item.Sku</div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="badge @ui.BgIcon @ui.TextColor text-[9px] font-black uppercase tracking-widest border-transparent py-1 px-2.5 rounded-lg">
                                            @item.CategoryName
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <div class="flex flex-col items-center">
                                            <div class="text-[16px] font-black font-outfit @(item.StockQuantity < 10 ? "text-rose-600" : "text-foreground")">
                                                @item.StockQuantity
                                            </div>
                                            @if (item.StockQuantity < 10)
                                            {
                                                <span class="text-[9px] font-black text-rose-500/80 uppercase tracking-widest leading-none mt-1">Low Stock</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-right">
                                        <div class="text-base font-black font-outfit text-primary">
                                            <span class="text-[10px] mr-0.5 opacity-50 font-bold">$</span>@item.Price.ToString("F2")
                                        </div>
                                    </td>
                                    <td class="pr-6 py-3 text-right">
                                        <button class="w-8 h-8 rounded-xl hover:bg-primary/10 text-muted-foreground hover:text-primary flex items-center justify-center transition-all ml-auto hover:rotate-90">
                                            <i data-lucide="chevron-right" class="w-4 h-4"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    public class InventoryUI
    {
        public string Icon { get; set; } = "";
        public string Color { get; set; } = "";
        public string Gradient { get; set; } = "";
        public string BgGlow { get; set; } = "";
        public string BgIcon { get; set; } = "";
        public string TextColor { get; set; } = "";
    }

    private List<BranchInventoryListResponseDto>? _inventories;
    private List<Category> _categories = new();
    private List<BranchListResponseDto> _branches = new();
    
    private string _searchTerm = "";
    private string _viewMode = "grid";
    private Guid? _selectedCategoryId;
    private Guid? _selectedBranchId;
    
    // Default Merchant ID (for filtering branches/categories if needed)
    private string _defaultMerchantId = "3798433e-f36b-1410-8548-003fb1df8966";

    protected override async Task OnInitializedAsync()
    {
        await LoadBranches();
        await LoadCategories();
        
        // If we have branches, select the first one by default if not already set
        if (_branches.Any() && _selectedBranchId == null)
        {
            _selectedBranchId = _branches.First().Id;
        }
        
        if (_selectedBranchId != null)
        {
            await LoadInventory();
        }
    }

    private async Task LoadBranches()
    {
        try
        {
            var response = await Http.GetAsync("api/branches");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<BranchListResponseDto>>();
                if (result != null)
                {
                    _branches = result.Data;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading branches: {ex.Message}");
        }
    }

    private async Task LoadCategories()
    {
        try
        {
            var response = await Http.GetAsync("api/categories");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<Category>>();
                if (result != null)
                {
                    _categories = result.Data;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading categories: {ex.Message}");
        }
    }

    private async Task LoadInventory()
    {
        if (_selectedBranchId == null) return;

        _inventories = null; // Show loading state
        StateHasChanged();

        try
        {
            var url = $"api/inventories?branchId={_selectedBranchId}&page=1&pageSize=100";
            if (_selectedCategoryId.HasValue)
            {
                url += $"&categoryId={_selectedCategoryId}";
            }

            var response = await Http.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<BranchInventoryListResponseDto>>();
                if (result != null)
                {
                    _inventories = result.Data;
                }
            }
            else
            {
                _inventories = new List<BranchInventoryListResponseDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading inventory: {ex.Message}");
            _inventories = new List<BranchInventoryListResponseDto>();
        }
        finally
        {
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private InventoryUI GetInventoryUI(BranchInventoryListResponseDto item)
    {
        var categoryName = item.CategoryName ?? "General";
        var hash = Math.Abs(categoryName.GetHashCode());

        var icons = new[] { "package", "box", "archive", "layers", "tag", "coffee", "utensils", "cup-soda", "ice-cream", "shopping-bag", "leaf", "croissant", "star", "bookmark" };
        var colors = new[] { "primary", "emerald", "orange", "indigo", "rose", "pink", "sky", "violet", "amber", "cyan", "fuchsia", "lime" };

        var icon = icons[hash % icons.Length];
        var color = colors[(hash + 3) % colors.Length];

        // Specific overrides for inventory-like items
        if (item.StockQuantity < 5) icon = "alert-triangle";
        else if (item.StockQuantity == 0) icon = "x-circle";

        string bgGlow = color == "primary" ? "bg-primary/20" : $"bg-{color}-500/20";
        string bgIcon = color == "primary" ? "bg-primary/10" : $"bg-{color}-500/10";
        string textColor = color == "primary" ? "text-primary" : $"text-{color}-600";
        string gradient = color == "primary" ? "from-primary/20 to-primary/5" : $"from-{color}-500/20 to-{color}-500/5";

        return new InventoryUI
        {
            Icon = icon,
            Color = color,
            Gradient = gradient,
            BgGlow = bgGlow,
            BgIcon = bgIcon,
            TextColor = textColor
        };
    }

    private void GoToInventoryDetail(Guid id)
    {
        // Navigation.NavigateTo($"/inventory/{id}");
    }

    private void GoToAddInventory()
    {
        Navigation.NavigateTo("/inventory/add");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
