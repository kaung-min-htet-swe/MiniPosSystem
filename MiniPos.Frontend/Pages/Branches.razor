@page "/branches"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Branches - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Store Branches</h1>
            <p class="text-muted-foreground mt-1 text-sm">Manage physical locations, addresses, and connect registers.</p>
        </div>
        <button class="btn btn-primary rounded-lg shadow-primary">
            <i data-lucide="map-pin" class="w-4 h-4 mr-2"></i> Add Branch
        </button>
    </div>

    <!-- Striking Branch Cards Grid -->
    @if (_pagedBranches == null)
    {
        <div class="flex items-center justify-center h-48">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var branch in _pagedBranches.Data)
            {
                <div class="pos-card relative overflow-hidden group hover:-translate-y-1 transition-transform border border-border hover:border-primary/30 min-h-[220px]">
                    <div class="absolute inset-0 z-0 opacity-10 grayscale group-hover:grayscale-0 group-hover:opacity-30 transition-all duration-700 pointer-events-none" style="background-image: radial-gradient(hsl(var(--primary)) 1px, transparent 1px); background-size: 20px 20px;"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 rounded-full bg-white shadow-md border border-border flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                                <i data-lucide="store" class="w-6 h-6"></i>
                            </div>
                            <span class="flex items-center gap-1.5 badge badge-success text-[10px] px-2 shadow-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span> Online
                            </span>
                        </div>
                        <h3 class="font-bold text-xl text-foreground mb-1">@branch.Name</h3>
                        <p class="text-sm text-muted-foreground flex items-center gap-1 mb-auto">
                            <i data-lucide="map-pin" class="w-3.5 h-3.5"></i> @(branch.Address ?? "Address not provided")
                        </p>
                        <div class="mt-6 pt-4 border-t border-border/50 grid grid-cols-2 gap-4">
                            <div>
                                <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-1">Registers</div>
                                <div class="font-bold text-foreground font-outfit">@(new Random().Next(2, 6)) connected</div>
                            </div>
                            <div class="text-right">
                                <button class="text-xs font-bold text-primary hover:underline uppercase tracking-wide">Manage Settings</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    private PagedResult<Branch>? _pagedBranches;

    protected override async Task OnInitializedAsync()
    {
        _pagedBranches = await Http.GetFromJsonAsync<PagedResult<Branch>>("sample-data/branches.json");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
