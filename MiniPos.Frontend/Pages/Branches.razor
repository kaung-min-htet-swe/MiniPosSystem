@page "/branches"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Branches - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div class="flex items-center gap-4 flex-1">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-foreground">Store Branches</h1>
                <p class="text-muted-foreground mt-1 text-sm">Manage physical locations, addresses, and connect registers.</p>
            </div>

            <!-- Merchant Selector -->
            <div class="relative group">
                <i data-lucide="store"
                   class="w-3.5 h-3.5 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors pointer-events-none"></i>
                <select @bind="_selectedMerchantId" @bind:after="LoadData"
                        class="bg-white border border-border/60 rounded-2xl text-xs font-bold py-2.5 pl-10 pr-10 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm cursor-pointer appearance-none">
                    <option value="">All Merchants</option>
                    @foreach (var mer in _merchants)
                    {
                        <option value="@mer.Id">@mer.Name</option>
                    }
                </select>
                <i data-lucide="chevron-down"
                   class="w-3.5 h-3.5 absolute right-3.5 top-1/2 -translate-y-1/2 text-muted-foreground transition-transform group-focus-within:rotate-180 pointer-events-none"></i>
            </div>
        </div>
        <button class="btn btn-primary rounded-[1.2rem] px-5 py-3 shadow-lg shadow-primary/20 flex items-center gap-2 font-bold text-sm hover:scale-105 active:scale-95 transition-all" @onclick="GoToAddBranch">
            <i data-lucide="plus" class="w-4 h-4"></i>
            <span>Add Branch</span>
        </button>
    </div>
    
    <!-- Floating Alert Box -->
    @if (!string.IsNullOrEmpty(_alertMessage))
    {
        <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] animate-slide-down">
            <div class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-2xl border backdrop-blur-md
                @(_alertType == "success" ? "bg-emerald-50/90 border-emerald-200 text-emerald-800" : "bg-rose-50/90 border-rose-200 text-rose-800")">
                <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center
                    @(_alertType == "success" ? "bg-emerald-100" : "bg-rose-100")">
                    <i data-lucide="@(_alertType == "success" ? "check-circle" : "alert-circle")" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="text-xs font-black uppercase tracking-widest opacity-60">@(_alertType == "success" ? "Success" : "Error")</p>
                    <p class="text-sm font-bold">@_alertMessage</p>
                </div>
            </div>
        </div>
    }

    <!-- Striking Branch Cards Grid -->
    @if (_pagedBranches == null)
    {
        <div class="flex items-center justify-center h-48">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var branch in _pagedBranches.Data)
            {
                <div class="pos-card relative overflow-hidden group hover:-translate-y-1 transition-transform border border-border hover:border-primary/30 min-h-[220px] cursor-pointer" @onclick="() => GoToBranchDetail(branch.Id)">
                    <div class="absolute inset-0 z-0 opacity-10 grayscale group-hover:grayscale-0 group-hover:opacity-30 transition-all duration-700 pointer-events-none" style="background-image: radial-gradient(hsl(var(--primary)) 1px, transparent 1px); background-size: 20px 20px;"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 rounded-full bg-white shadow-md border border-border flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                                <i data-lucide="store" class="w-6 h-6"></i>
                            </div>
                            <span class="flex items-center gap-1.5 badge badge-success text-[10px] px-2 shadow-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span> Active
                            </span>
                        </div>
                        <h3 class="font-bold text-xl text-foreground mb-1">@branch.Name</h3>
                        <p class="text-muted-foreground text-[10px] font-bold uppercase tracking-wider mb-2">@branch.Merchant?.Name</p>
                        <p class="text-sm text-muted-foreground flex items-center gap-1 mb-auto">
                            <i data-lucide="map-pin" class="w-3.5 h-3.5"></i> @(branch.Address ?? "Address not provided")
                        </p>
                        <div class="mt-6 pt-4 border-t border-border/50 flex justify-between items-center">
                            <div class="text-[10px] font-bold uppercase tracking-widest text-primary">View Details</div>
                            <i data-lucide="arrow-right" class="w-4 h-4 text-primary group-hover:translate-x-1 transition-transform"></i>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private PagedResult<BranchListResponseDto>? _pagedBranches;
    private List<Merchant> _merchants = new();
    private Guid? _selectedMerchantId;
    
    // Alert state
    private string _alertMessage = "";
    private string _alertType = "success";

    protected override async Task OnInitializedAsync()
    {
        await LoadMerchants();
        await LoadData();
    }

    private async Task LoadMerchants()
    {
        try
        {
            var response = await Http.GetAsync("api/merchants?pageSize=100");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<Merchant>>();
                if (result != null)
                {
                    _merchants = result.Data;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading merchants: {ex.Message}");
        }
    }

    private async Task LoadData()
    {
        _pagedBranches = null;
        StateHasChanged();

        try
        {
            var url = "api/branches?page=1&pageSize=50";
            if (_selectedMerchantId.HasValue) url += $"&merchantId={_selectedMerchantId.Value}";

            var response = await Http.GetAsync(url);
            if (!response.IsSuccessStatusCode)
            {
                await ShowAlert("Failed to load branches.", "error");
                _pagedBranches = new PagedResult<BranchListResponseDto> { Data = new List<BranchListResponseDto>() };
                return;
            }

            _pagedBranches = await response.Content.ReadFromJsonAsync<PagedResult<BranchListResponseDto>>();
        }
        catch (Exception ex)
        {
            await ShowAlert($"Error loading branches: {ex.Message}", "error");
            _pagedBranches = new PagedResult<BranchListResponseDto> { Data = new List<BranchListResponseDto>() };
        }
        finally
        {
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private async Task ShowAlert(string message, string type = "success")
    {
        _alertMessage = message;
        _alertType = type;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("initIcons");
        _alertMessage = "";
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
    private void GoToBranchDetail(Guid branchId)
    {
        Navigation.NavigateTo($"/branches/{branchId}");
    }
    private void GoToAddBranch()
    {
        Navigation.NavigateTo("/branches/add");
    }
}
