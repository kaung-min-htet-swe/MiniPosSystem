@page "/branches"
@using MiniPos.Frontend.Models

<PageTitle>Store Branches - MiniPOS</PageTitle>

<PageHeader Title="Store Branches"
            Subtitle="Manage physical locations and service points"
            SearchPlaceholder="Search branches..."
            @bind-SearchTerm="_searchTerm"
            ShowViewToggle="false"
            OnSearch="LoadBranches">
    <Filters>
        <div class="relative group">
            <i data-lucide="store"
               class="w-3.5 h-3.5 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors pointer-events-none"></i>
            <select @bind="_selectedMerchantId" @bind:after="LoadBranches"
                    class="bg-white border border-border/60 rounded-2xl text-xs font-bold py-2.5 pl-10 pr-10 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm cursor-pointer appearance-none">
                <option value="">All Merchants</option>
                @foreach (var mer in _merchants)
                {
                    <option value="@mer.Id">@mer.Name</option>
                }
            </select>
            <i data-lucide="chevron-down"
               class="w-3.5 h-3.5 absolute right-3.5 top-1/2 -translate-y-1/2 text-muted-foreground transition-transform group-focus-within:rotate-180 pointer-events-none"></i>
        </div>
    </Filters>
    <Actions>
        <button
            class="bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-2xl font-bold text-sm shadow-lg shadow-primary/20 flex items-center gap-2 transition-all active:scale-95"
            @onclick="GoToAddBranch">
            <i data-lucide="plus" class="w-4 h-4"></i>
            <span>Add Branch</span>
        </button>
    </Actions>
</PageHeader>

<div
    class="bg-white/40 backdrop-blur-xl border border-white/60 rounded-[2rem] shadow-2xl shadow-primary/5 overflow-hidden flex flex-col min-h-0">
    @if (_selectedMerchantId == null || _pagedBranches == null || !_pagedBranches.Data.Any())
    {
        <div class="flex-1 flex flex-col items-center justify-center p-24 text-center">
            <div class="w-20 h-20 bg-muted/20 rounded-3xl flex items-center justify-center mb-6">
                <i data-lucide="map-pin-off" class="w-10 h-10 text-muted-foreground/30"></i>
            </div>
            <h3 class="text-xl font-black text-foreground">No branches found</h3>
            <p class="text-muted-foreground max-w-xs mx-auto mt-2">Try adjusting your search or merchant filters.</p>
        </div>
    }
    else if (_isLoading)
    {
        <div class="flex-1 flex flex-col items-center justify-center p-24">
            <div class="animate-spin rounded-full h-12 w-12 border-4 border-t-primary border-primary/20"></div>
            <p class="mt-6 text-sm font-bold text-muted-foreground tracking-widest uppercase">Locating branches...</p>
        </div>
    }
    else
    {
        <div class="p-8 stylish-scrollbar overflow-y-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                @foreach (var branch in _pagedBranches.Data)
                {
                    <div
                        class="group relative bg-white/60 hover:bg-white border border-border/40 hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/5 rounded-3xl p-6 transition-all duration-500 cursor-pointer"
                        @onclick='() => Navigation.NavigateTo($"/branches/edit/{branch.Id}")'>

                        <div class="flex items-start justify-between mb-6">
                            <div
                                class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500 border border-primary/5">
                                <i data-lucide="store" class="w-7 h-7"></i>
                            </div>
                            <span
                                class="px-3 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-black uppercase tracking-widest rounded-full border border-emerald-100 flex items-center gap-1.5 shadow-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                Active
                            </span>
                        </div>

                        <div class="space-y-1">
                            <h3 class="text-xl font-black text-foreground group-hover:text-primary transition-colors font-outfit">@branch.Name</h3>
                            <p class="text-sm text-muted-foreground font-medium flex items-center gap-2">
                                <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                                @branch.Address
                            </p>
                        </div>

                        <div class="mt-8 pt-6 border-t border-border/10 flex items-center justify-between">
                            <div class="flex -space-x-2">
                                <div
                                    class="w-8 h-8 rounded-full bg-slate-100 border-2 border-white flex items-center justify-center text-[10px] font-black text-slate-500">
                                    M
                                </div>
                                <div
                                    class="w-8 h-8 rounded-full bg-slate-50 border-2 border-white flex items-center justify-center text-[10px] font-black text-slate-400">
                                    +3
                                </div>
                            </div>
                            <span
                                class="text-[10px] font-black text-muted-foreground uppercase tracking-widest bg-muted/30 px-2 py-0.5 rounded-lg">Merchant: @branch.Merchant!.Name</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <Pagination CurrentPage="_currentPage"
                    TotalPages="@(_pagedBranches?.TotalPages ?? 1)"
                    TotalCount="@(_pagedBranches?.TotalCount ?? 0)"
                    PageSize="10"
                    PageChanged="HandlePageChanged"/>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private PagedResult<BranchListResponseDto>? _pagedBranches;
    private List<Merchant> _merchants = new();
    private Guid? _selectedMerchantId;
    private string _searchTerm = "";
    private int _currentPage = 1;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadMerchants();
    }

    private async Task LoadMerchants()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<PagedResult<Merchant>>("api/merchants?pageSize=100");
            _merchants = result?.Data ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading merchants: {ex.Message}");
        }
    }

    private async Task LoadBranches()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var url = $"api/branches?page={_currentPage}&pageSize=10";
            if (!string.IsNullOrEmpty(_searchTerm)) url += $"&searchTerm={Uri.EscapeDataString(_searchTerm)}";
            if (_selectedMerchantId.HasValue) url += $"&merchantId={_selectedMerchantId.Value}";

            _pagedBranches = await Http.GetFromJsonAsync<PagedResult<BranchListResponseDto>>(url);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading branches: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;
        await LoadBranches();
    }

    private void GoToAddBranch() => Navigation.NavigateTo("/branches/add");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

}
