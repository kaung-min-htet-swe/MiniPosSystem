@page "/users/add"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Add Staff - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-3xl mx-auto pb-12">
    <!-- Header with Back Navigation -->
    <div class="mb-10">
        <button class="flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors mb-6 group" @onclick="GoBack">
            <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
            Back to Staff Directory
        </button>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Add New Staff</h1>
        <p class="text-muted-foreground mt-1 text-sm">Create a new merchant account or register a cashier to a branch.</p>
    </div>

    <!-- Success / Error Banners -->
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="mb-6 p-4 rounded-2xl bg-success/10 border border-success/30 text-success flex items-center gap-3 animate-fade-in">
            <i data-lucide="check-circle-2" class="w-5 h-5 shrink-0"></i>
            <span class="text-sm font-semibold">@_successMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mb-6 p-4 rounded-2xl bg-destructive/10 border border-destructive/30 text-destructive flex items-center gap-3 animate-fade-in">
            <i data-lucide="alert-circle" class="w-5 h-5 shrink-0"></i>
            <span class="text-sm font-semibold">@_errorMessage</span>
        </div>
    }

    <!-- Main Form Card -->
    <div class="pos-card p-0 overflow-hidden bg-white/60 shadow-lg border-border/40">

        <!-- Role Selection Header -->
        <div class="p-8 pb-6 border-b border-border/40 bg-gradient-to-br from-white/80 to-transparent relative overflow-hidden">
            <div class="absolute -right-8 -top-8 w-32 h-32 bg-primary/5 rounded-full blur-2xl pointer-events-none"></div>
            <h2 class="text-xl font-bold text-foreground mb-1 relative z-10">Select Role</h2>
            <p class="text-sm text-muted-foreground relative z-10">Choose the type of staff account to create.</p>

            <div class="flex gap-4 mt-6 relative z-10">
                <button class="flex-1 p-4 rounded-2xl border-2 transition-all flex flex-col items-center gap-3 group
                    @(_selectedRole == "Merchant" ? "border-primary bg-primary/5 shadow-md shadow-primary/10" : "border-border/60 bg-white/50 hover:border-primary/30 hover:bg-white")"
                    @onclick='() => SelectRole("Merchant")'>
                    <div class="w-14 h-14 rounded-full flex items-center justify-center transition-all
                        @(_selectedRole == "Merchant" ? "bg-primary text-white shadow-lg shadow-primary/30" : "bg-muted/50 text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary")">
                        <i data-lucide="briefcase" class="w-6 h-6"></i>
                    </div>
                    <div class="text-center">
                        <div class="font-bold text-sm @(_selectedRole == "Merchant" ? "text-primary" : "text-foreground")">Merchant</div>
                        <div class="text-[10px] text-muted-foreground font-medium mt-0.5">Store owner / operator</div>
                    </div>
                </button>

                <button class="flex-1 p-4 rounded-2xl border-2 transition-all flex flex-col items-center gap-3 group
                    @(_selectedRole == "Cashier" ? "border-success bg-success/5 shadow-md shadow-success/10" : "border-border/60 bg-white/50 hover:border-success/30 hover:bg-white")"
                    @onclick='() => SelectRole("Cashier")'>
                    <div class="w-14 h-14 rounded-full flex items-center justify-center transition-all
                        @(_selectedRole == "Cashier" ? "bg-success text-white shadow-lg shadow-success/30" : "bg-muted/50 text-muted-foreground group-hover:bg-success/10 group-hover:text-success")">
                        <i data-lucide="calculator" class="w-6 h-6"></i>
                    </div>
                    <div class="text-center">
                        <div class="font-bold text-sm @(_selectedRole == "Cashier" ? "text-success" : "text-foreground")">Cashier</div>
                        <div class="text-[10px] text-muted-foreground font-medium mt-0.5">Branch terminal operator</div>
                    </div>
                </button>
            </div>
        </div>

        <!-- Form Fields -->
        <div class="p-8 space-y-8">

            <!-- Account Information Section -->
            <div>
                <h3 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-5 flex items-center gap-2">
                    <i data-lucide="user" class="w-4 h-4"></i> Account Information
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Full Name <span class="text-destructive">*</span></label>
                        <input type="text" @bind="_userName" placeholder="e.g. John Doe"
                               class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Email Address <span class="text-destructive">*</span></label>
                        <input type="email" @bind="_email" placeholder="e.g. john@example.com"
                               class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40" />
                    </div>
                    <div class="space-y-2 sm:col-span-2">
                        <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Password <span class="text-destructive">*</span></label>
                        <div class="relative">
                            <input type="@(_showPassword ? "text" : "password")" @bind="_password" placeholder="Min 8 characters"
                                   class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40 pr-12" />
                            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors p-1" @onclick="TogglePassword">
                                <i data-lucide="@(_showPassword ? "eye-off" : "eye")" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Merchant Details Section (shown for Merchant role) -->
            @if (_selectedRole == "Merchant")
            {
                <div class="animate-fade-in">
                    <div class="h-px bg-border/40 mb-8"></div>
                    <h3 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-5 flex items-center gap-2">
                        <i data-lucide="building" class="w-4 h-4"></i> Merchant Details
                    </h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Business Name <span class="text-destructive">*</span></label>
                            <input type="text" @bind="_merchantName" placeholder="e.g. Super Mart LLC"
                                   class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Business Email</label>
                            <input type="email" @bind="_merchantContactEmail" placeholder="e.g. info@supermart.com"
                                   class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium placeholder:text-muted-foreground/40" />
                        </div>
                    </div>
                </div>
            }

            <!-- Branch Assignment Section (shown for Cashier role) -->
            @if (_selectedRole == "Cashier")
            {
                <div class="animate-fade-in">
                    <div class="h-px bg-border/40 mb-8"></div>
                    <h3 class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-5 flex items-center gap-2">
                        <i data-lucide="store" class="w-4 h-4"></i> Branch Assignment
                    </h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Merchant <span class="text-destructive">*</span></label>
                            <select @bind="_merchantId"
                                    class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium appearance-none cursor-pointer">
                                <option value="">Select a merchant...</option>
                                @if (_merchants != null)
                                {
                                    @foreach (var merchant in _merchants)
                                    {
                                        <option value="@merchant.Id">@merchant.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Branch <span class="text-destructive">*</span></label>
                            <select @bind="_branchId"
                                    class="w-full px-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all font-medium appearance-none cursor-pointer">
                                <option value="">Select a branch...</option>
                                @if (_branches != null)
                                {
                                    @foreach (var branch in _branches)
                                    {
                                        <option value="@branch.Id">@branch.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Footer Actions -->
        <div class="px-8 py-6 bg-muted/20 border-t border-border/40 flex flex-col sm:flex-row justify-between items-center gap-4">
            <p class="text-xs text-muted-foreground font-medium">
                <i data-lucide="info" class="w-3 h-3 inline mr-1"></i>
                Fields marked with <span class="text-destructive font-bold">*</span> are required.
            </p>
            <div class="flex gap-3">
                <button class="btn btn-ghost rounded-xl px-6" @onclick="GoBack" disabled="@_isSubmitting">
                    Cancel
                </button>
                <button class="btn btn-primary rounded-xl px-8 shadow-primary disabled:opacity-40 disabled:cursor-not-allowed flex items-center gap-2"
                        @onclick="HandleSubmit" disabled="@(!IsFormValid() || _isSubmitting)">
                    @if (_isSubmitting)
                    {
                        <div class="animate-spin rounded-full h-4 w-4 border-2 border-white/30 border-t-white"></div>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <i data-lucide="user-plus" class="w-4 h-4"></i>
                        <span>Create @_selectedRole</span>
                    }
                </button>
            </div>
        </div>

    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    // Form state
    private string _selectedRole = "Merchant";
    private string _userName = "";
    private string _email = "";
    private string _password = "";
    private bool _showPassword = false;

    // Merchant fields
    private string _merchantName = "";
    private string _merchantContactEmail = "";

    // Cashier fields
    private string _merchantId = "";
    private string _branchId = "";

    // Dropdown data
    private List<Merchant>? _merchants;
    private List<Branch>? _branches;

    // UI state
    private bool _isSubmitting = false;
    private string _successMessage = "";
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        // Load merchants and branches for cashier assignment dropdowns
        var merchantData = await Http.GetFromJsonAsync<PagedResult<Merchant>>("sample-data/merchants.json");
        _merchants = merchantData?.Data;

        var branchData = await Http.GetFromJsonAsync<PagedResult<Branch>>("sample-data/branches.json");
        _branches = branchData?.Data;
    }

    private void SelectRole(string role)
    {
        _selectedRole = role;
        _errorMessage = "";
        _successMessage = "";
        _ = ReinitIcons();
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
        _ = ReinitIcons();
    }

    private bool IsFormValid()
    {
        if (string.IsNullOrWhiteSpace(_userName) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
            return false;

        if (_selectedRole == "Merchant" && string.IsNullOrWhiteSpace(_merchantName))
            return false;

        if (_selectedRole == "Cashier" && (string.IsNullOrWhiteSpace(_merchantId) || string.IsNullOrWhiteSpace(_branchId)))
            return false;

        return true;
    }

    private async Task HandleSubmit()
    {
        _errorMessage = "";
        _successMessage = "";

        if (!IsFormValid())
        {
            _errorMessage = "Please fill in all required fields.";
            return;
        }

        _isSubmitting = true;
        StateHasChanged();

        // Simulate API delay for demo purposes
        await Task.Delay(1200);

        _isSubmitting = false;
        _successMessage = $"{_selectedRole} account for \"{_userName}\" created successfully!";

        // Reset form
        _userName = "";
        _email = "";
        _password = "";
        _merchantName = "";
        _merchantContactEmail = "";
        _merchantId = "";
        _branchId = "";

        StateHasChanged();
        await ReinitIcons();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/users");
    }

    private async Task ReinitIcons()
    {
        await Task.Delay(50);
        await JSRuntime.InvokeVoidAsync("initIcons");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
