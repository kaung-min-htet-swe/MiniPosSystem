@page "/cashiers/{Id}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    @if (_isLoading)
    {
        <div class="d-flex justify-center my-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true"/>
        </div>
    }
    else if (_cashier == null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">The requested user profile could not be found.
        </MudAlert>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" Class="mt-4">
            Back to Cashiers
        </MudButton>
    }
    else
    {
        <MudCard Elevation="4" Class="rounded-lg">
            <MudCardHeader Class="pb-0">
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Primary" Size="Size.Large" Variant="Variant.Filled">
                        @(_cashier.Username?.FirstOrDefault().ToString().ToUpper() ?? "?")
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary"><strong>@_cashier.Username</strong></MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Role: @_cashier.Role</MudText>
                </CardHeaderContent>
            </MudCardHeader>

            <MudCardContent>
                <MudGrid Class="mt-2">
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Personal Details</MudText>
                        <MudDivider/>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@_cashier.Email"
                                      Label="Email Address"
                                      ReadOnly="true"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email"/>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@_cashier.CreatedAt.ToString("MMMM dd, yyyy")"
                                      Label="Date Joined"
                                      ReadOnly="true"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.CalendarToday"/>
                    </MudItem>

                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Location Assignment</MudText>
                        <MudDivider/>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@(_cashier.Merchant?.Name ?? "Unassigned")"
                                      Label="Assigned Merchant"
                                      ReadOnly="true"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Business"/>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@(_cashier.Branch?.Name ?? "Unassigned")"
                                      Label="Assigned Branch"
                                      ReadOnly="true"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Storefront"/>
                    </MudItem>
                </MudGrid>
            </MudCardContent>

            <MudCardActions Class="d-flex justify-space-between pb-4 pl-4 pr-4 mt-4 bg-light">
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="GoBack">
                    Back
                </MudButton>

                <div>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.LockReset"
                               Class="mr-2">
                        Reset Password
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.Edit"
                               Href="@($"/cashiers/edit/{_cashier.Id}")">
                        Edit Profile
                    </MudButton>
                </div>
            </MudCardActions>
        </MudCard>
    }
</MudContainer>