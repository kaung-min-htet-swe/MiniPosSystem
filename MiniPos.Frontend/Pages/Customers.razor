@page "/customers"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Customers - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Customer Database</h1>
            <p class="text-muted-foreground mt-1 text-sm">View profiles, track loyalty, and manage contact info.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex relative mr-2 group">
                <i data-lucide="search" class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground group-focus-within:text-primary transition-colors"></i>
                <input type="text" placeholder="Search by name, email, phone..." class="w-64 pl-10 pr-4 py-2.5 bg-white border border-border/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm" />
            </div>
            <button class="btn btn-primary rounded-lg shadow-primary">
                <i data-lucide="user-plus" class="w-4 h-4 mr-2"></i> New Customer
            </button>
        </div>
    </div>

    <!-- Stunning Unified Data Table -->
    <div class="pos-card p-0 overflow-hidden shadow-md">
        @if (_customers == null)
        {
            <div class="flex items-center justify-center p-12">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-muted/40">
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60">Customer Profile</th>
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60">Contact</th>
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60">Registered</th>
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60 text-right">Loyalty Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border/40 bg-white">
                    @foreach (var customer in _customers)
                    {
                        var isVip = customer.Orders.Count > 50;
                        var initials = GetInitials(customer.Name);
                        var avatarBgClass = isVip ? "bg-gradient-to-tr from-indigo-500 to-purple-600 text-white" : "bg-slate-200 text-slate-700";
                        var badgeClass = isVip ? "bg-amber-100 text-amber-700" : "bg-muted text-muted-foreground";
                        var badgeText = isVip ? "VIP Member" : "Standard";
                        var city = _customerCities.GetValueOrDefault(customer.Id, "Unknown");
                        
                        <tr class="hover:bg-muted/30 transition-colors cursor-pointer group">
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-full @avatarBgClass shadow-md flex items-center justify-center font-bold font-outfit text-lg border-2 border-white relative">
                                        @if (isVip)
                                        {
                                            <div class="absolute -top-1 -right-1 w-4 h-4 bg-amber-400 rounded-full flex items-center justify-center shadow-sm">
                                                <i data-lucide="star" class="w-2.5 h-2.5 text-white"></i>
                                            </div>
                                        }
                                        @initials
                                    </div>
                                    <div>
                                        <div class="font-bold text-foreground text-base">@customer.Name</div>
                                        <div class="text-xs text-muted-foreground font-medium flex items-center gap-1 mt-0.5"><i data-lucide="map-pin" class="w-3 h-3"></i> @city</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="text-sm font-semibold">@customer.Email</div>
                                <div class="text-xs text-muted-foreground mt-0.5">@customer.PhoneNumber</div>
                            </td>
                            <td class="py-4 px-6 text-sm text-foreground font-medium">@customer.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="py-4 px-6 text-right">
                                <span class="badge @badgeClass px-3 py-1 text-xs">@badgeText</span>
                                <div class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest mt-1">@customer.Orders.Count Orders</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        }
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    private List<Customer>? _customers;
    private Dictionary<Guid, string> _customerCities = new();

    protected override async Task OnInitializedAsync()
    {
        _customers = await Http.GetFromJsonAsync<List<Customer>>("sample-data/customers.json");

        if (_customers != null)
        {
            // Map the parsed id to cities for backwards compatibility with the UI dictionary
            var mariahId = _customers.FirstOrDefault(c => c.Name == "Mariah Kelly")?.Id ?? Guid.Empty;
            if (mariahId != Guid.Empty) _customerCities[mariahId] = "San Francisco";

            var davidId = _customers.FirstOrDefault(c => c.Name == "David Tennant")?.Id ?? Guid.Empty;
            if (davidId != Guid.Empty) _customerCities[davidId] = "Chicago";
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[parts.Length - 1].Substring(0, 1)).ToUpper();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
