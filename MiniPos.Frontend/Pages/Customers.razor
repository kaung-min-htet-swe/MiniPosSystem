@page "/customers"

<PageTitle>Customers - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Customer Database</h1>
            <p class="text-muted-foreground mt-1 text-sm">View profiles, track loyalty, and manage contact info.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex relative mr-2">
                <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"></i>
                <input type="text" placeholder="Search by name, email, phone..." class="pl-9 pr-4 py-2 bg-white/60 backdrop-blur-sm border border-border/60 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 w-64 transition-all hover:bg-white" />
            </div>
            <button class="btn btn-primary rounded-lg shadow-primary">
                <i data-lucide="user-plus" class="w-4 h-4 mr-2"></i> New Customer
            </button>
        </div>
    </div>

    <!-- Stunning Unified Data Table -->
    <div class="pos-card p-0 overflow-hidden shadow-md">
        <div class="table-container">
            <table class="table w-full text-left border-collapse">
                <thead>
                    <tr class="bg-muted/40">
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60">Customer Profile</th>
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60">Contact</th>
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60">Registered</th>
                        <th class="py-4 px-6 font-bold text-[11px] text-muted-foreground uppercase tracking-widest border-b border-border/60 text-right">Loyalty Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border/40 bg-white">
                    <!-- Row 1 VIP -->
                    <tr class="hover:bg-muted/30 transition-colors cursor-pointer group">
                        <td class="py-4 px-6">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-600 shadow-md text-white flex items-center justify-center font-bold font-outfit text-lg border-2 border-white relative">
                                    <div class="absolute -top-1 -right-1 w-4 h-4 bg-amber-400 rounded-full flex items-center justify-center shadow-sm">
                                        <i data-lucide="star" class="w-2.5 h-2.5 text-white"></i>
                                    </div>
                                    MK
                                </div>
                                <div>
                                    <div class="font-bold text-foreground text-base">Mariah Kelly</div>
                                    <div class="text-xs text-muted-foreground font-medium flex items-center gap-1 mt-0.5"><i data-lucide="map-pin" class="w-3 h-3"></i> San Francisco</div>
                                </div>
                            </div>
                        </td>
                        <td class="py-4 px-6">
                            <div class="text-sm font-semibold">mariah.kelly@example.com</div>
                            <div class="text-xs text-muted-foreground mt-0.5">+1 (555) 123-4567</div>
                        </td>
                        <td class="py-4 px-6 text-sm text-foreground font-medium">Jan 12, 2023</td>
                        <td class="py-4 px-6 text-right">
                            <span class="badge bg-amber-100 text-amber-700 px-3 py-1 text-xs">VIP Memeber</span>
                            <div class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest mt-1">104 Orders</div>
                        </td>
                    </tr>

                    <!-- Row 2 -->
                    <tr class="hover:bg-muted/30 transition-colors cursor-pointer group">
                        <td class="py-4 px-6">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-slate-200 text-slate-700 flex items-center justify-center font-bold font-outfit text-lg border-2 border-white">
                                    DT
                                </div>
                                <div>
                                    <div class="font-bold text-foreground text-base">David Tennant</div>
                                    <div class="text-xs text-muted-foreground font-medium flex items-center gap-1 mt-0.5"><i data-lucide="map-pin" class="w-3 h-3"></i> Chicago</div>
                                </div>
                            </div>
                        </td>
                        <td class="py-4 px-6">
                            <div class="text-sm font-semibold">david.t@dev.io</div>
                            <div class="text-xs text-muted-foreground mt-0.5">+1 (555) 987-6543</div>
                        </td>
                        <td class="py-4 px-6 text-sm text-foreground font-medium">Nov 04, 2023</td>
                        <td class="py-4 px-6 text-right">
                            <span class="badge bg-muted text-muted-foreground px-3 py-1 text-xs">Standard</span>
                            <div class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest mt-1">4 Orders</div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
