@page "/cashiers/edit/{Id}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Color="Color.Primary">Edit Cashier Profile</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Update account details and location assignments.
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            @if (_isLoading)
            {
                <div class="d-flex justify-center my-4">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true"/>
                </div>
            }
            else if (_cashierModel == null)
            {
                <MudAlert Severity="Severity.Error">The requested cashier could not be found.</MudAlert>
            }
            else
            {
                <MudForm @ref="_form" Model="@_cashierModel">

                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_cashierModel.Email"
                                          Label="Email Address"
                                          Required="true"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"/>
                        </MudItem>

                        <MudItem xs="12" Class="mt-4">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Assignments</MudText>
                            <MudDivider Class="mb-4"/>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="Guid?"
                                       Label="Merchant"
                                       Value="_cashierModel.MerchantId"
                                       ValueChanged="OnMerchantChanged"
                                       Variant="Variant.Outlined"
                                       Clearable="true">
                                @foreach (var merchant in _availableMerchants)
                                {
                                    <MudSelectItem T="Guid?" Value="@merchant.Id">@merchant.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="Guid?"
                                       Label="Branch"
                                       @bind-Value="_cashierModel.BranchId"
                                       Variant="Variant.Outlined"
                                       Disabled="@(_cashierModel.MerchantId == null || _isLoadingBranches)"
                                       Clearable="true">
                                @if (_isLoadingBranches)
                                {
                                    <MudSelectItem T="Guid?" Value="null" Disabled="true">Loading branches...
                                    </MudSelectItem>
                                }
                                else if (!_availableBranches.Any() && _cashierModel.MerchantId != null)
                                {
                                    <MudSelectItem T="Guid?" Value="null" Disabled="true">No branches found for this
                                        merchant.
                                    </MudSelectItem>
                                }
                                else
                                {
                                    @foreach (var branch in _availableBranches)
                                    {
                                        <MudSelectItem T="Guid?" Value="@branch.Id">@branch.Name</MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudForm>
            }
        </MudCardContent>

        <MudCardActions Class="pb-4 pl-4 pr-4 d-flex justify-end">
            <MudButton Variant="Variant.Text" OnClick="Cancel" Class="mr-2">Cancel</MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveChanges"
                       Disabled="@(_isLoading || _isSaving)">
                @if (_isSaving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">Saving...</MudText>
                }
                else
                {
                    <MudText>Save Changes</MudText>
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>