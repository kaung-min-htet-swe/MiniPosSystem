@page "/branches/add"
@using MiniPos.Frontend.Shared.Types
@inject NotificationService Notification

<PageTitle>Add Branch - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-2xl mx-auto pb-12">
    <!-- Header with Back Navigation -->
    <div class="mb-8">
        <button class="flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors mb-4 group" @onclick="GoBack">
            <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
            Back to Branches
        </button>
        <h1 class="text-3xl font-black tracking-tight text-foreground">Add New Branch</h1>
        <p class="text-muted-foreground mt-1 text-sm">Create a new physical location and link it to a merchant.</p>
    </div>

    <!-- Form Card -->
    <div class="pos-card p-8 bg-white/60 shadow-xl border-border/40 relative overflow-hidden">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/5 rounded-full blur-2xl"></div>

        <EditForm Model="@_branchRequest" OnValidSubmit="HandleSubmit" class="space-y-6 relative z-10">
            <DataAnnotationsValidator />


            <div class="grid grid-cols-1 gap-5">
                <!-- Branch Name -->
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Branch Name</label>
                    <div class="relative flex items-center">
                        <i data-lucide="store" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                        <InputText @bind-Value="_branchRequest.Name" placeholder="e.g. Headquarters, Metro Branch" class="w-full pl-11 pr-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm" />
                    </div>
                    <ValidationMessage For="@(() => _branchRequest.Name)" class="text-xs text-destructive font-semibold mt-1" />
                </div>

                <!-- Address -->
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Address</label>
                    <div class="relative flex items-center">
                        <i data-lucide="map-pin" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                        <InputText @bind-Value="_branchRequest.Address" placeholder="e.g. 124 Main Street, NY" class="w-full pl-11 pr-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm" />
                    </div>
                    <ValidationMessage For="@(() => _branchRequest.Address)" class="text-xs text-destructive font-semibold mt-1" />
                </div>

                <!-- Associated Merchant -->
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Select Merchant</label>
                    <div class="relative flex items-center">
                        <i data-lucide="building" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                        <select @bind="_branchRequest.MerchantId" class="w-full pl-11 pr-10 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm appearance-none cursor-pointer">
                            <option value="">Choose a Merchant...</option>
                            @if (_merchants != null)
                            {
                                @foreach (var m in _merchants)
                                {
                                    <option value="@m.Id.ToString()">@m.Name</option>
                                }
                            }
                        </select>
                        <i data-lucide="chevron-down" class="absolute right-4 w-4 h-4 text-muted-foreground pointer-events-none"></i>
                    </div>
                    @if (string.IsNullOrEmpty(_branchRequest.MerchantId) && _hasSubmittedAttempt)
                    {
                        <div class="text-xs text-destructive font-semibold mt-1">Merchant is required.</div>
                    }
                </div>
            </div>

            <div class="pt-4 flex items-center gap-4">
                <button type="submit"
                        class="btn btn-primary px-8 h-12 shadow-xl shadow-primary/30 flex items-center gap-3 transition-all"
                        disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <div class="animate-spin rounded-full h-5 w-5 border-4 border-t-white border-white/20"></div>
                    }
                    else
                    {
                        <i data-lucide="check-circle" class="w-5 h-5 font-black"></i>
                    }
                    <span class="font-black uppercase tracking-tight text-sm">Create Branch</span>
                </button>
                <button type="button" class="btn btn-ghost rounded-xl px-6 py-3 font-bold text-sm" @onclick="GoBack" disabled="@_isSubmitting">Cancel</button>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private BranchFormModel _branchRequest = new();
    private List<Merchant>? _merchants;
    
    private bool _isSubmitting = false;
    private bool _hasSubmittedAttempt = false;

    public class BranchFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "Too long.")]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Address is required.")]
        public string Address { get; set; } = "";

        public string MerchantId { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"api/merchants");
            if (response.IsSuccessStatusCode)
            {
                var pagedResult = await response.Content.ReadFromJsonAsync<PagedResult<Merchant>>();
                _merchants = pagedResult?.Data;
            }
            else
            {
                await Notification.ShowError("Failed to load merchants.");
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"Error loading merchants: {ex.Message}");
        }
    }

    private void GoBack() { Navigation.NavigateTo("/branches"); }

    private async Task HandleSubmit()
    {
        _hasSubmittedAttempt = true;
        
        if (string.IsNullOrEmpty(_branchRequest.MerchantId)) return;

        _isSubmitting = true;
        
        try
        {
            var request = new BranchCreateRequest
            {
                MerchantId = _branchRequest.MerchantId,
                Name = _branchRequest.Name,
                Address = _branchRequest.Address
            };

            var response = await Http.PostAsJsonAsync("api/branches", request);
            if (response.IsSuccessStatusCode)
            {
                await Notification.ShowSuccess("Branch created successfully!");
                Navigation.NavigateTo("/branches");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await Notification.ShowError($"Creation failed: {error}");
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"Network error: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await JSRuntime.InvokeVoidAsync("initIcons"); }
    }
}
