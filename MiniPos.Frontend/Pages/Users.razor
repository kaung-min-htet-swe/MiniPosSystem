@page "/users"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Users - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Staff Directory</h1>
            <p class="text-muted-foreground mt-1 text-sm">Manage employee access, roles, and review terminal activity.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex relative mr-2">
                <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"></i>
                <input type="text" placeholder="Search staff..." class="pl-9 pr-4 py-2 bg-white/60 backdrop-blur-sm border border-border/60 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 w-48 transition-all hover:bg-white" />
            </div>
            <button class="btn btn-outline bg-white hover:bg-muted shadow-sm rounded-lg p-2">
                <i data-lucide="filter" class="w-4 h-4"></i>
            </button>
            <button class="btn btn-primary rounded-lg shadow-primary">
                <i data-lucide="user-plus" class="w-4 h-4 mr-2"></i>
                Invite Staff
            </button>
        </div>
    </div>

    @if (_users == null)
    {
        <div class="flex items-center justify-center p-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <!-- Stunning User Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

            @foreach (var user in _users)
            {
                var ui = _userUIs.GetValueOrDefault(user.Id, new UserUI { BadgeClass = "bg-muted text-muted-foreground", Icon = "user", AvatarGradient = "from-slate-400 to-slate-500", IsOnline = false, BranchName = "Unassigned", LeftStatLabel = "Total Sales", LeftStatValue = "-", LeftStatClass = "text-muted-foreground", RightStatLabel = "Shift Today", RightStatValue = "-" });
                var nameParts = user.Username.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                var initials = nameParts.Length > 1 
                    ? $"{nameParts[0][0]}{nameParts[nameParts.Length - 1][0]}".ToUpper() 
                    : user.Username.Substring(0, Math.Min(2, user.Username.Length)).ToUpper();

                <div class="pos-card relative overflow-visible group hover:-translate-y-1 transition-transform bg-white/40 @(user.DeletedAt == null ? "" : "grayscale-[20%]") @(user.Role == "Admin" ? "border-primary/20" : "")">
                    <!-- Top Role Badge & Actions -->
                    <div class="flex justify-between items-start w-full">
                        <span class="badge @ui.BadgeClass px-2.5 py-1 uppercase tracking-widest text-[9px] shadow-sm flex items-center">
                            <i data-lucide="@ui.Icon" class="w-3 h-3 mr-1"></i> @user.Role
                        </span>
                        <button class="text-muted-foreground hover:text-foreground">
                            <i data-lucide="more-horizontal" class="w-5 h-5"></i>
                        </button>
                    </div>

                    <!-- Avatar Profile -->
                    <div class="flex flex-col items-center mt-4">
                        <div class="relative">
                            <div class="w-20 h-20 rounded-full bg-gradient-to-tr @ui.AvatarGradient shadow-sm flex items-center justify-center text-white text-2xl font-bold font-outfit border-4 border-white @(user.Role == "Admin" ? "shadow-primary" : "")">
                                @initials
                            </div>
                            <div class="absolute bottom-0 right-1 w-4 h-4 @(ui.IsOnline ? "bg-success" : "bg-muted") border-2 border-white rounded-full" title="@(ui.IsOnline ? "Online" : "Offline")"></div>
                        </div>
                        <h3 class="font-bold text-lg mt-3 text-foreground">@user.Username</h3>
                        <p class="text-xs text-muted-foreground font-medium">@user.Email</p>
                    </div>

                    <!-- Detailed Stats / Context -->
                    <div class="mt-6 flex flex-col gap-2">
                        <div class="@(ui.BranchName == "Unassigned" ? "bg-muted/10 opacity-70" : "bg-muted/30") rounded-lg p-3 flex items-center gap-3">
                            <div class="w-8 h-8 rounded-md bg-white border border-border text-muted-foreground flex items-center justify-center">
                                <i data-lucide="@(ui.BranchName == "Unassigned" ? "alert-circle" : (user.Role == "Admin" ? "building" : "store"))" class="w-4 h-4"></i>
                            </div>
                            <div>
                                <div class="text-[10px] uppercase font-bold text-muted-foreground tracking-wider">Assigned To</div>
                                @if (ui.BranchName == "Unassigned")
                                {
                                    <div class="text-sm font-semibold italic text-muted-foreground">@ui.BranchName</div>
                                }
                                else
                                {
                                    <div class="text-sm font-semibold">@ui.BranchName</div>
                                }
                            </div>
                        </div>
                        
                        @if (ui.BranchName == "Unassigned")
                        {
                            <div class="bg-white/30 border border-border/50 rounded-lg p-2 text-center mt-1">
                                <button class="text-xs font-bold text-primary group-hover:underline">Manage Assignment</button>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-2 gap-2 mt-1">
                                <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                                    <div class="font-bold text-lg font-outfit @ui.LeftStatClass">@ui.LeftStatValue</div>
                                    <div class="text-[9px] text-muted-foreground uppercase font-bold">@ui.LeftStatLabel</div>
                                </div>
                                <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                                    <div class="font-bold text-lg text-foreground font-outfit">@ui.RightStatValue</div>
                                    <div class="text-[9px] text-muted-foreground uppercase font-bold">@ui.RightStatLabel</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    public class UserUI
    {
        public string BadgeClass { get; set; } = "";
        public string Icon { get; set; } = "";
        public string AvatarGradient { get; set; } = "";
        public bool IsOnline { get; set; }
        public string BranchName { get; set; } = "";
        public string LeftStatLabel { get; set; } = "";
        public string LeftStatValue { get; set; } = "";
        public string LeftStatClass { get; set; } = "";
        public string RightStatLabel { get; set; } = "";
        public string RightStatValue { get; set; } = "";
    }

    private List<User>? _users;
    private Dictionary<Guid, UserUI> _userUIs = new();

    protected override async Task OnInitializedAsync()
    {
        _users = await Http.GetFromJsonAsync<List<User>>("sample-data/users.json");

        if (_users != null)
        {
            var id1 = Guid.Parse("00000000-0000-0000-0000-00000000771A");
            var id2 = Guid.Parse("00000000-0000-0000-0000-000000007719");
            var id3 = Guid.Parse("00000000-0000-0000-0000-000000007718");
            var id4 = Guid.Parse("00000000-0000-0000-0000-000000007717");

            _userUIs[id1] = new UserUI { BadgeClass = "badge-primary", Icon = "shield-check", AvatarGradient = "from-primary to-purple-500", IsOnline = true, BranchName = "Headquarters", LeftStatLabel = "Total Sales", LeftStatValue = "1.2k", LeftStatClass = "text-primary", RightStatLabel = "Shift Today", RightStatValue = "8 hrs" };
            _userUIs[id2] = new UserUI { BadgeClass = "badge-success", Icon = "calculator", AvatarGradient = "from-success to-emerald-400", IsOnline = true, BranchName = "Metro Branch 1", LeftStatLabel = "Sales Today", LeftStatValue = "42", LeftStatClass = "text-success", RightStatLabel = "Active POS", RightStatValue = "Term 2" };
            _userUIs[id3] = new UserUI { BadgeClass = "badge-warning", Icon = "briefcase", AvatarGradient = "from-warning to-yellow-400", IsOnline = false, BranchName = "Metro Branch 1", LeftStatLabel = "Total Sales", LeftStatValue = "1.9k", LeftStatClass = "text-warning", RightStatLabel = "Shift Today", RightStatValue = "-" };
            _userUIs[id4] = new UserUI { BadgeClass = "bg-muted text-muted-foreground", Icon = "calculator", AvatarGradient = "from-muted-foreground to-muted", IsOnline = false, BranchName = "Unassigned" };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
