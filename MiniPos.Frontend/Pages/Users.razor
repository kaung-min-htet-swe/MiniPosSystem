@page "/users"
@using MiniPos.Frontend.Models
@using MiniPos.Frontend.Services

<div class="flex flex-col animate-slide-down">
    <!-- Ultra-Clean Container -->
    <div class="flex-1 min-h-0 flex flex-col bg-white/40 backdrop-blur-xl border border-white/60 rounded-[2rem] shadow-2xl shadow-primary/5 overflow-hidden">
        
        <!-- Minimal Top Strip -->
        <div class="px-6 py-4 border-b border-border/10 flex items-center justify-between gap-4 shrink-0 bg-white/10">
            <div class="flex items-center gap-2 flex-1 max-w-xl">
                <div class="relative flex-1 group">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-muted-foreground transition-colors group-focus-within:text-primary"></i>
                    <input type="text" placeholder="Search staff..." 
                           @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyUp"
                           class="w-full pl-10 pr-4 py-2.5 bg-white border border-border/60 rounded-2xl text-sm focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:bg-white transition-all shadow-sm"/>
                </div>
                <button class="p-2 bg-white/60 rounded-xl border border-border/10 hover:border-primary/20 hover:text-primary transition-all shadow-sm" title="Filters">
                    <i data-lucide="filter" class="w-4 h-4"></i>
                </button>
                <button class="bg-primary hover:bg-primary-focus text-white px-4 py-2 rounded-xl font-bold text-xs shadow-lg shadow-primary/20 flex items-center gap-1.5 transition-all active:scale-95" @onclick="GoToAddStaff">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                    <span>Add Staff</span>
                </button>
            </div>
            
            <div class="hidden sm:block">
                @if (_pagedUsers != null)
                {
                    <p class="text-[9px] text-muted-foreground font-bold uppercase tracking-widest opacity-60">
                        @_pagedUsers.TotalCount Members Total
                    </p>
                }
            </div>
        </div>

        @if (_pagedUsers == null)
        {
            <div class="flex-1 flex items-center justify-center bg-white/5">
                <div class="w-10 h-10 rounded-full border-2 border-primary/20 border-t-primary animate-spin"></div>
            </div>
        }
        else
        {
            <!-- Full Height Table -->
            <div class="flex-1 overflow-auto custom-scrollbar">
                <table class="w-full text-left border-collapse table-fixed lg:table-auto">
                    <thead class="sticky top-0 z-10 bg-white/80 backdrop-blur-md border-b border-border/10">
                        <tr>
                            <th class="pl-6 py-3 text-[9px] font-bold uppercase tracking-widest text-muted-foreground w-[40%]">Member</th>
                            <th class="px-4 py-3 text-[9px] font-bold uppercase tracking-widest text-muted-foreground">Role</th>
                            <th class="px-4 py-3 text-[9px] font-bold uppercase tracking-widest text-muted-foreground hidden md:table-cell">Assignment</th>
                            <th class="pr-6 py-3 text-[9px] font-bold uppercase tracking-widest text-muted-foreground text-right w-24">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/5">
                    @foreach (var user in _pagedUsers.Data)
                    {
                        var ui = _userUIs.GetValueOrDefault(user.Id, new UserUI { BadgeClass = "bg-muted text-muted-foreground", AvatarGradient = "from-slate-400 to-slate-500", IsActive = false, BranchName = "Unassigned" });
                        var nameParts = user.UserName?.Split(' ', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                        var initials = nameParts.Length > 1 ? $"{nameParts[0][0]}{nameParts[nameParts.Length - 1][0]}".ToUpper() : (user.UserName?.Length > 0 ? user.UserName.Substring(0, Math.Min(2, user.UserName.Length)).ToUpper() : "??");

                        <tr class="group hover:bg-white/40 transition-all cursor-pointer" @onclick="() => GoToUserDetail(user.Id)">
                            <td class="pl-6 py-3.5">
                                <div class="flex items-center gap-3">
                                    <div class="relative shrink-0">
                                        <div class="w-9 h-9 rounded-xl bg-gradient-to-tr @ui.AvatarGradient shadow-sm flex items-center justify-center text-white text-xs font-black border border-white">
                                            @initials
                                        </div>
                                        <div class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 @(ui.IsActive ? "bg-emerald-500" : "bg-neutral-300") border-2 border-white rounded-full"></div>
                                    </div>
                                    <div class="min-w-0">
                                        <h4 class="font-bold text-xs text-foreground group-hover:text-primary transition-colors truncate">@user.UserName</h4>
                                        <p class="text-[9px] text-muted-foreground font-medium truncate">@user.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3.5">
                                <span class="text-[9px] uppercase font-bold tracking-widest px-2 py-0.5 rounded-lg border border-border/10 @ui.BadgeClass shadow-sm inline-block">
                                    @user.Role
                                </span>
                            </td>
                            <td class="px-4 py-3.5 hidden md:table-cell">
                                <div class="flex items-center gap-2 text-[10px] font-semibold text-foreground/70">
                                    <i data-lucide="store" class="w-3 h-3 text-primary/60"></i>
                                    <span class="truncate">@ui.BranchName</span>
                                </div>
                            </td>
                            <td class="pr-6 py-3.5 text-right">
                                    <button 
                                        class="p-1.5 hover:bg-primary/10 hover:text-primary text-muted-foreground rounded-lg transition-all"
                                        @onclick:stopPropagation="true"
                                        >
                                        <i data-lucide="menu" class="w-3.5 h-3.5"></i>
                                    </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <!-- Minimal Pagination Bar -->
            <div class="px-6 py-3 border-t border-border/10 bg-white/20 backdrop-blur-md flex justify-center items-center shrink-0">
                <div class="flex items-center gap-1">
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/60 border border-border/10 text-muted-foreground hover:bg-primary hover:text-white transition-all disabled:opacity-30 shadow-sm"
                            disabled="@(!_pagedUsers.HasPreviousPage)"
                            @onclick="() => ChangePage(_pagedUsers.PageNumber - 1)">
                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </button>

                    @for (int i = 1; i <= Math.Max(1, _pagedUsers.TotalPages); i++)
                    {
                        var pageIndex = i;
                        <button class="w-8 h-8 flex items-center justify-center rounded-lg font-bold text-[10px] transition-all
                                       @(pageIndex == _pagedUsers.PageNumber ? "bg-primary text-white shadow-lg shadow-primary/20 scale-105" : "bg-white/40 border border-border/10 text-muted-foreground hover:border-primary/40 hover:text-primary")"
                                @onclick="() => ChangePage(pageIndex)">
                            @pageIndex
                        </button>
                    }

                    <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/60 border border-border/10 text-muted-foreground hover:bg-primary hover:text-white transition-all disabled:opacity-30 shadow-sm"
                            disabled="@(!_pagedUsers.HasNextPage)"
                            @onclick="() => ChangePage(_pagedUsers.PageNumber + 1)">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private CookieService Cookies { get; set; } = default!;

    public class UserUI
    {
        public string BadgeClass { get; set; } = "";
        public string AvatarGradient { get; set; } = "";
        public bool IsActive { get; set; }
        public string BranchName { get; set; } = "";
    }

    private PagedResult<User>? _pagedUsers;
    private readonly Dictionary<Guid, UserUI> _userUIs = new();
    private string _searchTerm = "";
    private int _currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            var url = $"/api/users?includeCashiers=true&pageNumber={_currentPage}&pageSize=10&searchTerm={Uri.EscapeDataString(_searchTerm)}";
            _pagedUsers = await Http.GetFromJsonAsync<PagedResult<User>>(url);
            
            _userUIs.Clear();
            if (_pagedUsers?.Data != null)
            {
                foreach (var user in _pagedUsers.Data)
                {
                    _userUIs[user.Id] = new UserUI
                    {
                        BadgeClass = user.Role switch
                        {
                            "Admin" => "bg-indigo-50 text-indigo-600 border-indigo-100",
                            "Manager" => "bg-rose-50 text-rose-600 border-rose-100",
                            "Cashier" => "bg-blue-50 text-blue-600 border-blue-100",
                            _ => "bg-slate-50 text-slate-600 border-slate-100"
                        },
                        AvatarGradient = user.Role switch
                        {
                            "Admin" => "from-indigo-400 to-indigo-600",
                            "Manager" => "from-rose-400 to-rose-600",
                            "Cashier" => "from-blue-400 to-blue-600",
                            _ => "from-slate-400 to-slate-600"
                        },
                        IsActive = true,
                        BranchName = user.Role == "Admin" ? "Global" : "Terminal Alpha"
                    };
                }
            }
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        _currentPage = 1;
        await LoadUsers();
    }

    private async Task ChangePage(int page)
    {
        if (page < 1 || (_pagedUsers != null && page > _pagedUsers.TotalPages)) return;
        _currentPage = page;
        await LoadUsers();
    }

    private void GoToUserDetail(Guid userId) => Navigation.NavigateTo($"/users/{userId}");
    private void GoToAddStaff() => Navigation.NavigateTo("/users/add");
}
