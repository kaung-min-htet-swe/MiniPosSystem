@page "/users"

<PageTitle>Staff & Roles - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Staff Directory</h1>
            <p class="text-muted-foreground mt-1 text-sm">Manage employee access, roles, and review terminal activity.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex relative mr-2">
                <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"></i>
                <input type="text" placeholder="Search staff..." class="pl-9 pr-4 py-2 bg-white/60 backdrop-blur-sm border border-border/60 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 w-48 transition-all hover:bg-white" />
            </div>
            <button class="btn btn-outline bg-white hover:bg-muted shadow-sm rounded-lg p-2">
                <i data-lucide="filter" class="w-4 h-4"></i>
            </button>
            <button class="btn btn-primary rounded-lg shadow-primary">
                <i data-lucide="user-plus" class="w-4 h-4 mr-2"></i>
                Invite Staff
            </button>
        </div>
    </div>

    <!-- Stunning Grid Layout for Staff/Users -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        <!-- Staff Card 1 (Admin) -->
        <div class="pos-card relative overflow-visible group hover:-translate-y-1 transition-transform bg-white/40 border-primary/20">
            <!-- Top Role Badge & Actions -->
            <div class="flex justify-between items-start w-full">
                <span class="badge badge-primary px-2.5 py-1 uppercase tracking-widest text-[9px] shadow-sm flex items-center">
                    <i data-lucide="shield-check" class="w-3 h-3 mr-1"></i> Admin
                </span>
                <button class="text-muted-foreground hover:text-foreground">
                    <i data-lucide="more-horizontal" class="w-5 h-5"></i>
                </button>
            </div>

            <!-- Avatar Profile -->
            <div class="flex flex-col items-center mt-4">
                <div class="relative">
                    <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-primary to-purple-500 shadow-primary flex items-center justify-center text-white text-2xl font-bold font-outfit border-4 border-white">
                        AS
                    </div>
                    <div class="absolute bottom-0 right-1 w-4 h-4 bg-success border-2 border-white rounded-full" title="Online"></div>
                </div>
                <h3 class="font-bold text-lg mt-3 text-foreground">Alice Smith</h3>
                <p class="text-xs text-muted-foreground font-medium">alice@example.com</p>
            </div>

            <!-- Detailed Stats / Context -->
            <div class="mt-6 flex flex-col gap-2">
                <div class="bg-muted/30 rounded-lg p-3 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-md bg-white border border-border text-muted-foreground flex items-center justify-center">
                        <i data-lucide="building" class="w-4 h-4"></i>
                    </div>
                    <div>
                        <div class="text-[10px] uppercase font-bold text-muted-foreground tracking-wider">Assigned To</div>
                        <div class="text-sm font-semibold">Headquarters</div>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-2 mt-1">
                    <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                        <div class="font-bold text-lg text-primary font-outfit">1.2k</div>
                        <div class="text-[9px] text-muted-foreground uppercase font-bold">Total Sales</div>
                    </div>
                    <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                        <div class="font-bold text-lg text-foreground font-outfit">8 hrs</div>
                        <div class="text-[9px] text-muted-foreground uppercase font-bold">Shift Today</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Staff Card 2 (Cashier) -->
        <div class="pos-card relative overflow-visible group hover:-translate-y-1 transition-transform bg-white/40">
            <!-- Top Role Badge & Actions -->
            <div class="flex justify-between items-start w-full">
                <span class="badge badge-success px-2.5 py-1 uppercase tracking-widest text-[9px] shadow-sm flex items-center">
                    <i data-lucide="calculator" class="w-3 h-3 mr-1"></i> Cashier
                </span>
                <button class="text-muted-foreground hover:text-foreground">
                    <i data-lucide="more-horizontal" class="w-5 h-5"></i>
                </button>
            </div>

            <!-- Avatar Profile -->
            <div class="flex flex-col items-center mt-4">
                <div class="relative">
                    <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-success to-emerald-400 shadow-sm flex items-center justify-center text-white text-2xl font-bold font-outfit border-4 border-white">
                        JD
                    </div>
                    <div class="absolute bottom-0 right-1 w-4 h-4 bg-success border-2 border-white rounded-full" title="Online"></div>
                </div>
                <h3 class="font-bold text-lg mt-3 text-foreground">John Doe</h3>
                <p class="text-xs text-muted-foreground font-medium">john.doe@example.com</p>
            </div>

            <!-- Detailed Stats / Context -->
            <div class="mt-6 flex flex-col gap-2">
                <div class="bg-muted/30 rounded-lg p-3 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-md bg-white border border-border text-muted-foreground flex items-center justify-center">
                        <i data-lucide="store" class="w-4 h-4"></i>
                    </div>
                    <div>
                        <div class="text-[10px] uppercase font-bold text-muted-foreground tracking-wider">Assigned To</div>
                        <div class="text-sm font-semibold">Metro Branch 1</div>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-2 mt-1">
                    <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                        <div class="font-bold text-lg text-success font-outfit">42</div>
                        <div class="text-[9px] text-muted-foreground uppercase font-bold">Sales Today</div>
                    </div>
                    <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                        <div class="font-bold text-lg text-foreground font-outfit">Term 2</div>
                        <div class="text-[9px] text-muted-foreground uppercase font-bold">Active POS</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Staff Card 3 (Manager) -->
        <div class="pos-card relative overflow-visible group hover:-translate-y-1 transition-transform bg-white/40">
            <!-- Top Role Badge & Actions -->
            <div class="flex justify-between items-start w-full">
                <span class="badge badge-warning px-2.5 py-1 uppercase tracking-widest text-[9px] shadow-sm flex items-center">
                    <i data-lucide="briefcase" class="w-3 h-3 mr-1"></i> Manager
                </span>
                <button class="text-muted-foreground hover:text-foreground">
                    <i data-lucide="more-horizontal" class="w-5 h-5"></i>
                </button>
            </div>

            <!-- Avatar Profile -->
            <div class="flex flex-col items-center mt-4">
                <div class="relative">
                    <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-warning to-yellow-400 shadow-sm flex items-center justify-center text-white text-2xl font-bold font-outfit border-4 border-white">
                        EW
                    </div>
                    <div class="absolute bottom-0 right-1 w-4 h-4 bg-muted border-2 border-white rounded-full" title="Offline"></div>
                </div>
                <h3 class="font-bold text-lg mt-3 text-foreground">Emily Wong</h3>
                <p class="text-xs text-muted-foreground font-medium">ewong@minipos.app</p>
            </div>

            <!-- Detailed Stats / Context -->
            <div class="mt-6 flex flex-col gap-2">
                <div class="bg-muted/30 rounded-lg p-3 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-md bg-white border border-border text-muted-foreground flex items-center justify-center">
                        <i data-lucide="store" class="w-4 h-4"></i>
                    </div>
                    <div>
                        <div class="text-[10px] uppercase font-bold text-muted-foreground tracking-wider">Assigned To</div>
                        <div class="text-sm font-semibold">Metro Branch 1</div>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-2 mt-1">
                    <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                        <div class="font-bold text-lg text-warning font-outfit">1.9k</div>
                        <div class="text-[9px] text-muted-foreground uppercase font-bold">Total Sales</div>
                    </div>
                    <div class="bg-white/60 border border-border/50 rounded-lg p-2 text-center">
                        <div class="font-bold text-lg text-muted-foreground font-outfit">-</div>
                        <div class="text-[9px] text-muted-foreground uppercase font-bold">Shift Today</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Staff Card 4 (Cashier - Offline) -->
        <div class="pos-card relative overflow-visible group hover:-translate-y-1 transition-transform bg-white/40 grayscale-[20%]">
            <!-- Top Role Badge & Actions -->
            <div class="flex justify-between items-start w-full">
                <span class="badge bg-muted text-muted-foreground px-2.5 py-1 uppercase tracking-widest text-[9px] shadow-sm flex items-center">
                    <i data-lucide="calculator" class="w-3 h-3 mr-1"></i> Cashier
                </span>
                <button class="text-muted-foreground hover:text-foreground">
                    <i data-lucide="more-horizontal" class="w-5 h-5"></i>
                </button>
            </div>

            <!-- Avatar Profile -->
            <div class="flex flex-col items-center mt-4">
                <div class="relative">
                    <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-muted-foreground to-muted shadow-sm flex items-center justify-center text-white text-2xl font-bold font-outfit border-4 border-white">
                        RT
                    </div>
                    <div class="absolute bottom-0 right-1 w-4 h-4 bg-muted border-2 border-white rounded-full" title="Offline"></div>
                </div>
                <h3 class="font-bold text-lg mt-3 text-foreground">Robert Taylor</h3>
                <p class="text-xs text-muted-foreground font-medium">robert.t@example.com</p>
            </div>

            <!-- Detailed Stats / Context -->
            <div class="mt-6 flex flex-col gap-2">
                <div class="bg-muted/10 rounded-lg p-3 flex items-center gap-3 opacity-70">
                    <div class="w-8 h-8 rounded-md bg-white border border-border text-muted-foreground flex items-center justify-center">
                        <i data-lucide="alert-circle" class="w-4 h-4"></i>
                    </div>
                    <div>
                        <div class="text-[10px] uppercase font-bold text-muted-foreground tracking-wider">Assigned To</div>
                        <div class="text-sm font-semibold italic text-muted-foreground">Unassigned</div>
                    </div>
                </div>
                
                <div class="bg-white/30 border border-border/50 rounded-lg p-2 text-center mt-1">
                    <button class="text-xs font-bold text-primary group-hover:underline">Manage Assignment</button>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}
