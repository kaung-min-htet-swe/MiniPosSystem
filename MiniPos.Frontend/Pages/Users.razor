@page "/users"
@using MiniPos.Frontend.Models
@using MiniPos.Frontend.Services

<PageTitle>Users - MiniPOS</PageTitle>

@if (!string.IsNullOrEmpty(_alertMessage))
{
    <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] animate-slide-down">
        <div class="px-6 py-4 rounded-2xl shadow-2xl backdrop-blur-md flex items-center gap-4 border
            @(_alertType == "success" ? "bg-success border-success/30 text-white" : "bg-destructive border-destructive/30 text-white")">
            <i data-lucide="@(_alertType == "success" ? "check-circle-2" : "alert-circle")"
               class="w-6 h-6 shrink-0"></i>
            <span class="font-bold tracking-wide">@_alertMessage</span>
            <button @onclick='() => _alertMessage = ""' class="ml-4 hover:opacity-70 transition-opacity">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
    </div>
}

<div class="animate-slide-down">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Staff Directory</h1>
            <p class="text-muted-foreground mt-1 text-sm">Manage employee access, roles, and review terminal
                activity.</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex relative mr-2">
                <i data-lucide="search"
                   class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"></i>
                <input type="text" placeholder="Search staff..."
                       class="pl-9 pr-4 py-2 bg-white/60 backdrop-blur-sm border border-border/60 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 w-48 transition-all hover:bg-white"/>
            </div>
            <button class="btn btn-outline bg-white hover:bg-muted shadow-sm rounded-lg p-2">
                <i data-lucide="filter" class="w-4 h-4"></i>
            </button>
            <button class="btn btn-primary rounded-lg shadow-primary" @onclick="GoToAddStaff">
                <i data-lucide="user-plus" class="w-4 h-4 mr-2"></i>
                Add Staff
            </button>
        </div>
    </div>

    @if (_pagedUsers == null)
    {
        <div class="flex items-center justify-center p-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <!-- Stunning User Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var user in _pagedUsers.Data)
            {
                var ui = _userUIs.GetValueOrDefault(
                    user.Id,
                    new UserUI
                    {
                        BadgeClass = "bg-muted text-muted-foreground",
                        Icon = "user",
                        AvatarGradient = "from-slate-400 to-slate-500",
                        IsActive = false,
                        BranchName = "Unassigned"
                        // LeftStatLabel = "Total Sales", 
                        // LeftStatValue = "-", 
                        // LeftStatClass = "text-muted-foreground", 
                        // RightStatLabel = "Shift Today", 
                        // RightStatValue = "-"
                    });
                var nameParts = user.UserName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                var initials = nameParts.Length > 1
                    ? $"{nameParts[0][0]}{nameParts[nameParts.Length - 1][0]}".ToUpper()
                    : user.UserName.Substring(0, Math.Min(2, user.UserName.Length)).ToUpper();
                <div
                    class="group relative bg-white/60 backdrop-blur-md border border-border/40 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 rounded-2xl p-5 transition-all duration-300 cursor-pointer flex flex-col items-center text-center shadow-sm"
                    @onclick="() => GoToUserDetail(user.Id)">

                    <!-- Top Action/Badge -->
                    <div class="absolute top-4 right-4 flex items-center">
                        <span
                            class="badge @ui.BadgeClass text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-full shadow-sm">
                            @user.Role
                        </span>
                    </div>

                    <button
                        class="absolute top-4 left-4 text-muted-foreground/60 hover:text-foreground transition-colors p-1 hover:bg-muted/30 rounded-full"
                        @onclick:stopPropagation="true">
                        <i data-lucide="more-horizontal" class="w-4 h-4"></i>
                    </button>

                    <!-- Avatar Profile -->
                    <div class="relative mt-2">
                        <div
                            class="w-16 h-16 rounded-full bg-gradient-to-tr @ui.AvatarGradient shadow-sm flex items-center justify-center text-white text-xl font-semibold font-outfit border-2 border-white">
                            @initials
                        </div>
                        <div
                            class="absolute bottom-0 right-0 w-3 h-3 @(ui.IsActive ? "bg-emerald-500" : "bg-neutral-300") border-2 border-white rounded-full"
                            title="@(ui.IsActive ? "Online" : "Offline")"></div>
                    </div>

                    <!-- User Info -->
                    <div class="mt-3.5">
                        <h3 class="font-bold text-base text-foreground group-hover:text-primary transition-colors">@user.UserName</h3>
                        <p class="text-[11px] text-muted-foreground font-medium mt-0.5 tracking-wide">@user.Email</p>
                    </div>

                    <!-- Assignments -->
                    <div class="mt-4 pt-3 border-t border-border/40 w-full flex flex-col items-center gap-1">
                        <div class="flex items-center gap-1.5 text-xs font-semibold text-foreground/80">
                            <i data-lucide="store" class="w-3.5 h-3.5 text-primary/80"></i>
                            <span>@ui.BranchName</span>
                        </div>
                        @if (!string.IsNullOrEmpty(ui.MerchantName))
                        {
                            <div class="flex items-center gap-1 text-[10px] text-muted-foreground font-medium">
                                <i data-lucide="building-2" class="w-3 h-3 text-muted-foreground/60"></i>
                                <span>@ui.MerchantName</span>
                            </div>
                        }
                    </div>

                    @if (ui.BranchName == "Unassigned")
                    {
                        <div class="mt-3 w-full">
                            <button
                                class="text-xs font-bold text-primary hover:underline flex items-center justify-center gap-1 mx-auto"
                                @onclick:stopPropagation="true">
                                <i data-lucide="shield-plus" class="w-3.5 h-3.5"></i> Assign
                            </button>
                        </div>
                    }

                </div>
            }
        </div>
    }
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private CookieService Cookies { get; set; } = default!;

    public class UserUI
    {
        public string BadgeClass { get; set; } = "";
        public string Icon { get; set; } = "";
        public string AvatarGradient { get; set; } = "";
        public bool IsActive { get; set; }
        public string BranchName { get; set; } = "";

        public string MerchantName { get; set; } = "";
        // public string LeftStatLabel { get; set; } = "";
        // public string LeftStatValue { get; set; } = "";
        // public string LeftStatClass { get; set; } = "";
        // public string RightStatLabel { get; set; } = "";
        // public string RightStatValue { get; set; } = "";
    }

    private PagedResult<User>? _pagedUsers;
    private readonly Dictionary<Guid, UserUI> _userUIs = new();

    // Alert state
    private string _alertMessage = "";
    private string _alertType = "success";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _pagedUsers = await Http.GetFromJsonAsync<PagedResult<User>>("/api/users?IncludeCashierRole=true");

            if (_pagedUsers != null)
            {
                foreach (var user in _pagedUsers.Data)
                {
                    _userUIs[user.Id] = user.Role switch
                    {
                        "Admin" => new UserUI
                        {
                            BadgeClass = "badge-primary", Icon = "shield-check",
                            AvatarGradient = "from-primary to-purple-500", IsActive = true,
                            BranchName = user.Branch?.Name ?? "Unassigned",
                            MerchantName = user.Merchant?.Name ?? ""
                        },
                        "Cashier" => new UserUI
                        {
                            BadgeClass = "badge-success", Icon = "calculator",
                            AvatarGradient = "from-success to-emerald-400", IsActive = true,
                            BranchName = user.Branch?.Name ?? "Unassigned",
                            MerchantName = user.Merchant?.Name ?? ""
                        },
                        "Merchant" or "Manager" => new UserUI
                        {
                            BadgeClass = "badge-warning", Icon = "briefcase",
                            AvatarGradient = "from-warning to-yellow-400", IsActive = false,
                            BranchName = user.Branch?.Name ?? "Unassigned",
                            MerchantName = user.Merchant?.Name ?? ""
                        },
                        _ => new UserUI
                        {
                            BadgeClass = "bg-muted text-muted-foreground", Icon = "user",
                            AvatarGradient = "from-muted-foreground to-muted", IsActive = false,
                            BranchName = "Unassigned",
                            MerchantName = user.Merchant?.Name ?? ""
                        }
                    };
                }
            }
        }
        catch (Exception ex)
        {
            await ShowAlert($"Failed to load staff directory: {ex.Message}", "error");
        }
    }

    private async Task ShowAlert(string message, string type = "success")
    {
        _alertMessage = message;
        _alertType = type;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("initIcons");
        await Task.Delay(5000);
        _alertMessage = "";
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }

    private void GoToAddStaff()
    {
        Navigation.NavigateTo("/users/add");
    }

    private void GoToUserDetail(Guid userId)
    {
        Navigation.NavigateTo($"/users/{userId}");
    }

}
