@page "/merchants/add"

<PageTitle>Add Merchant - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-2xl mx-auto pb-12">
    <!-- Header with Back Navigation -->
    <div class="mb-8">
        <button class="flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors mb-4 group" @onclick="GoBack">
            <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
            Back to Merchants
        </button>
        <h1 class="text-3xl font-black tracking-tight text-foreground">Add New Merchant</h1>
        <p class="text-muted-foreground mt-1 text-sm">Create a new corporate entity or vendor profile profile safely.</p>
    </div>

    <!-- Form Card -->
    <div class="pos-card p-8 bg-white/60 shadow-xl border-border/40 relative overflow-hidden">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/5 rounded-full blur-2xl"></div>

        <EditForm Model="@_merchantRequest" OnValidSubmit="HandleSubmit" class="space-y-6 relative z-10">
            <DataAnnotationsValidator />

            <!-- Success / Error Banner -->
            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="bg-success/10 border border-success/20 text-success rounded-xl p-4 text-sm font-bold flex items-center gap-2 animate-fade-in mb-4">
                    <i data-lucide="check-circle" class="w-4 h-4"></i> @_successMessage
                </div>
            }

            <div class="grid grid-cols-1 gap-5">
                <!-- Merchant Name -->
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Merchant Name</label>
                    <div class="relative flex items-center">
                        <i data-lucide="building" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                        <InputText @bind-Value="_merchantRequest.Name" placeholder="e.g. Super Mart LLC, Coffee Fusion" class="w-full pl-11 pr-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm" />
                    </div>
                    <ValidationMessage For="@(() => _merchantRequest.Name)" class="text-xs text-destructive font-semibold mt-1" />
                </div>

                <!-- Contact Email -->
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Contact Email</label>
                    <div class="relative flex items-center">
                        <i data-lucide="mail" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                        <InputText @bind-Value="_merchantRequest.ContactEmail" placeholder="e.g. admin@supermart.com" class="w-full pl-11 pr-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm" />
                    </div>
                    <ValidationMessage For="@(() => _merchantRequest.ContactEmail)" class="text-xs text-destructive font-semibold mt-1" />
                </div>

                <!-- Status Toggle -->
                <div class="flex items-center justify-between p-4 bg-muted/20 rounded-xl border border-border/30">
                    <div>
                        <div class="text-sm font-bold text-foreground">Is Active Account</div>
                        <div class="text-xs text-muted-foreground">Enable active sessions instantly.</div>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" @bind="_merchantRequest.IsActive" class="sr-only peer" />
                        <div class="w-10 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </div>
            </div>

            <div class="pt-4 flex items-center gap-4">
                <button type="submit"
                        class="btn btn-primary px-8 h-12 shadow-xl shadow-primary/30 flex items-center gap-3 transition-all"
                        disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <div class="animate-spin rounded-full h-5 w-5 border-4 border-t-white border-white/20"></div>
                    }
                    else
                    {
                        <i data-lucide="check-circle" class="w-5 h-5 font-black"></i>
                    }
                    <span class="font-black uppercase tracking-tight text-sm">Create Merchant</span>
                </button>
                <button type="button" class="btn btn-ghost rounded-xl px-6 py-3 font-bold text-sm" @onclick="GoBack" disabled="@_isSubmitting">Cancel</button>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private MerchantFormModel _merchantRequest = new() { IsActive = true };
    
    private bool _isSubmitting = false;
    private string _successMessage = "";

    public class MerchantFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "Too long.")]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address format.")]
        public string? ContactEmail { get; set; }

        public bool IsActive { get; set; }
    }

    private void GoBack() { Navigation.NavigateTo("/merchants"); }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _successMessage = "";
        
        await Task.Delay(1500); // Simulate API Submit
        _isSubmitting = false;
        _successMessage = "Merchant created successfully!";
        
        // Redirect after delay
        await Task.Delay(1000);
        Navigation.NavigateTo("/merchants");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await JSRuntime.InvokeVoidAsync("initIcons"); }
    }
}
