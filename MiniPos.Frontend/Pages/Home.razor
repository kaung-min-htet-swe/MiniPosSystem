@page "/"
@using MiniPos.Frontend.Models
@using System.Net.Http.Json

<PageTitle>Dashboard - MiniPOS</PageTitle>

<div class="animate-slide-down">
    <!-- Header Area -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Dashboard Overview</h1>
            <p class="text-muted-foreground mt-1 text-sm">Welcome back, here's what's happening with your store today.</p>
        </div>
        <div class="flex items-center gap-3">
            <button class="btn btn-outline bg-white hover:bg-muted shadow-sm rounded-lg">
                <i data-lucide="calendar" class="w-4 h-4 mr-2"></i>
                Today
                <i data-lucide="chevron-down" class="w-4 h-4 ml-2 text-muted-foreground"></i>
            </button>
            <button class="btn btn-primary rounded-lg shadow-primary">
                <i data-lucide="download" class="w-4 h-4 mr-2"></i>
                Export Report
            </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <!-- Stat Card 1 -->
        <div class="pos-card relative overflow-hidden group">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-colors"></div>
            <div class="pos-card-header">
                <h3 class="pos-card-title">Total Revenue</h3>
                <div class="pos-card-icon bg-primary/10 text-primary">
                    <i data-lucide="dollar-sign" class="w-5 h-5"></i>
                </div>
            </div>
            <div class="pos-card-value">$24,592.50</div>
            <div class="pos-card-trend trend-up">
                <i data-lucide="trending-up" class="w-4 h-4"></i>
                <span>+14.5% from last month</span>
            </div>
        </div>

        <!-- Stat Card 2 -->
        <div class="pos-card relative overflow-hidden group">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-success/5 rounded-full blur-2xl group-hover:bg-success/10 transition-colors"></div>
            <div class="pos-card-header">
                <h3 class="pos-card-title">Transactions</h3>
                <div class="pos-card-icon bg-success bg-opacity-10 text-success">
                    <i data-lucide="credit-card" class="w-5 h-5"></i>
                </div>
            </div>
            <div class="pos-card-value">+1,249</div>
            <div class="pos-card-trend trend-up">
                <i data-lucide="trending-up" class="w-4 h-4"></i>
                <span>+8.2% from last month</span>
            </div>
        </div>

        <!-- Stat Card 3 -->
        <div class="pos-card relative overflow-hidden group">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-warning/5 rounded-full blur-2xl group-hover:bg-warning/10 transition-colors"></div>
            <div class="pos-card-header">
                <h3 class="pos-card-title">Active Orders</h3>
                <div class="pos-card-icon bg-warning bg-opacity-10 text-warning">
                    <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                </div>
            </div>
            <div class="pos-card-value">42</div>
            <div class="pos-card-trend text-muted-foreground">
                <i data-lucide="clock" class="w-4 h-4"></i>
                <span>Processing in kitchen</span>
            </div>
        </div>

        <!-- Stat Card 4 -->
        <div class="pos-card relative overflow-hidden group">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-destructive/5 rounded-full blur-2xl group-hover:bg-destructive/10 transition-colors"></div>
            <div class="pos-card-header">
                <h3 class="pos-card-title">Refunds</h3>
                <div class="pos-card-icon bg-destructive/10 text-destructive">
                    <i data-lucide="arrow-down-circle" class="w-5 h-5"></i>
                </div>
            </div>
            <div class="pos-card-value">$420.00</div>
            <div class="pos-card-trend trend-down">
                <i data-lucide="trending-down" class="w-4 h-4"></i>
                <span>-2.1% from last month</span>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Revenue Chart Section -->
        <div class="pos-card lg:col-span-2 flex flex-col">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h3 class="text-lg font-bold">Revenue Analytics</h3>
                    <p class="text-sm text-muted-foreground">Sales performance over the last 7 days</p>
                </div>
                <button class="btn btn-ghost p-2 rounded-full hidden sm:flex">
                    <i data-lucide="more-horizontal" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="flex-1 min-h-[300px] w-full relative bg-primary/5 rounded-xl border border-primary/10 overflow-hidden flex items-end">
                <!-- Artificial SVG Chart representing high-end analytics -->
                <svg viewBox="0 0 800 300" class="w-full h-full absolute bottom-0 drop-shadow-lg" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="chartGlow" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="hsl(var(--primary))" stop-opacity="0.3" />
                            <stop offset="100%" stop-color="hsl(var(--primary))" stop-opacity="0.0" />
                        </linearGradient>
                    </defs>
                    <path d="M0,300 L0,200 C100,200 150,150 250,120 C350,90 400,180 500,150 C600,120 700,50 800,20 L800,300 Z" fill="url(#chartGlow)" />
                    <path d="M0,200 C100,200 150,150 250,120 C350,90 400,180 500,150 C600,120 700,50 800,20" fill="none" stroke="hsl(var(--primary))" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                    <!-- Data points -->
                    <circle cx="250" cy="120" r="6" fill="white" stroke="hsl(var(--primary))" stroke-width="3" />
                    <circle cx="500" cy="150" r="6" fill="white" stroke="hsl(var(--primary))" stroke-width="3" />
                    <circle cx="800" cy="20" r="6" fill="white" stroke="hsl(var(--primary))" stroke-width="3" />
                </svg>
            </div>
        </div>

        <!-- Recent Orders Section -->
        <div class="pos-card flex flex-col">
            <div class="p-6 pb-2 border-b border-border/40">
                <h2 class="font-bold text-lg text-foreground flex items-center">
                    <i data-lucide="clock" class="w-4 h-4 mr-2 text-primary"></i> Recent Orders
                </h2>
            </div>
            
            <div class="p-4 flex flex-col gap-3">
                @if (_recentOrders == null)
                {
                    <div class="flex items-center justify-center p-8">
                        <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-primary"></div>
                    </div>
                }
                else
                {
                    @foreach (var order in _recentOrders.Take(4))
                {
                    var ui = _orderUIs.GetValueOrDefault(order.Id, new OrderUI { Initials = "GU", BgClass = "bg-muted text-muted-foreground", StatusText = "Paid", StatusClass = "badge-success" });
                    var customerName = "Guest User";
                    var timeAgo = GetTimeAgo(order.OrderDate);
                    var orderNumber = GetFormattedOrderNumber(order.Id);

                    <div class="flex items-center justify-between p-3 rounded-lg hover:bg-muted/50 transition-colors border border-transparent hover:border-border/50 cursor-pointer">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full @ui.BgClass flex items-center justify-center font-bold text-sm">
                                @if (customerName == "Guest User")
                                {
                                    <i data-lucide="user" class="w-4 h-4"></i>
                                }
                                else
                                {
                                    @ui.Initials
                                }
                            </div>
                            <div>
                                <p class="text-sm font-semibold">@customerName</p>
                                <p class="text-xs text-muted-foreground">@orderNumber • @timeAgo</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold">$@order.TotalAmount.ToString("F2")</p>
                            <span class="badge @ui.StatusClass mt-1">@ui.StatusText</span>
                        </div>
                    </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    public class OrderUI
    {
        public string Initials { get; set; } = "";
        public string BgClass { get; set; } = "";
        public string StatusText { get; set; } = "";
        public string StatusClass { get; set; } = "";
    }

    private List<Order>? _recentOrders;
    private Dictionary<Guid, OrderUI> _orderUIs = new();

    protected override async Task OnInitializedAsync()
    {
        var pagedOrders = await Http.GetFromJsonAsync<PagedResult<Order>>("sample-data/orders.json");
        var allOrders = pagedOrders?.Data;
        
        if (allOrders != null)
        {
            // Just take the later 4 orders for the dashboard mapping
            _recentOrders = allOrders.Where(o => o.Id.ToString().StartsWith("00000000-0000-0000-0000-0000000089")).ToList();
            if(!_recentOrders.Any()) _recentOrders = allOrders.Take(4).ToList();

            var id1 = Guid.Parse("00000000-0000-0000-0000-000000008923");
            var id2 = Guid.Parse("00000000-0000-0000-0000-000000008922");
            var id3 = Guid.Parse("00000000-0000-0000-0000-000000008921");
            var id4 = Guid.Parse("00000000-0000-0000-0000-000000008920");

            _orderUIs[id1] = new OrderUI { Initials = "JS", BgClass = "bg-primary/10 text-primary", StatusText = "Paid", StatusClass = "badge-success" };
            _orderUIs[id2] = new OrderUI { Initials = "AW", BgClass = "bg-accent text-accent-foreground", StatusText = "Pending", StatusClass = "badge-warning" };
            _orderUIs[id3] = new OrderUI { Initials = "MR", BgClass = "bg-success/20 text-success", StatusText = "Paid", StatusClass = "badge-success" };
            _orderUIs[id4] = new OrderUI { Initials = "GU", BgClass = "bg-muted text-muted-foreground", StatusText = "Paid", StatusClass = "badge-success" };
        }
    }

    private string GetTimeAgo(DateTime date)
    {
        var ts = DateTime.Now - date;
        if (ts.TotalMinutes < 60) return $"{(int)ts.TotalMinutes} mins ago";
        if (ts.TotalHours < 24) return $"{(int)ts.TotalHours} hour{(ts.TotalHours >= 2 ? "s" : "")} ago";
        return date.ToString("MMM dd");
    }

    private string GetFormattedOrderNumber(Guid id)
    {
        var idStr = id.ToString().Split('-').Last().ToUpper();
        if (idStr.Length > 4) idStr = idStr.Substring(idStr.Length - 4);
        return $"ORD-{idStr}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initIcons");
        }
    }
}