@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject HttpClient Http
@using MiniPos.Frontend.Shared.Services
@inject NotificationService NotificationService

<div class="dashboard-layout animate-fade-in">
    @if (@_isAuthenticated)
    {
        <!-- Premium Glass Sidebar -->
        <aside class="dashboard-sidebar shadow-lg">
            <div class="logo-container">
                <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center mr-3">
                    <i data-lucide="zap" class="w-5 h-5 text-primary"></i>
                </div>
                <span class="tracking-tight font-bold text-foreground">MiniPOS</span>
                <span class="text-primary ml-1">.</span>
            </div>

            <div class="p-4 flex-1 overflow-y-auto">
                <NavMenu />
            </div>

            <!-- Premium Footer Profile in Sidebar -->
            <div class="p-2 border-t border-border/50 bg-white/50 m-2 rounded-xl shadow-sm cursor-pointer hover:bg-white/80 transition-all hover:shadow-md group">
                @* <div class="flex items-center gap-3" @onclick='() => Navigation.NavigateTo("/profile")'> *@
                @*     <div class="avatar shadow-md shrink-0 bg-blue-500 flex items-center justify-center text-white font-bold"> *@
                @*         <i data-lucide="user" class="w-4 h-4"></i> *@
                @*     </div> *@
                @*     <div class="flex-col overflow-hidden"> *@
                @*         <span class="text-xs font-semibold truncate block uppercase tracking-tighter">POS Terminal</span> *@
                @*         <span class="text-[10px] text-muted-foreground truncate block">Active Session</span> *@
                @*     </div> *@
                @* </div> *@
                <button @onclick="() => _showSignoutPrompt = true" class="w-full mt-3 btn btn-outline border-border/50 bg-white hover:bg-red-50 hover:text-red-600 hover:border-red-200 text-xs justify-between group py-2">
                    Signout
                    <i data-lucide="log-out" class="w-3 h-3 text-muted-foreground group-hover:text-red-600 transition-colors"></i>
                </button>
            </div>
        </aside>

        @if (_showSignoutPrompt)
        {
            <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/40 backdrop-blur-sm animate-fade-in">
                <div class="w-full max-w-sm bg-white/90 backdrop-blur-xl border border-white/20 rounded-2xl shadow-2xl overflow-hidden animate-scale-in">
                    <div class="p-6 text-center">
                        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i data-lucide="log-out" class="w-8 h-8 text-red-600"></i>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 mb-2">Confirm Signout</h3>
                        <p class="text-slate-500 mb-6">Are you sure you want to sign out of your session?</p>
                        
                        <div class="flex gap-3">
                            <button @onclick="() => _showSignoutPrompt = false" class="flex-1 btn btn-outline border-slate-200 text-slate-600 hover:bg-slate-50">
                                Cancel
                            </button>
                            <button @onclick="HandleSignout" class="flex-1 btn bg-red-600 hover:bg-red-700 text-white shadow-lg shadow-red-200 border-none font-bold">
                                Yes, Signout
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Main Content Area -->
        <div class="dashboard-main">
            <!-- Floating App Bar -->
            <header class="dashboard-header animate-slide-down">
                <div class="flex items-center gap-4">
                    <button class="btn btn-ghost p-2 sm:hidden rounded-full" aria-label="Toggle Sidebar">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    @* Search removed as per request *@
                </div>

                <div class="flex items-center gap-4">
                    <button class="relative btn btn-ghost p-2 rounded-full hover:bg-white shadow-sm border border-transparent hover:border-border/40">
                        <i data-lucide="bell" class="w-5 h-5 text-muted-foreground"></i>
                        <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-destructive rounded-full border border-white"></span>
                    </button>
                </div>
            </header>

            <!-- Dynamic Page Content (Extended Width) -->
            <main class="dashboard-content">
                    @Body
            </main>
        </div>
    }
    else
    {
        <div class="h-screen w-full flex items-center justify-center bg-slate-950">
             <div class="animate-spin rounded-full h-8 w-8 border-2 border-t-blue-600 border-white/10"></div>
        </div>
    }
</div>

<!-- Global Toast Notifications -->
<Toast />

@code {
    private bool _isAuthenticated = false;
    private bool _showSignoutPrompt = false;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthentication();
    }

    private async Task CheckAuthentication()
    {
            _isAuthenticated = false;
            var request = await Http.GetAsync("api/auth/check");
            if (!request.IsSuccessStatusCode)            {
                 Navigation.NavigateTo("/login");
                 return;
            }
            _isAuthenticated = true;
    }

    private async Task HandleSignout()
    {
        try 
        {
            var response = await Http.GetAsync("api/auth/signout");
            if (!response.IsSuccessStatusCode)
            {
                return;
            }
                Navigation.NavigateTo("/login");
        }
        catch 
        {
            Navigation.NavigateTo("/login");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("initIcons");
    }
}